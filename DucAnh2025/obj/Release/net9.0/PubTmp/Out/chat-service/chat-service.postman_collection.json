        {
          "name": "Socket.IO Auth Notes",
          "request": {
            "description": "Socket namespace: `{{baseUrl}}/chat`. Browser client connects with `io('{{baseUrl}}/chat', { auth: { token: '{{token}}' }, transports: ['websocket', 'polling'] })`. Events: `conversation:join`, `message:send`, `message:seen`, `message:typing`. Server emits: `message:new`, `message:seen`, `message:typing`, `presence:online`, `presence:offline`, `notification:new`.",
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/socket.io/?EIO=4&transport=polling",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "socket.io",
                ""
              ],
              "query": [
                {
                  "key": "EIO",
                  "value": "4"
                },
                {
                  "key": "transport",
                  "value": "polling"
                }
              ]
            }
