    {
      "name": "Auth",
      "description": "Use ASP.NET API to obtain a JWT compatible with chat-service. If web login uses cookies, first sign in on the web app, then call Get JWT Token with cookies enabled.",
      "item": [
        {
          "name": "Login - ASP.NET API",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login returned 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.token) { pm.environment.set(\"token\", pm.response.json().token); }",
                  "const token = json.token || json.Token || json.data?.token || json.data?.Token;",
                  "if (token) pm.environment.set('token', token);",
                  "pm.test('token saved when present', function () { pm.expect(pm.environment.get('token') || '').to.not.equal(''); });"
                ]
              }
            }
          ],
          "request": {
            "description": "Authenticates against ASP.NET `/api/User/Login`. The response token is saved into `token`.",
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{webBaseUrl}}/api/User/Login",
              "host": [
                "{{webBaseUrl}}"
              ],
              "path": [
                "api",
                "User",
                "Login"
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"P@ssw0rd!\"\n}"
                },
                "url": "{{webBaseUrl}}/api/User/Login"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Dang nhap thanh cong\",\n  \"data\": {\n    \"token\": \"jwt-token\",\n    \"expiration\": \"2026-05-25T12:00:00\"\n  }\n}"
            },
            {
              "name": "Failed",
              "originalRequest": {
                "method": "POST",
                "header": [],
                "url": "{{webBaseUrl}}/api/User/Login"
              },
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"Mat khau khong dung\",\n  \"data\": null\n}"
            }
          ]
        },
        {
          "name": "Get JWT Token - Cookie Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('get token returned 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.token) { pm.environment.set(\"token\", pm.response.json().token); }",
                  "const token = json.token || json.Token;",
                  "if (token) pm.environment.set('token', token);",
                  "if (json.userInfor?.id) pm.environment.set('userId', json.userInfor.id);",
                  "if (json.userInfor?.groupId) pm.environment.set('groupId', json.userInfor.groupId);"
                ]
              }
            }
          ],
          "request": {
            "description": "Gets a JWT from the current ASP.NET cookie session. Enable cookie jar in Postman or call after browser login.",
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{webBaseUrl}}/api/User/GetJwtToken",
              "host": [
                "{{webBaseUrl}}"
              ],
              "path": [
                "api",
                "User",
                "GetJwtToken"
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": "{{webBaseUrl}}/api/User/GetJwtToken"
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"token\": \"jwt-token\",\n  \"userInfor\": {\n    \"id\": \"user-id\",\n    \"userName\": \"user@example.com\",\n    \"groupId\": \"group-id\",\n    \"companyId\": \"company-id\",\n    \"name\": \"User Name\"\n  }\n}"
            }
          ]
        },
