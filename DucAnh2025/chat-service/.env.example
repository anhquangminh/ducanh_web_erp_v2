PORT=3000
NODE_ENV=development
CORS_ORIGINS=https://localhost:5001,http://localhost:5000,http://localhost:5220

# Must match ASP.NET Core Jwt settings in appsettings.json
JWT_ISSUER=https://ducanherp.com
JWT_AUDIENCE=quangminh
JWT_KEY=hisIsAReallyStrongSecretKeyThatIs32BytesLong1234

# Existing SQL Server database used by DucAnh2025
SQL_SERVER=IT\SQLEXPRESS
SQL_DATABASE=Minh2024
SQL_USER=sa
SQL_PASSWORD=1
SQL_ENCRYPT=false

MONGODB_URI=mongodb://127.0.0.1:27017/chat-service
MONGODB_DB_NAME=chat-service
REDIS_URL=
MEDIA_ROOT=./uploads/chat
CHAT_PUBLIC_BASE_URL=http://localhost:3000
INTERNAL_AUTH_SECRET=dev-chat-internal-secret-change-me
# Prefer this when notification is centralized in the main API.
FCM_NOTIFICATION_API_URL=http://192.168.9.104:8080/api/Fcm/send-notification
FCM_NOTIFICATION_API_TIMEOUT_MS=60000

# AI assistant. Leave AI_PROVIDER empty to disable AI replies.
# Supported: openai, gemini, ollama
AI_PROVIDER=
AI_ASSISTANT_NAME=AI Assistant
AI_SYSTEM_PROMPT=Bạn là trợ lý AI hữu ích, trả lời ngắn gọn, rõ ràng và thân thiện bằng tiếng Việt khi phù hợp.
AI_MAX_HISTORY_MESSAGES=20
AI_REQUEST_TIMEOUT_MS=60000

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
