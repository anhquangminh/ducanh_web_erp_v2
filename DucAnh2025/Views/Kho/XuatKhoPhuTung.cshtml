                                  url: `/api/caidatsoluotduyet/ListStepSetting?groupId=${groupId}&majorId=523f812e-5bf5-4784-bbf4-d986816796d1&departmentId=${dept.id || ''}&permissionId=${permissionMap[tab]}`,
