@using DucAnh2025.Models
@using DucAnh2025.Models.Accounts
@model LoginModel

@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Đăng nhập";
}

<div class="app-container app-theme-white body-tabs-shadow">
    <div class="app-container">
        <div class="h-100">
            <div class="h-100 no-gutters row">
                <div class="d-none d-lg-block col-lg-4">
                    <div class="slider-light">
                        <div class="slick-slider">
                            <div>
                                <div class="position-relative h-100 d-flex justify-content-center align-items-center bg-plum-plate" tabindex="-1">
                                    <div class="slide-img-bg" style="background-image: url('../assets/images/login.jpg');"></div>
                                    <div class="slider-content">
                                        <h3>Đức Anh</h3>
                                        <p>Bê tông Đức Anh niềm tin của mọi công trình</p>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="position-relative h-100 d-flex justify-content-center align-items-center bg-premium-dark" tabindex="-1">
                                    <div class="slide-img-bg" style="background-image: url('../assets/images/khucn.jpg');"></div>
                                    <div class="slider-content">
                                        <h3>Quản lý công việc</h3>
                                        <p>Tổ chức công việc – Dẫn lối thành công</p>
                                    </div>
                                </div>
                            </div>
                            <div>
                                <div class="position-relative h-100 d-flex justify-content-center align-items-center bg-sunny-morning" tabindex="-1">
                                    <div class="slide-img-bg" style="background-image: url('../assets/images/originals/citydark.jpg');"></div>
                                    <div class="slider-content">
                                        <h3>CRM</h3>
                                        <p>Tối ưu công việc, tăng tốc hiệu quả</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="h-100 d-flex bg-white justify-content-center align-items-center col-md-12 col-lg-8">
                    <div class="mx-auto app-login-box col-sm-12 col-md-10 col-lg-9">
                        <img src="~/assets/images/logoLG.jpg" width="150" />
                        <h4 class="mb-0 mt-2">
                            <span class="d-block">Xin chào,</span>
                            <span>Vui lòng đăng nhập tài khoản của bạn.</span>
                        </h4>
                        <h6 class="mt-3">Tạo mới ? <a href="/Account/Register" class="text-primary">đăng ký</a></h6>
                        <h6 class="mt-3"><a href="/Account/QrSignInPage" class="text-primary">Đăng nhập bằng qr code.</a></h6>
                        <div class="divider row"></div>
                        <div>
                            <form asp-action="Login" method="post">
                                <div asp-validation-summary="All" class="text-danger"></div>
                                <div class="form-row">
                                    <div class="col-md-6">
                                        <div class="position-relative form-group">
                                            <label asp-for="Email">Email</label>
                                            <input asp-for="Email" class="form-control" placeholder="Email" />
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="position-relative form-group">
                                            <label asp-for="Password">Mật khẩu</label>
                                            <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu" value="@Model.Password" autocomplete="current-password" />
                                        </div>
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="form-check d-flex justify-content-end align-items-center">
                                    <div class="row">
                                        <input asp-for="RememberMe" type="checkbox" class="form-check-input me-2">
                                        <label asp-for="RememberMe" class="form-check-label">Lưu thông tin đăng nhập</label>
                                    </div>
                                </div>

                                <div class="divider row"></div>
                                <div class="d-flex align-items-center">
                                    <div class="ml-auto">
                                        <a href="/Account/forgotpassword">Quên mật khẩu?</a>
                                        <a href="/Account/resendconfirmationemail">Gửi lại email xác nhận</a>
                                        <button type="submit" class="btn btn-primary btn-lg">Đăng nhập</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
