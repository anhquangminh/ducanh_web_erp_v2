@using DucAnh2025.ViewModels.Accounts
@model LoginWithRecoveryCodeViewModel
@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Recovery code verification";
}

<h1>Recovery code verification</h1>
<hr />
@if (ViewBag.StatusMessage != null)
{
    <div class="alert alert-danger">@ViewBag.StatusMessage</div>
}
<p>
    You have requested to log in with a recovery code. This login will not be remembered until you provide
    an authenticator app code at log in or disable 2FA and log in again.
</p>
<div class="row">
    <div class="col-md-4">
        <form asp-action="LoginWithRecoveryCode" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="form-floating mb-3">
                <input asp-for="RecoveryCode" class="form-control" autocomplete="off" />
                <label asp-for="RecoveryCode" class="form-label"></label>
                <span asp-validation-for="RecoveryCode" class="text-danger"></span>
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>
        </form>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
