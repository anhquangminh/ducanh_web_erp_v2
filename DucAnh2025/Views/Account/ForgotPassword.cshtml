@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Forgot your password?";
}

<div class="app-container app-theme-white body-tabs-shadow">
    <div class="container d-flex justify-content-center align-items-center min-vh-100">
        <div class="card shadow-lg p-4 col-sm-12 col-md-10 col-lg-6">
            <div class="card-body">
                <h3 class="text-center mb-2">Quên mật khẩu?</h3>
                <p class="text-center text-muted mb-4">Vui lòng nhập email để đặt lại mật khẩu</p>
                <hr />

                <form asp-action="ForgotPassword" method="post">
                    <div class="form-floating mb-3">
                        <input type="email" name="email" id="email" class="form-control" required placeholder="name@example.com" />
                        <label for="email">Email</label>
                    </div>

                    <button type="submit" class="w-100 btn btn-primary btn-lg">Gửi liên kết đặt lại mật khẩu</button>
                </form>
            </div>
        </div>
    </div>
</div>

