<div class="tab-content">
    <div class="card mt-3 p-2">
        <div class="card-header">
            <h3 class="m-0 mr-2">Danh sách</h3>
            <span style="cursor:pointer;" onclick="showHuongDanNghiepVu()" title="Hướng dẫn sử dụng">
                <i class="bi bi-question-circle-fill text-info" style="font-size: 1.5em;"></i>
            </span>
        </div>
        <div class="card-body">
            <div>
                <button data-permission="Tao" class="mb-2 mr-2 btn-icon btn btn-primary" onclick="showModalTaoMoi()">
                    <i class="fas fa-plus btn-icon-wrapper"></i>Tạo mới
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover" id="table_chinhanh">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Thuộc tổ chức</th>
                            <th>Tên chi nhánh</th>
                            <th>Loại chi nhánh</th>
                            <th>Điện thoại</th>
                            <th>Email</th>
                            <th>Địa chỉ</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>#</th>
                            <th>Thuộc tổ chức</th>
                            <th>Tên loại chi nhánh</th>
                            <th>Loại chi nhánh</th>
                            <th>Điện thoại</th>
                            <th>Email</th>
                            <th>Địa chỉ</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
     $(function () {
         loadData();
     });

     function loadData() {
         getJwtToken().then(function (resUser) {
             $.ajax({
                 url: "/api/ChiNhanh/GetByVM?groupId=" + resUser.userInfor.groupId,
                 method: "POST",
                 headers: {
                     "Content-Type": "application/json",
                     "Authorization": "Bearer " + resUser.token
                 },
                 data: JSON.stringify({
                     Id : "",
                     ParentId : "",
                     TenChiNhanh : "",
                     CompanyType : "",
                     Phone : "",
                     Email : "",
                     Address : "",
                     GroupId : "",
                     Ordinarily : 0,
                     CreateAt : null,
                     CreateBy : "",
                     IsActive : 0,
                     ApprovalUserId : "",
                     DateApproval : null,
                     ApprovalDept : "",
                     DepartmentId : "",
                     DepartmentOrder : 0,
                     ApprovalOrder : 0,
                     ApprovalId : "",
                     LastApprovalId : "",
                     IsStatus : ""
                 })
             }).done(function (res) {
                 let dataSet = [];
                 if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                     dataSet = res.data.map((item, idx) => ({
                         stt: idx + 1,
                         id: item.id,
                         parentId :item.parentId ||'',
                         tenChiNhanh: item.tenChiNhanh ||'',
                         companyType: item.companyType ||'',
                         phone: item.phone ||'',
                         email: item.email ||'',
                         address: item.address ||'',
                         isStatus: item.isStatus ||'',
                         isActive: item.isActive ||'',
                     }));
                 }

                 const $table = $('#table_chinhanh');
                 if ($.fn.DataTable.isDataTable($table)) {
                     $table.DataTable().clear().destroy();
                 }

                 $table.DataTable({
                     data: dataSet,
                     columns: [
                         { data: 'stt', className: 'text-center align-middle', width: '5%' },
                         { data: 'parentId', className: 'align-middle' },
                         { data: 'tenChiNhanh', className: 'align-middle' },
                         { data: 'companyType', className: 'align-middle' },
                         { data: 'phone', className: 'align-middle' },
                         { data: 'email', className: 'align-middle' },
                         { data: 'address', className: 'align-middle' },
                         { data: 'isStatus', className: 'align-middle' },
                         {
                             data: null,
                             className: 'text-center align-middle',
                             orderable: false,
                             width: "1%",
                             render: function (data, type, row) {
                                 let buttons = `
                                     <div class="btn-group">
                                 `;
                                 // Chỉ hiển thị nút duyệt/hủy duyệt khi isActive == 0 (chờ duyệt)
                                 if (row.isActive != 3) {
                                     buttons += `
                                         <button class="btn btn-sm btn-success btn-approve" title="Duyệt" data-id="${row.id}" onclick="duyet('${row.id}')"><i class="fas fa-check"></i></button>
                                         <button class="btn btn-sm btn-warning btn-cancel-approve" title="Hủy duyệt" data-id="${row.id}" onclick="huyDuyet('${row.id}')"><i class="fas fa-times"></i></button>
                                     `;
                                 }
                                 buttons += `
                                     <button class="btn btn-sm btn-danger btn-delete" title="Chi tiết" data-id="${row.id}" onclick=chiTiet("${row.id}")><i class="fas fa-eye"></i></button>
                                     <button class="btn btn-sm btn-primary btn-edit" title="Chỉnh sửa" data-id="${row.id}" onclick=editCaiDat("${row.id}")><i class="fas fa-edit"></i></button>
                                     <button class="btn btn-sm btn-danger btn-delete" title="Xóa" data-id="${row.id}" onclick=deleteCaiDat("${row.id}")><i class="fas fa-trash"></i></button>

                                 </div>
                                 `;
                                 return buttons;
                            }
                        }
                     ],
                     autoWidth: false,
                     scrollX: false,
                     ordering: true,
                     searching: true,
                     paging: true,
                     pageLength: 10,
                     info: true,
                     language: {
                         lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                         zeroRecords: "Không tìm thấy dữ liệu",
                         info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                         infoEmpty: "Không có bản ghi nào",
                         infoFiltered: "(lọc từ _MAX_ bản ghi)",
                         search: "Tìm kiếm:",
                         paginate: {
                             first: "Đầu",
                             last: "Cuối",
                             next: "Sau",
                             previous: "Trước"
                         }
                     },
                      initComplete: function () {
                          this.api().columns().every(function () {
                              var column = this;
                              var select = $('<select><option value=""></option></select>')
                                  .appendTo($(column.footer()).empty())
                                  .on('change', function () {
                                      var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                      column
                                          .search(val ? '^' + val + '$' : '', true, false)
                                          .draw();
                                  });

                              column.data().unique().sort().each(function (d) {
                                  select.append('<option value="' + d + '">' + d + '</option>');
                              });
                          });
                      }
                 });
             }).fail(function (xhr) {
                 $('#table_chinhanh tbody').html('<tr><td colspan="7" class="text-center text-danger">Lỗi khi tải dữ liệu.</td></tr>');
             });
         });
     }


     // Helper to render approval dept/step content
     function renderApprovalDept() {
         return `
             <div id="smartwizard3" class="forms-wizard-vertical sw-main sw-theme-default">
                 <ul class="forms-wizard nav nav-tabs step-anchor">

                 </ul>
                 <div class="form-wizard-content sw-container tab-content" style="min-height: 300px;">
                     <div id="step-122" class="tab-pane step-content" style="display: block;">
                         <div class="card-body">

                         </div>
                     </div>
                 </div>
             </div>
         `;
     }

     async function showModalTaoMoi(isEdit = false, data = null) {
         const modalTitle = isEdit ? "Cập nhật " : "Thêm mới ";

         const bodyHtml = `
             <form id="form_caidat">
                 <div class="form-row">
                     <!-- Tổ chức -->
                     <div class="form-group col-md-3">
                         <label>Thuộc tổ chức</label>
                         <select class="form-control" id="ddlChiNhanh"><option value="">-- Chọn tổ chức --</option></select>
                     </div>
                     <!-- Tên chi nhánh -->
                     <div class="form-group col-md-3">
                         <label>Tên chi nhánh</label>
                         <input type="text" id="input-tenChiNhanh" name="name" value="${data ? data.tenChiNhanh : ''}" class="form-control" />
                     </div>
                     <!-- Loại chi nhánh -->
                     <div class="form-group col-md-3">
                         <label>Loại chi nhánh </label>
                         <select class="form-control" id="ddlLoaiChiNhanh"><option value="">-- Chọn loại chi nhánh --</option></select>
                     </div>
                     <!-- Điện thoại -->
                     <div class="form-group col-md-3">
                         <label>Điện thoại</label>
                         <input type="phone" id="input-phone" name="name" value="${data ? data.phone : ''}" class="form-control" />
                     </div>
                      <!-- Email-->
                     <div class="form-group col-md-3">
                         <label>Email</label>
                         <input type="email" id="input-email" name="name" value="${data ? data.email : ''}" class="form-control" />
                     </div>
                       <!-- Địa chỉ-->
                     <div class="form-group col-md-3">
                         <label>Địa chỉ</label>
                         <input type="text" id="input-address" name="name" value="${data ? data.address : ''}" class="form-control" />
                     </div>
                 </div>
             </form>
             <div id="error_msg" class="text-danger font-weight-bold mb-2"></div>
         `;

         const footerHtml = `
             <button type="button" class="btn btn-primary" id="btnLuuCaiDat">${isEdit ? "Cập nhật" : "Lưu "}</button>
             <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>`;

         showGlobalModal(modalTitle, bodyHtml, footerHtml);
         $('#btnLuuCaiDat').data("isedit", isEdit).data("id", data?.id || "");

         await loadAllDropdowns();
         // Sự kiện click nút Lưu
         $('#btnLuuCaiDat').off('click').on('click', async function () {
             $('#error_msg').text("");
             $('#form_caidat select, #form_caidat input').removeClass('is-invalid');
             let isValid = true;
             let errorMessages = [];

             // Validate tất cả dropdown (select)
             $('#form_caidat select').each(function () {
                 if (!$(this).val() || $(this).val().trim() === "") {
                     $(this).addClass('is-invalid');
                     isValid = false;
                     errorMessages.push("Vui lòng chọn " + ($('label[for="' + $(this).attr('id') + '"]').text() || "trường bắt buộc") + ".");
                 }
             });

             // Validate tất cả input (không để trống và đúng định dạng)
             $('#form_caidat input').each(function () {
                 const $input = $(this);
                 const val = $input.val().trim();
                 const type = $input.attr('type');
                 const label = $input.closest('.form-group').find('label').text() || "Trường bắt buộc";

                 if (!val) {
                     $input.addClass('is-invalid');
                     isValid = false;
                     errorMessages.push("Vui lòng nhập " + label + ".");
                 } else {

                      if (type === "phone" || $input.attr('id').toLowerCase().includes('phone')) {
                            if (!isValidPhoneNumber(val)) {
                                 $input.addClass('is-invalid');
                                 isValid = false;
                                 errorMessages.push("Số điện thoại không đúng định dạng.");
                            }
                      }

                       if (type === "email" || $input.attr('id').toLowerCase().includes('email')) {
                             if (!isValidEmail(val)) {
                                $input.addClass('is-invalid');
                                isValid = false;
                                errorMessages.push("Email không đúng định dạng.");
                             }
                       }
                 }
             });

             if (!isValid) {
                 $('#error_msg').html(errorMessages.join("<br/>"));
                 return;
             }

             // Lấy thông tin user
             const resUser = await getJwtToken();
             const token = resUser.token;
             const groupId = resUser.userInfor.groupId;
             const userName = resUser.userInfor.userName;

             // Chuẩn bị dữ liệu gửi lên API
             const isEdit = $(this).data("isedit") === true;
             const id = $(this).data("id") || generateUUID();

             const dataSend = {
                  Id: isEdit ? id : "",
                  ParentId : $('#ddlChiNhanh').val(),
                  TenChiNhanh : $('#input-tenChiNhanh').val(),
                   CompanyType : $('#ddlLoaiChiNhanh').val(),
                   Phone : $('#input-phone').val(),
                   Email : $('#input-email').val(),
                   Address :$('#input-address').val(),
                  GroupId : groupId,
                 Ordinarily : 0,
                  CreateAt: new Date().toISOString(),
                  CreateBy: userName,
                  IsActive: isEdit && data ? data.isActive : 0,
                 ApprovalUserId : "",
                  DateApproval : null,
                 ApprovalDept : "",
                 DepartmentId : "",
                 DepartmentOrder : 0,
                 ApprovalOrder : 0,
                 ApprovalId : "",
                 LastApprovalId : "",
                 IsStatus : ""
             };

             try {
                 // Gọi API lưu
                 const res = await $.ajax({
                      url: `/api/ChiNhanh/CreateChiNhanh?isEdit=${isEdit}`,
                     method: "POST",
                     contentType: "application/json",
                     headers: { Authorization: `Bearer ${token}` },
                     data: JSON.stringify(dataSend)
                 });

                 if (res.success) {
                     showToastSuccess(isEdit ? "Cập nhật thành công!" : "Lưu thành công!");
                     $('#globalModal').modal('hide');
                     loadData();
                 } else {
                     $('#error_msg').text(res.message || "Có lỗi xảy ra khi lưu.");
                     showToastError(res.message || "Có lỗi xảy ra khi lưu.");
                 }
             } catch (err) {
                 $('#error_msg').text("Lỗi hệ thống khi lưu dữ liệu.");
             }
         });

          setTimeout(function () {
            $('#globalModal select').select2({
                width: '100%',
                      theme: 'bootstrap4',
                      dropdownParent: $('#globalModal')
                  });
         }, 100);
     }


    async function getUserInfo() {
         const res = await getJwtToken();
         return { token: res.token, groupId: res.userInfor.groupId ,userName : res.userInfor.userName };
     }

     async function loadAllDropdowns() {
         const { token, groupId } = await getUserInfo();

         // Load Chi nhánh
         await $.ajax({
             url: `/api/chinhanh/getall?groupId=${groupId}`,
             headers: { Authorization: `Bearer ${token}` }
         }).done(res => {
             const ddl = $('#ddlChiNhanh');
             ddl.empty().append('<option value="">-- Chọn chi nhánh --</option>');
             res.data?.forEach(x => ddl.append(`<option value="${x.id}">${x.tenChiNhanh}</option>`));
         });

         // Load Nghiệp vụ cha
         await $.ajax({
               url: `/api/loaichinhanh/GetAll?groupId=${groupId }`,
             headers: { Authorization: `Bearer ${token}` }
         }).done(res => {
             const ddl = $('#ddlLoaiChiNhanh');
             ddl.empty().append('<option value="">-- Chọn loại chi nhánh --</option>');
               res.data?.forEach(x => ddl.append(`<option value="${x.id}">${x.tenLoaiChiNhanh}</option>`));
          }).fail(function (xhr) {
                  console.log('lỗi ');
              });

     }

     async function editCaiDat(id) {
         const { token } = await getUserInfo();
         try {
             const res = await $.ajax({
                 url: `/api/chinhanh/GetById?id=${id}`,
                 method: 'GET',
                 headers: { Authorization: `Bearer ${token}` }
             });

             if (!res.success || !res.data) {
                 alert(res.message || 'Không lấy được dữ liệu');
                 return;
             }

             await showModalTaoMoi(true, res.data);

             // Set loại tổ chức
               $('#ddlChiNhanh').val(res.data.parentId).trigger('change');
             // Set loaichinhanh
               $('#ddlLoaiChiNhanh').val(res.data.companyType).trigger('change');

         } catch (err) {
             console.error('editCaiDat error:', err);
             alert('Lỗi khi load dữ liệu!');
         }
     }

     async function chiTiet(id) {
         const resUser = await getJwtToken();
         const token = resUser.token;

         try {
             const res = await $.ajax({
                 url: `/api/ChiNhanh/GetHistory?id=${id}`,
                 method: "GET",
                 headers: { Authorization: `Bearer ${token}` }
             });

             if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                 let tableRows = res.data.map((item, idx) => `
                     <tr>
                         <td class="text-center">${idx + 1}</td>
                         <td>${item.tenChiNhanh || ''}</td>
                         <td>${item.isStatus || ''}</td>
                         <td>${item.createBy || ''}</td>
                         <td>${item.createAt ? new Date(item.createAt).toLocaleString() : ''}</td>
                     </tr>
                 `).join('');

                 const bodyHtml = `
                     <div class="table-responsive">
                         <table class="table table-bordered table-hover">
                             <thead class="thead-light">
                                 <tr>
                                     <th class="text-center">#</th>
                                     <th>Tên loại chi nhánh</th>
                                     <th>Trạng thái</th>
                                     <th>Người thao tác</th>
                                     <th>Thời gian</th>
                                 </tr>
                             </thead>
                             <tbody>
                                 ${tableRows}
                             </tbody>
                         </table>
                     </div>
                 `;

                 showGlobalModal("Lịch sử loại chi nhánh", bodyHtml, `<button class="btn btn-secondary" data-dismiss="modal">Đóng</button>`);
             } else {
                 showGlobalModal("Lịch sử loại chi nhánh", `<div class="text-center text-muted">Không có dữ liệu lịch sử.</div>`, `<button class="btn btn-secondary" data-dismiss="modal">Đóng</button>`);
             }
         } catch (err) {
             showGlobalModal("Lịch sử loại chi nhánh", `<div class="text-center text-danger">Lỗi khi tải dữ liệu lịch sử.</div>`, `<button class="btn btn-secondary" data-dismiss="modal">Đóng</button>`);
         }
     }
         // Duyệt loại chi nhánh
     async function duyet(id) {
         if (!confirm('Bạn có chắc chắn muốn duyệt loại chi nhánh này?')) return;
         const resUser = await getJwtToken();
         const token = resUser.token;
         try {
             const res = await $.ajax({
                 url: `/api/ChiNhanh/Duyet?id=${id}`,
                 method: "POST",
                 headers: { Authorization: `Bearer ${token}` }
             });
             if (res.success) {
                 showToastSuccess("Duyệt thành công!");
                 loadData();
             } else {
                 showToastError(res.message || "Duyệt thất bại!");
             }
         } catch (err) {
             showToastError("Lỗi hệ thống khi duyệt!");
         }
     }

     // Hủy duyệt loại chi nhánh
     async function huyDuyet(id) {
         if (!confirm('Bạn có chắc chắn muốn hủy duyệt loại chi nhánh này?')) return;
         const resUser = await getJwtToken();
         const token = resUser.token;
         try {
             const res = await $.ajax({
                 url: `/api/ChiNhanh/HuyDuyet?id=${id}`,
                 method: "POST",
                 headers: { Authorization: `Bearer ${token}` }
             });
             if (res.success) {
                 showToastSuccess("Hủy duyệt thành công!");
                 loadData();
             } else {
                 showToastError(res.message || "Hủy duyệt thất bại!");
             }
         } catch (err) {
             showToastError("Lỗi hệ thống khi hủy duyệt!");
         }
     }


     // Xóa loại chi nhánh
     async function deleteCaiDat(id) {
         if (!confirm('Bạn có chắc chắn muốn xóa loại chi nhánh này?')) return;
         const resUser = await getJwtToken();
         const token = resUser.token;
         try {
             const res = await $.ajax({
                 url: `/api/ChiNhanh/${id}`,
                 method: "DELETE",
                 headers: { Authorization: `Bearer ${token}` }
             });
             if (res.success) {
                 showToastSuccess("Xóa thành công!");
                 loadData();
             } else {
                 showToastError(res.message || "Xóa thất bại!");
             }
         } catch (err) {
             showToastError("Lỗi hệ thống khi xóa!");
         }
     }


      function showHuongDanNghiepVu() {
          const headerHtml =
              `<div><div class="card-header">
                  <i class="header-icon lnr-license icon-gradient bg-plum-plate"></i>
                  <form id="SearchInfo">
                      <select id="ChiNhanhInfo" class="form-control">
                          <option value="">-- Chọn chi nhánh --</option>
                      </select>
                  </form>
                  <div class="btn-actions-pane-right">
                      <div role="group" class="btn-group-sm nav btn-group">
                          <a data-toggle="tab" href="#tab-hdsd" class="btn-shadow active btn btn-primary">Hướng dẫn sử dụng</a>
                          <a data-toggle="tab" href="#tab-ttd" class="btn-shadow  btn btn-primary">Thứ tự duyệt</a>
                      </div>
                  </div>
              </div>`;

          const tabsHtml = `
              <div class="card-body">
                  <div class="tab-content">
                      <div class="tab-pane tabs-animation fade active show" id="tab-hdsd" role="tabpanel">
                          <div class="p-3">Nội dung hướng dẫn sử dụng...</div>
                      </div>
                      <div class="tab-pane tabs-animation fade" id="tab-ttd" role="tabpanel">
                          <div class="row">
                              <div class="col-md-12">
                                  <div>
                                      <div class="mb-3">
                                          <div role="group" class="btn-group-sm nav btn-group">
                                              <a data-toggle="tab" href="#tab-them" class="btn-pill pl-3 btn btn-warning active show">Thêm</a>
                                              <a data-toggle="tab" href="#tab-sua" class="btn btn-warning show">Sửa</a>
                                              <a data-toggle="tab" href="#tab-xoa" class="btn-pill pr-3 btn btn-warning show">Xóa</a>
                                          </div>
                                      </div>
                                      <div class="tab-content">
                                          <div class="tab-pane show active" id="tab-them" role="tabpanel">
                                              <div class="row">
                                                  <div class="col-md-4">
                                                      <ul class="list-group" id="ul-them"></ul>
                                                  </div>
                                                  <div class="col-md-8">
                                                      <div class="card-body" id="content-them">Chọn phòng ban để xem chi tiết</div>
                                                  </div>
                                              </div>
                                          </div>
                                          <div class="tab-pane show" id="tab-sua" role="tabpanel">
                                              <div class="row">
                                                  <div class="col-md-4">
                                                      <ul class="list-group" id="ul-sua"></ul>
                                                  </div>
                                                  <div class="col-md-8">
                                                      <div class="card-body" id="content-sua">Chọn phòng ban để xem chi tiết</div>
                                                  </div>
                                              </div>
                                          </div>
                                          <div class="tab-pane show" id="tab-xoa" role="tabpanel">
                                              <div class="row">
                                                  <div class="col-md-4">
                                                      <ul class="list-group" id="ul-xoa"></ul>
                                                  </div>
                                                  <div class="col-md-8">
                                                      <div class="card-body" id="content-xoa">Chọn phòng ban để xem chi tiết</div>
                                                  </div>
                                              </div>
                                          </div>
                                      </div>
                                  </div>
                              </div>
                          </div>
                      </div>
                  </div>
              </div>
          `;

          const bodyHtml = headerHtml + tabsHtml;
          const footerHtml = `<button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>`;

          showGlobalModal("Thông tin nghiệp vụ", bodyHtml, footerHtml);

          // Lấy groupId và token, sau đó gọi API lấy danh sách chi nhánh
          getJwtToken().then(function (resUser) {
              const groupId = resUser.userInfor.groupId;
              $.ajax({
                  url: `/api/caidatsoluotduyet/GetChiNhanhsForCompanyId?groupId=${groupId}`,
                  method: "GET",
                  headers: {
                      "Authorization": "Bearer " + resUser.token
                  }
              }).done(function (res) {
                  const $ddl = $('#ChiNhanhInfo');
                  $ddl.empty().append('<option value="">-- Chọn chi nhánh --</option>');
                  if (res.success && Array.isArray(res.data)) {
                      res.data.forEach(function (item) {
                          $ddl.append(`<option value="${item.id}">${item.tenChiNhanh}</option>`);
                      });
                  }
              }).fail(function (err) {
                  $('#ChiNhanhInfo').empty().append('<option value="">Lỗi tải chi nhánh</option>');
              });

                  // Sau khi gọi API ListDept thành công
              $.ajax({
                  url: `/api/caidatphongbanduyet/ListDept?groupId=${groupId}`,
                  method: "GET",
                  headers: {
                      "Authorization": "Bearer " + resUser.token
                  }
              }).done(function (res) {
                  let htmlUl = "";
                  if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                      var stt =1 ;
                      res.data.forEach(function (item, idx) {
                          htmlUl += `<li class="list-group-item" data-idx="${idx}" style="cursor:pointer;">
                              <b>${stt +"."+item.deptName}</b><br/>
                              <span>Trạng thái: ${item.isActive ? "Hoạt động" : "Ngừng"}</span>
                          </li>`;
                          stt++;
                      });
                  } else {
                      htmlUl = `<li class="list-group-item text-muted">Không có dữ liệu phòng ban.</li>`;
                  }
                  // Render cho cả 3 tab
                  $('#ul-them').html(htmlUl);
                  $('#ul-sua').html(htmlUl);
                  $('#ul-xoa').html(htmlUl);

                  function bindDeptClick(tab, data, groupId) {
                      // Map tab to permissionId
                      const permissionMap = {
                          'them': '22cd5c88-a9d1-6189-8d91-d856b4595815',
                          'sua': '25a73733-e932-5cf0-231a-cd2469d2d091',
                          'xoa': 'db666b7c-1e63-19df-dd09-1d860de545a4'
                      };
                      const permissionId = permissionMap[tab];

                      $(`#ul-${tab}`).off('click').on('click', 'li', function () {
                          const idx = $(this).data('idx');
                          const dept = data[idx];
                          let content = '';

                          if (dept) {
                              // Call API with correct permissionId
                              $.ajax({
                                    url: `/api/caidatsoluotduyet/ListStepSetting?groupId=${groupId}&majorId=74537f8f-a779-4313-ab4d-010d2d4ebab3&departmentId=${dept.id || ''}&permissionId=${permissionId}`,
                                  method: "GET",
                                  headers: {
                                       "Authorization": "Bearer " + resUser.token
                                   }
                              }).done(function (res) {
                                  if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                                      let stepsHtml = `<h5>${dept.deptName}</h5>`;
                                      stepsHtml += `<ul class="list-group mb-2">`;
                                      res.data.forEach((step, i) => {
                                          stepsHtml += `<li class="list-group-item">
                                              <b>Bước ${i + 1}:</b> ${step.content || ''}
                                              <span class="badge badge-info ml-2">${step.isStatus || ''}</span>
                                          </li>`;
                                      });
                                      stepsHtml += `</ul>`;
                                      content = stepsHtml;
                                  } else {
                                      content = `<div class="text-muted">Không có dữ liệu bước duyệt.</div>`;
                                  }
                                  $(`#content-${tab}`).html(content);
                              }).fail(function (err) {
                                  $(`#content-${tab}`).html('<div class="text-danger">Lỗi khi tải dữ liệu bước duyệt.</div>');
                              });
                          } else {
                              $(`#content-${tab}`).html("Không có dữ liệu chi tiết.");
                          }
                          $(`#ul-${tab} li`).removeClass('active');
                          $(this).addClass('active');
                      });
                  }
                  bindDeptClick('them', res.data, groupId);
                  bindDeptClick('sua', res.data, groupId);
                  bindDeptClick('xoa', res.data, groupId);
              }).fail(function (err) {
                  $('#ul-them, #ul-sua, #ul-xoa').html('<li class="list-group-item text-danger">Lỗi khi tải dữ liệu phòng ban.</li>');
                  $('#content-them, #content-sua, #content-xoa').html('');
              });
          });

          // Khởi tạo select2 nếu cần
          if (window.$ && $.fn.select2) {
              $('#ChiNhanhInfo').select2();
          }
          $('#ChiNhanhInfo').off('change').on('change', function () {
              if (typeof onSelectChange === 'function') {
                  onSelectChange($(this).val());
              }
          });
      }
</script>




