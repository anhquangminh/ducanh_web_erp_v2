         function handleLogout(e) {
            e.preventDefault(); // Ngăn submit mặc định

            // Xóa localStorage và sessionStorage
            localStorage.clear();
            sessionStorage.clear();

            // Submit lại form
            document.getElementById('logoutForm').submit();
