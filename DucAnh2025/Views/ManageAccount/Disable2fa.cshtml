@{
    ViewData["Title"] = "Disable 2FA";
}
<h3>Disable two-factor authentication (2FA)</h3>
<div class="alert alert-warning">
    <strong>This action only disables 2FA.</strong>
    <p>Disabling 2FA does not change the keys used in authenticator apps. If you wish to change the key used in an authenticator app you should <a href="/ManageAccount/ResetAuthenticator">reset your authenticator keys</a>.</p>
</div>
<form asp-action="Disable2fa" method="post">
    <button class="btn btn-danger" type="submit">Disable 2FA</button>
</form>
