                    </tr>`).join('');

                const bodyHtml = `
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover no-wrap-table">
                            <thead class="thead-light">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th> Mã nhân viên</th>
                                    <th> Loại Biến động</th>
                                    <th> Mã Quyết định</th>
