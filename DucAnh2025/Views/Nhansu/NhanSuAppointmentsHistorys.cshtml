                                    <th> Chức danh (Cũ)</th>
                                    <th> Phòng ban (Mới)</th>
                                    <th> Chức danh (Mới)</th>
                                    <th> Mức lương (Mới)</th>
                                    <th> Nội dung thay đổi</th>
                                    <th> Đường dẫn File QĐ</th>
                                    <th> Người ký Quyết định</th>
                                    <th> GroupId</th>
                                    <th> Thứ tự</th>
                                    <th> Ngày tạo</th>
                                    <th> Người tạo</th>
                                    <th> IsActive</th>
                                    <th> Người duyệt</th>
                                    <th> Ngày duyệt</th>
                                    <th> Phòng ban duyệt</th>
                                    <th> Phòng ban duyệt tiếp</th>
                                    <th> Thứ tự phòng ban</th>
                                    <th> Thứ tự duyệt</th>
