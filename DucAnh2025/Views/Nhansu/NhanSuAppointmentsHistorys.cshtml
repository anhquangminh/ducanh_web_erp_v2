<div class="tab-content">
    <div class="card mt-3 p-2">
        <div class="card-header">
            <h3 class="m-0 mr-2">Danh sách</h3>
            <span style="cursor:pointer;" onclick="showHuongDanNghiepVuAppHistory()" title="Hướng dẫn sử dụng">
                <i class="bi bi-question-circle-fill text-info" style="font-size: 1.5em;"></i>
            </span>
        </div>
        <div class="card-body">
            <div>
                <button data-permission="Tao" class="mb-2 mr-2 btn-icon btn btn-primary" onclick="showModalTaoMoiAppHistory()">
                    <i class="fas fa-plus btn-icon-wrapper"></i> Tạo mới
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover" id="table_appHistory">
                    <thead>
                        <tr>
                            <th></th>
                            <th>#</th>
                            <th>Mã nhân viên</th>
                            <th>Tên nhân viên</th>
                            <th>Loại Biến động</th>
                            <th>Mã Quyết định</th>
                            <th>Ngày Quyết định</th>
                            <th>Ngày Hiệu lực</th>
                            <th>Phòng ban (Cũ)</th>
                            <th>Chức danh (Cũ)</th>
                            <th>Phòng ban (Mới)</th>
                            <th>Chức danh (Mới)</th>
                            <th>Mức lương (Mới)</th>
                            <th>Nội dung thay đổi</th>
                            <th>Đường dẫn File QĐ</th>
                            <th>Người ký Quyết định</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th>#</th>
                            <th>Mã nhân viên</th>
                            <th>Tên nhân viên</th>
                            <th>Loại Biến động</th>
                            <th>Mã Quyết định</th>
                            <th>Ngày Quyết định</th>
                            <th>Ngày Hiệu lực</th>
                            <th>Phòng ban (Cũ)</th>
                            <th>Chức danh (Cũ)</th>
                            <th>Phòng ban (Mới)</th>
                            <th>Chức danh (Mới)</th>
                            <th>Mức lương (Mới)</th>
                            <th>Nội dung thay đổi</th>
                            <th>Đường dẫn File QĐ</th>
                            <th>Người ký Quyết định</th>
                            <th>Trạng thái</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
<script>
    let data_appp_history = null;
    $(function () {
        loadDataAppHistory();
    });

    function loadDataAppHistory() {
        getJwtToken().then(function (resUser) {
            $.ajax({
                url: `/api/NhanSuAppointmentsHistory/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        employeeId: item.employeeId || '',
                        maNhanVien: item.maNhanVien || '',
                        fullName: item.fullName || '',
                        changeTypeId: item.changeTypeId || '',
                        decisionCode: item.decisionCode || '',
                        decisionDate: formatDate(item.decisionDate) || null,
                        effectiveDate: formatDate(item.effectiveDate) || null,
                        oldDepartmentId: item.oldDepartmentId || '',
                        oldChucVuId: item.oldChucVuId || '',
                        newDepartmentId: item.newDepartmentId || '',
                        newChucVuId: item.newChucVuId || '',
                        newBasicSalary: item.newBasicSalary || '',
                        content: item.content || '',
                        filePath: item.filePath || '',
                        signerId: item.signerId || '',
                        groupId: item.groupId || '',
                        ordinarily: item.ordinarily || 0,
                        createAt: formatDate(item.createAt) || null,
                        createBy: item.createBy || '',
                        isActive: item.isActive || 0,
                        approvalUserId: item.approvalUserId || '',
                        dateApproval: formatDate(item.dateApproval) || null,
                        approvalDept: item.approvalDept || '',
                        departmentId: item.departmentId || '',
                        departmentOrder: item.departmentOrder || 0,
                        approvalOrder: item.approvalOrder || 0,
                        approvalId: item.approvalId || '',
                        lastApprovalId: item.lastApprovalId || '',
                        isStatus: item.isStatus || '',
                    }));
                }
                if (!data_appp_history) {
                data_appp_history = $('#table_appHistory').DataTable({
                    data: dataSet,
                    columns: [
                        {
                            data: null,
                            className: 'text-center align-middle',
                            orderable: false,
                            width: '1%',
                            render: function (data, type, row) {
                                let buttons = `
                                    <div class="btn-group">
                                `;
                                if (row.isActive < 3) {
                                    buttons += `
                                        <button class="btn btn-sm btn-success btn-approve" title="Duyệt" data-id="${row.id}" onclick="duyetAppHistory('${row.id}')" ><i class="fas fa-check"></i></button>
                                        <button class="btn btn-sm btn-warning btn-cancel-approve" title="Hủy duyệt" data-id="${row.id}" onclick="huyDuyetAppHistory('${row.id}')" ><i class="fas fa-times"></i></button>
                                    `;
                                } else if (row.isActive == 3) {
                                    buttons += `
                                        <button class="btn btn-sm btn-danger btn-delete" title="Xóa" data-id="${row.id}" onclick="xoaAppHistory('${row.id}')" ><i class="fas fa-trash"></i></button>
                                    `;
                                }
                                buttons += `
                                    <button class="btn btn-sm btn-primary btn-edit" title="Chỉnh sửa" data-id="${row.id}" onclick="chinhSuaAppHistory('${row.id}')" ><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger btn-delete" title="Chi tiết !" data-id="${row.id}" onclick="chiTietAppHistory('${row.id}')" ><i class="fas fa-eye"></i></button>
                                </div>
                                `;
                                return buttons;
                            }
                        },
                        { data: 'stt', className: 'text-center align-middle', width: '5%' },
                        {
                            data: 'maNhanVien',
                            className: 'align-middle',
                            render: function (data, type, row) {
                                return `<a href="javascript:void(0);" onclick="chiTietAppHistory('${row.id}')">${data}</a>`;
                            }
                        },
                        { data: 'fullName', className: 'align-middle' },
                        { data: 'changeTypeId', className: 'align-middle' },
                        { data: 'decisionCode', className: 'align-middle' },
                        { data: 'decisionDate', className: 'align-middle' },
                        { data: 'effectiveDate', className: 'align-middle' },
                        { data: 'oldDepartmentId', className: 'align-middle' },
                        { data: 'oldChucVuId', className: 'align-middle' },
                        { data: 'newDepartmentId', className: 'align-middle' },
                        { data: 'newChucVuId', className: 'align-middle' },
                        { data: 'newBasicSalary', className: 'align-middle' },
                        { data: 'content', className: 'align-middle' },
                        { data: 'filePath', className: 'align-middle' },
                        { data: 'signerId', className: 'align-middle' },
                        { data: 'isStatus', className: 'align-middle' }

                    ],
                    autoWidth: false,
                    scrollX: false,
                    ordering: true,
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi moí trang ",
                        zeroRecords: "Không tìm thấy dữ liệu !",
                        info: "Hiển thị của _TOTAL_ bản ghi !_START_ đến _END_ của _TOTAL_ bản ghi !",
                        infoEmpty: "Không có bản ghi nào ",
                        infoFiltered: "( Lọc từ )_MAX_( bản ghi)",
                        search: "Tìm kiếm :",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function () {
                            var column = this;
                            var select = $('<select><option value=""></option></select>')
                                .appendTo($(column.footer()).empty())
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });
                            column.data().unique().sort().each(function (d) {
                                select.append('<option value="' + d + '">' + d + '</option>');
                            });
                        });
                    }
                });
               }else {
                data_appp_history.clear();
                data_appp_history.rows.add(dataSet);
                data_appp_history.draw(false);
                }
            }).fail(function (xhr) {
                $('#table_danhmuc tbody').html('<tr><td colspan="7" class="text-center text-danger">Lỗi khi tải dữ liệu </td></tr>');
            });
        });
    }
    async function showModalTaoMoiAppHistory(isEdit = false, data = null) {
        const modalTitle = isEdit ? "Cập nhật" : "Thêm mới";
        const resUser = await getJwtToken();
       const token = resUser.token;
       const groupId = resUser.userInfor.groupId;
       const userName = resUser.userInfor.userName;

        let selectOptions_EmployeeId = '<option value="">Chọn Mã nhân viên --</option>';
        try {
            const res_EmployeeId = await $.ajax({
                url: `/api/NhanSuEmployeeProfile/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_EmployeeId.success && Array.isArray(res_EmployeeId.data)) {
                res_EmployeeId.data.forEach(item => {
                    selectOptions_EmployeeId += `<option value="${item.id}" ${data && data.esStatus === item.id ? 'selected' : ''}>${item.fullName}</option>`;
                });
            }
        } catch {
            selectOptions_EmployeeId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_ChangeTypeId = '<option value="">Chọn Loại Biến động --</option>';
        try {
            const res_ChangeTypeId = await $.ajax({
                url: `/api/NhanSuDMChangeType/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_ChangeTypeId.success && Array.isArray(res_ChangeTypeId.data)) {
                res_ChangeTypeId.data.forEach(item => {
                    selectOptions_ChangeTypeId += `<option value="${item.id}" ${data && data.csStatus === item.id ? 'selected' : ''}>${item.changeTypeName}</option>`;
                });
            }
        } catch {
            selectOptions_ChangeTypeId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_OldDepartmentId = '<option value="">Chọn Phòng ban (Cũ) --</option>';
        try {
            const res_OldDepartmentId = await $.ajax({
                url: `/api/Department/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_OldDepartmentId.success && Array.isArray(res_OldDepartmentId.data)) {
                res_OldDepartmentId.data.forEach(item => {
                    selectOptions_OldDepartmentId += `<option value="${item.id}" ${data && data.osStatus === item.id ? 'selected' : ''}>${item.deptName}</option>`;
                });
            }
        } catch {
            selectOptions_OldDepartmentId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_OldChucVuId = '<option value="">Chọn Chức danh (Cũ) --</option>';
        try {
            const res_OldChucVuId = await $.ajax({
                url: `/api/ChucVu/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_OldChucVuId.success && Array.isArray(res_OldChucVuId.data)) {
                res_OldChucVuId.data.forEach(item => {
                    selectOptions_OldChucVuId += `<option value="${item.id}" ${data && data.osStatus === item.id ? 'selected' : ''}>${item.chucVu}</option>`;
                });
            }
        } catch {
            selectOptions_OldChucVuId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_NewDepartmentId = '<option value="">Chọn Phòng ban (Mới) --</option>';
        try {
            const res_NewDepartmentId = await $.ajax({
                url: `/api/Department/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_NewDepartmentId.success && Array.isArray(res_NewDepartmentId.data)) {
                res_NewDepartmentId.data.forEach(item => {
                    selectOptions_NewDepartmentId += `<option value="${item.id}" ${data && data.nsStatus === item.id ? 'selected' : ''}>${item.deptName}</option>`;
                });
            }
        } catch {
            selectOptions_NewDepartmentId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_NewChucVuId = '<option value="">Chọn Chức danh (Mới) --</option>';
        try {
            const res_NewChucVuId = await $.ajax({
                url: `/api/ChucVu/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_NewChucVuId.success && Array.isArray(res_NewChucVuId.data)) {
                res_NewChucVuId.data.forEach(item => {
                    selectOptions_NewChucVuId += `<option value="${item.id}" ${data && data.nsStatus === item.id ? 'selected' : ''}>${item.chucVu}</option>`;
                });
            }
        } catch {
            selectOptions_NewChucVuId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_SignerId = '<option value="">Chọn Người ký Quyết định --</option>';
        try {
            const res_SignerId = await $.ajax({
                url: `/api/NhanSuEmployeeProfile/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_SignerId.success && Array.isArray(res_SignerId.data)) {
                res_SignerId.data.forEach(item => {
                    selectOptions_SignerId += `<option value="${item.id}" ${data && data.ssStatus === item.id ? 'selected' : ''}>${item.fullName} (${item.maNhanVien})</option>`;
                });
            }
        } catch {
            selectOptions_SignerId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        const bodyHtml = `
            <form id="form_caidat" class="row">
                <div class="form-group col-md-3">
                    <label>Mã nhân viên</label>
                    <select id="select-EmployeeId" class="form-control">${selectOptions_EmployeeId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Loại Biến động</label>
                    <select id="select-ChangeTypeId" class="form-control">${selectOptions_ChangeTypeId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Mã Quyết định <span class="text-danger">*</span></label>
                    <input type="text" id="input-DecisionCode" name="DecisionCode" value="${data ? data.decisionCode : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Ngày Quyết định <span class="text-danger">*</span></label>
                    <input type="date" id="input-DecisionDate" name="DecisionDate" value="${data ? formatDate(data.decisionDate) : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Ngày Hiệu lực <span class="text-danger">*</span></label>
                    <input type="date" id="input-EffectiveDate" name="EffectiveDate" value="${data ? formatDate(data.effectiveDate) : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Phòng ban (Cũ)</label>
                    <select id="select-OldDepartmentId" class="form-control">${selectOptions_OldDepartmentId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Chức danh (Cũ)</label>
                    <select id="select-OldChucVuId" class="form-control">${selectOptions_OldChucVuId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Phòng ban (Mới)</label>
                    <select id="select-NewDepartmentId" class="form-control">${selectOptions_NewDepartmentId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Chức danh (Mới)</label>
                    <select id="select-NewChucVuId" class="form-control">${selectOptions_NewChucVuId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Mức lương (Mới)</label>
                    <input type="number" id="input-NewBasicSalary" name="NewBasicSalary" value="${data ? data.newBasicSalary : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Nội dung thay đổi <span class="text-danger">*</span></label>
                    <input type="text" id="input-Content" name="Content" value="${data ? data.content : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Đường dẫn File QĐ</label>
                    <input type="text" id="input-FilePath" name="FilePath" value="${data ? data.filePath : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Người ký Quyết định</label>
                    <select id="select-SignerId" class="form-control">${selectOptions_SignerId}</select>
                </div>
            </form>
            <div id="error_msg" class="text-danger font-weight-bold mb-2"></div>
        `;
        const footerHtml = `
            <button type="button" class="btn btn-primary" id="btnLuuCaiDat">${isEdit ? "Cập nhật" : "Lưu "}</button>
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>`;
        showGlobalModal(modalTitle, bodyHtml, footerHtml);
        $('#btnLuuCaiDat').data("isedit", isEdit).data("id", data?.id || "");
        $('#btnLuuCaiDat').off('click').on('click', async function () {
            $('#error_msg').text("");
            const resUser = await getJwtToken();
            const token = resUser.token;
            const isEdit = $(this).data("isedit") === true;
            const id = $(this).data("id");
            if (!validateFormAppHistoryAppHistory())
               return;
            const dataSend = {
                Id: id,
                EmployeeId: $('#select-EmployeeId').val() || "",
                ChangeTypeId: $('#select-ChangeTypeId').val() || "",
                DecisionCode: $('#input-DecisionCode').val() || "",
                DecisionDate: $('#input-DecisionDate').val() || null,
                EffectiveDate: $('#input-EffectiveDate').val() || null,
                OldDepartmentId: $('#select-OldDepartmentId').val() || "",
                OldChucVuId: $('#select-OldChucVuId').val() || "",
                NewDepartmentId: $('#select-NewDepartmentId').val() || "",
                NewChucVuId: $('#select-NewChucVuId').val() || "",
                NewBasicSalary: $('#input-NewBasicSalary').val() || 0.0,
                Content: $('#input-Content').val() || "",
                FilePath: $('#input-FilePath').val() || "",
                SignerId: $('#select-SignerId').val() || "",
                GroupId: groupId,
                Ordinarily: 0,
                CreateAt: new Date().toISOString(),
                CreateBy: userName,
                IsActive: isEdit && data ? data.isActive : 0,
                ApprovalUserId: "",
                DateApproval: null,
                ApprovalDept: "",
                DepartmentId: "",
                DepartmentOrder: 0,
                ApprovalOrder: 0,
                ApprovalId: "",
                LastApprovalId: "",
                IsStatus: ""
            };
            try {
                const res = await $.ajax({
                    url: `/api/NhanSuAppointmentsHistory/Create?isEdit=${isEdit}`,
                    method: "POST",
                    contentType: "application/json",
                    headers: { Authorization: `Bearer ${token}` },
                    data: JSON.stringify(dataSend)
                });
                if (res.success) {
                    showToastSuccess(isEdit ? "Cập nhật thành công " : "Lưu thành công");
                    $('#globalModal').modal('hide');
                    loadDataAppHistory();
                } else {
                    $('#error_msg').text(res.message || "Có lỗi xảy ra khi lưu");
                    showToastError(res.message || "Có lỗi xảy ra khi lưu");
                }
            } catch (err) {
                $('#error_msg').text("Có lỗi xảy ra khi lưu");
            }
        });
    }
    function validateFormAppHistoryAppHistory() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();
        let isValid = true;
        let firstInvalid = null;
        const requiredFields = [
            { selector: '#input-DecisionCode', message: 'Vui lòng nhâp Mã Quyết định.' },
            { selector: '#input-DecisionDate', message: 'Vui lòng nhâp Ngày Quyết định.' },
            { selector: '#input-EffectiveDate', message: 'Vui lòng nhâp Ngày Hiệu lực.' },
            { selector: '#input-Content', message: 'Vui lòng nhâp Nội dung thay đổi.' },
        ];

        requiredFields.forEach(f => {
            const $input = $(f.selector);
            if (!$input.val() || !$input.val().trim()) {
                showErrorAppHistory(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
            }
        });

        if (!isValid && firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
            const $el = $(firstInvalid);
            if ($el.hasClass('select2-hidden-accessible')) {
                $el.next('.select2-container').find('.select2-selection').focus();
            } else {
                $el.focus();
            }
        }
        return isValid;
    }


    function showErrorAppHistory(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }
    async function chiTietAppHistory(id) {
        const resUser = await getJwtToken();
        const token = resUser.token;

        try {
            const res = await $.ajax({
                url: `/api/NhanSuAppointmentsHistory/GetHistory?id=${id}`,
                method: "GET",
                headers: { Authorization: `Bearer ${token}` }
            });

            if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                let tableRows = res.data.map((item, idx) => `
                    <tr>
                        <td class="text-center">${idx + 1}</td>
                        <td>${item.maNhanVien || ''}</td>
                        <td>${item.changeTypeId || ''}</td>
                        <td>${item.decisionCode || ''}</td>
                        <td>${item.decisionDate || ''}</td>
                        <td>${item.effectiveDate || ''}</td>
                        <td>${item.oldDepartmentId || ''}</td>
                        <td>${item.oldChucVuId || ''}</td>
                        <td>${item.newDepartmentId || ''}</td>
                        <td>${item.newChucVuId || ''}</td>
                        <td>${item.newBasicSalary || ''}</td>
                        <td>${item.content || ''}</td>
                        <td>${item.filePath || ''}</td>
                        <td>${item.signerId || ''}</td>
                        <td>${item.groupId || ''}</td>
                        <td>${item.ordinarily || ''}</td>
                        <td>${item.createAt || ''}</td>
                        <td>${item.createBy || ''}</td>
                        <td>${item.isActive || ''}</td>
                        <td>${item.approvalUserId || ''}</td>
                        <td>${item.dateApproval || ''}</td>
                        <td>${item.approvalDept || ''}</td>
                        <td>${item.departmentId || ''}</td>
                        <td>${item.departmentOrder || ''}</td>
                        <td>${item.approvalOrder || ''}</td>
                        <td>${item.approvalId || ''}</td>
                        <td>${item.lastApprovalId || ''}</td>
                        <td>${item.isStatus || ''}</td>
                        <td>${item.createBy || ''}</td>
