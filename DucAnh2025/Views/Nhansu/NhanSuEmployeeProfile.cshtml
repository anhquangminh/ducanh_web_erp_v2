            });
            if (res_CurrentContractType.success && Array.isArray(res_CurrentContractType.data)) {
                res_CurrentContractType.data.forEach(item => {
                    selectOptions_CurrentContractType += `<option value="${item.id}" ${data && data.currentContractType == item.id ? 'selected' : ''}>${item.contractTypeName}</option>`;
                });
            }
        } catch {
            selectOptions_CurrentContractType += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_WorkStatusId = '<option value="">Chọn Tình trạng làm việc --</option>';
