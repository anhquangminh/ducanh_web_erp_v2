                    selectOptions_WorkStatusId += `<option value="${item.id}" ${data && data.workStatusId == item.id ? 'selected' : ''}>${item.workStatusName}</option>`;
                });
            }
        } catch {
            selectOptions_WorkStatusId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        const bodyHtml = `
            <form id="form_caidat" class="row">
                <div class="form-group col-md-3">
                    <label>Mã nhân viên<span class="text-danger">*</span></label>
                    <input type="text" id="input-EmployeeId" name="EmployeeId" value="${data ? data.employeeId : ''}" class="form-control" placeholder="NV001" />
                </div>
                <div class="form-group col-md-3">
                    <label>Họ và tên <span class="text-danger">*</span></label>
                    <input type="text" id="input-FullName" name="FullName" value="${data ? data.fullName : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                <label>Giới tính <span class="text-danger">*</span></label>
                <select id="input-Gender" name="Gender" class="form-control">
                    <option value="">-- Chọn giới tính --</option>
                    <option value="Nam" ${data && data.gender === 'Nam' ? 'selected' : ''}>Nam</option>
                    <option value="Nữ" ${data && data.gender === 'Nữ' ? 'selected' : ''}>Nữ</option>
                    <option value="Khác" ${data && data.gender === 'Khác' ? 'selected' : ''}>Khác</option>
                </select>
            </div>
                <div class="form-group col-md-3">
                    <label>Ngày sinh</label>
                    <input type="date" id="input-DateOfBirth" name="DateOfBirth" value="${data ? formatDate(data.dateOfBirth) : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Số CCCD/CMND <span class="text-danger">*</span></label>
                    <input type="text" id="input-IdentityCardNumber" name="IdentityCardNumber" value="${data ? data.identityCardNumber : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Ngày cấp CCCD</label>
                    <input type="date" id="input-IdentityCardIssueDate" name="IdentityCardIssueDate" value="${data ? formatDate(data.identityCardIssueDate) : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Nơi cấp CCCD</label>
                    <input type="text" id="input-IdentityCardIssuePlace" name="IdentityCardIssuePlace" value="${data ? data.identityCardIssuePlace : ''}" class="form-control" />
                </div>
