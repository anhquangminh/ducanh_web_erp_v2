            const res_WorkStatusId = await $.ajax({
                url: `/api/NhanSuDMWorkStatu/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_WorkStatusId.success && Array.isArray(res_WorkStatusId.data)) {
