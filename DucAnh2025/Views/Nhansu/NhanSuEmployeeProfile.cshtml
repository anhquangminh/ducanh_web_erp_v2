<script>
    let tableInfor = null;
    $(function () {
        loadDataInfor();
    });
    function loadDataInfor() {
        getJwtToken().then(function (resUser) {
            $.ajax({
                url: `/api/NhanSuEmployeeProfile/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        fullName: item.fullName || '',
                        employeeId: item.employeeId || '',
                        gender: item.gender || '',
                        dateOfBirth: item.dateOfBirth || '',
                        identityCardNumber: item.identityCardNumber || '',
                        identityCardIssueDate: item.identityCardIssueDate || '',
                        identityCardIssuePlace: item.identityCardIssuePlace || '',
                        taxCode: item.taxCode || '',
                        socialInsuranceNumber: item.socialInsuranceNumber || '',
                        mobilePhone: item.mobilePhone || '',
                        personalEmail: item.personalEmail || '',
                        permanentAddress: item.permanentAddress || '',
                        currentAddress: item.currentAddress || '',
                        emergencyContactName: item.emergencyContactName || '',
                        emergencyContactPhone: item.emergencyContactPhone || '',
                        departmentFrId: item.departmentFrId || '',
                        chucVuId: item.chucVuId || '',
                        managerId: item.managerId || '',
                        workEmail: item.workEmail || '',
                        hireDate: item.hireDate || '',
                        officialDate: item.officialDate || '',
                        currentContractType: item.currentContractType || '',
                        contractExpirationDate: item.contractExpirationDate || '',
                        workStatusId: item.workStatusId || '',
                        currentBasicSalary: item.currentBasicSalary || '',
                        bankAccountNumber: item.bankAccountNumber || '',
                        bankName: item.bankName || '',
                        salaryPaymentMethod: item.salaryPaymentMethod || '',
                        taxDependentsCount: item.taxDependentsCount || 0,
                        groupId: item.groupId || '',
                        ordinarily: item.ordinarily || 0,
                        createAt: item.createAt || null,
                        createBy: item.createBy || '',
                        isActive: item.isActive || 0,
                        approvalUserId: item.approvalUserId || '',
                        dateApproval: item.dateApproval || null,
                        approvalDept: item.approvalDept || '',
                        departmentId: item.departmentId || '',
                        departmentOrder: item.departmentOrder || 0,
                        approvalOrder: item.approvalOrder || 0,
                        approvalId: item.approvalId || '',
                        lastApprovalId: item.lastApprovalId || '',
                        isStatus: item.isStatus || '',
                    }));
                }
                if (!tableInfor) {
                tableInfor = $('#table_infor').DataTable({
                    data: dataSet,
                    columns: [
                        {
                            data: null,
                            className: 'text-center align-middle',
                            orderable: false,
                            width: '1%',
                            render: function (data, type, row) {
                                let buttons = `
                                    <div class="btn-group">
                                `;
                                if (row.isActive < 3) {
                                    buttons += `
                                        <button class="btn btn-sm btn-success btn-approve" title="Duyệt" data-id="${row.id}" onclick="duyetInfor('${row.id}')" ><i class="fas fa-check"></i></button>
                                        <button class="btn btn-sm btn-warning btn-cancel-approve" title="Hủy duyệt" data-id="${row.id}" onclick="huyDuyetInfor('${row.id}')" ><i class="fas fa-times"></i></button>
                                    `;
                                } else if (row.isActive == 3) {
                                    buttons += `
                                        <button class="btn btn-sm btn-danger btn-delete" title="Xóa" data-id="${row.id}" onclick="xoaInfor('${row.id}')" ><i class="fas fa-trash"></i></button>
                                    `;
                                }
                                buttons += `
                                    <button class="btn btn-sm btn-primary btn-edit" title="Chỉnh sửa" data-id="${row.id}" onclick="chinhSuaInfor('${row.id}')" ><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger btn-delete" title="chi tiết !" data-id="${row.id}" onclick="chiTietInfor('${row.id}')" ><i class="bi bi-clock-history"></i></button>
                                </div>
                                `;
                                return buttons;
                            }
                        },
                        { data: 'stt', className: 'text-center align-middle', width: '5%' },
                        {
                            data: 'employeeId',
                            className: 'align-middle',
                            render: function (data, type, row) {
                                return `<a href="javascript:void(0);" onclick="xemChiTietInfor('${row.id}')">${data}</a>`;
                            }
                        },
                        { data: 'fullName', className: 'align-middle' },
                        { data: 'gender', className: 'align-middle' },
                        { data: 'dateOfBirth', className: 'align-middle' },
                        { data: 'identityCardNumber', className: 'align-middle' },
                        { data: 'identityCardIssueDate', className: 'align-middle' },
                        { data: 'identityCardIssuePlace', className: 'align-middle' },
                        { data: 'taxCode', className: 'align-middle' },
                        { data: 'socialInsuranceNumber', className: 'align-middle' },
                        { data: 'mobilePhone', className: 'align-middle' },
                        { data: 'personalEmail', className: 'align-middle' },
                        { data: 'permanentAddress', className: 'align-middle' },
                        { data: 'currentAddress', className: 'align-middle' },
                        { data: 'emergencyContactName', className: 'align-middle' },
                        { data: 'emergencyContactPhone', className: 'align-middle' },
                        { data: 'departmentFrId', className: 'align-middle' },
                        { data: 'chucVuId', className: 'align-middle' },
                        { data: 'managerId', className: 'align-middle' },
                        { data: 'workEmail', className: 'align-middle' },
                        { data: 'hireDate', className: 'align-middle' },
                        { data: 'officialDate', className: 'align-middle' },
                        { data: 'currentContractType', className: 'align-middle' },
                        { data: 'contractExpirationDate', className: 'align-middle' },
                        { data: 'workStatusId', className: 'align-middle' },
                        { data: 'currentBasicSalary', className: 'align-middle' },
                        { data: 'bankAccountNumber', className: 'align-middle' },
                        { data: 'bankName', className: 'align-middle' },
                        { data: 'salaryPaymentMethod', className: 'align-middle' },
                        { data: 'taxDependentsCount', className: 'align-middle' },
                        { data: 'isStatus', className: 'align-middle' }
                    ],
                    autoWidth: false,
                    scrollX: false,
                    ordering: true,
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi moí trang ",
                        zeroRecords: "Không tìm thấy dữ liệu !",
                        info: "Hiển thị của _TOTAL_ bản ghi !_START_ đến _END_ của _TOTAL_ bản ghi !",
                        infoEmpty: "Không có bản ghi nào ",
                        infoFiltered: "( Lọc từ )_MAX_( bản ghi)",
                        search: "Tìm kiếm :",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function (index) {
                            var column = this;
                            if (index === 0) return;
                            var select = $('<select><option value=""></option></select>')
                                .appendTo($(column.footer()).empty())
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });
                            column.data().unique().sort().each(function (d) {
                                select.append('<option value="' + d + '">' + d + '</option>');
                            });
                        });
                    }
                });
               }else {
                tableInfor.clear();
                tableInfor.rows.add(dataSet);
                tableInfor.draw(false);
                }
            }).fail(function (xhr) {
                $('#table_infor tbody').html('<tr><td colspan="7" class="text-center text-danger">Lỗi khi tải dữ liệu </td></tr>');
            });
        });
    }
    async function showModalTaoMoiInfor(isEdit = false, data = null) {
        const modalTitle = isEdit ? "Cập nhật" : "Thêm mới";
        const resUser = await getJwtToken();
       const token = resUser.token;
       const groupId = resUser.userInfor.groupId;
       const userName = resUser.userInfor.userName;

        let selectOptions_DepartmentFrId = '<option value="">Chọn ID Phòng ban --</option>';
        try {
            const res_DepartmentFrId = await $.ajax({
                url: `/api/Department/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_DepartmentFrId.success && Array.isArray(res_DepartmentFrId.data)) {
                res_DepartmentFrId.data.forEach(item => {
                    selectOptions_DepartmentFrId += `<option value="${item.id}" ${data && data.departmentFrId == item.id ? 'selected' : ''}>${item.deptName}</option>`;
                });
            }
        } catch {
            selectOptions_DepartmentFrId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_ChucVuId = '<option value="">Chọn ID Chức danh/Vị trí --</option>';
        try {
            const res_ChucVuId = await $.ajax({
                url: `/api/ChucVu/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_ChucVuId.success && Array.isArray(res_ChucVuId.data)) {
                res_ChucVuId.data.forEach(item => {
                    selectOptions_ChucVuId += `<option value="${item.id}" ${data && data.chucVuId == item.id ? 'selected' : ''}>${item.chucVu}</option>`;
                });
            }
        } catch {
            selectOptions_ChucVuId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_ManagerId = '<option value="">Chọn Mã Quản lý trực tiếp --</option>';
        try {
            const res_ManagerId = await $.ajax({
                url: `/api/NhanSuEmployeeProfile/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
