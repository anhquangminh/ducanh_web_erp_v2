    // Helper chuyển date -> input value (YYYY-MM-DD)
    function formatDateInput(date) {
        if (!date) return "";
        const d = new Date(date);
        if (isNaN(d)) return "";
        return d.toISOString().split('T')[0];
    }
    function toPascalCase(str) {
        if (!str) return "";
        return str.charAt(0).toUpperCase() + str.slice(1);
    }
    function toCamelCaseLower(str) {
        if (!str) return str;
        return str.charAt(0).toLowerCase() + str.slice(1);
    }



    // Hàm gọi API cập nhật (bạn có thể thay endpoint / xử lý theo project)
    async function SaveInforToServer(updated,isEdit = true) {
        try {
            const resUser = await getJwtToken();
            const token = resUser.token;
            const groupId = resUser.userInfor.groupId;
            const userName = resUser.userInfor.userName;

            updated.GroupId= groupId;
            updated.CreateBy= userName,
            updated.IsActive = isEdit && (updated.isActive !== undefined) ? updated.isActive : 0;

            const res = await $.ajax({
                url: `/api/NhanSuEmployeeProfile/Create?isEdit=${isEdit}`,
                method: "POST",
                contentType: "application/json",
                headers: { Authorization: `Bearer ${token}` },
                data: JSON.stringify(updated)
            });

            return res;
        } catch (err) {
            console.error("SaveInforToServer error:", err);
            return { success: false, message: "Lỗi server" };
        }
    }
    
    // backup nguyên HTML để restore khi Cancel
    const originalHtml = {};
    
    // Hàm chính: replace toàn bộ info -> input/select (mở rộng đầy đủ các field)
    async function EditInfor(data) {
        if (!data) return;

        // Lấy token + groupId để load các select
        const resUser = await getJwtToken();
        const token = resUser.token;
        const groupId = resUser.userInfor.groupId;

        // helper load select giống modal
        async function loadSelect(url, selectedValue, textField) {
            let html = `<option value="">-- Chọn --</option>`;
            try {
                const res = await $.ajax({
                    url: `${url}?groupId=${groupId}`,
                    method: "GET",
                    headers: {
                        "Content-Type": "application/json",
                        "Authorization": "Bearer " + token
                    }
                });
                if (res.success && Array.isArray(res.data)) {
                    res.data.forEach(item => {
                        html += `<option value="${item.id}" ${selectedValue == item.id ? 'selected' : ''}>${item[textField]}</option>`;
                    });
                }
            } catch (e) {
                html += `<option value="">Lỗi tải dữ liệu</option>`;
            }
            return html;
        }

        // pre-load select options async
        const optDepartment = await loadSelect("/api/Department/GetAll", data.departmentFrId, "deptName");
        const optChucVu = await loadSelect("/api/ChucVu/GetAll", data.chucVuId, "chucVu");
        const optManager = await loadSelect("/api/NhanSuEmployeeProfile/GetAll", data.managerId, "fullName");
        const optContractType = await loadSelect("/api/NhanSuDMContractType/GetAll", data.currentContractType, "contractTypeName");
        const optWorkStatus = await loadSelect("/api/NhanSuDMWorkStatu/GetAll", data.workStatusId, "workStatusName");

        // Danh sách fields cần replace — đầy đủ
        const fields = [
            "id","employeeId", "fullName", "gender", "dateOfBirth",
            "identityCardNumber", "identityCardIssueDate", "identityCardIssuePlace",
            "taxCode", "socialInsuranceNumber",
            "permanentAddress", "currentAddress",
            "emergencyContactName", "emergencyContactPhone",
            "departmentFrId", "chucVuId", "managerId",
            "workEmail", "hireDate", "officialDate",
            "currentContractType", "contractExpirationDate", "workStatusId",
            "currentBasicSalary", "taxDependentsCount",
            "bankAccountNumber", "bankName", "salaryPaymentMethod",
            "mobilePhone", "personalEmail"
        ];

        // map tên info -> cách tạo input (selects handled separately)
        const createInput = (field) => {
            // date fields
            if (/(date|Date|DOB|IssueDate|hireDate|officialDate|contractExpirationDate)/i.test(field)) {
                return `<input id="input-${toPascalCase(field)}" type="date" class="form-control mb-2" value="${formatDateInput(data[field])}">`;
            }
            // number fields
            if (/(salary|Count|count|TaxDependents)/i.test(field) || field === "currentBasicSalary" || field === "taxDependentsCount") {
                return `<input id="input-${toPascalCase(field)}" type="number" class="form-control mb-2" value="${data[field] != null ? data[field] : ''}">`;
            }
            // email
            if (/email/i.test(field) || field === "personalEmail" || field === "workEmail") {
                return `<input id="input-${toPascalCase(field)}" type="email" class="form-control mb-2" value="${data[field] || ''}">`;
            }
            // default text
            return `<input id="input-${toPascalCase(field)}" type="text" class="form-control mb-2" value="${data[field] || ''}">`;
        };

        // Replace: nếu tồn tại #info-<field> trên DOM thì replaceWith input/select
        for (const f of fields) {
            const sel = `#info-${f}`;
            if ($(sel).length > 0) {
                originalHtml[toPascalCase(f)] = $(sel).prop("outerHTML");

                // some special: selects
                if (f === "departmentFrId") {
                    $(sel).replaceWith(`<select id="select-${toPascalCase(f)}" class="form-control mb-2">${optDepartment}</select>`);
                } else if (f === "chucVuId") {
                    $(sel).replaceWith(`<select id="select-${toPascalCase(f)}" class="form-control mb-2">${optChucVu}</select>`);
                } else if (f === "managerId") {
                    $(sel).replaceWith(`<select id="select-${toPascalCase(f)}" class="form-control mb-2">${optManager}</select>`);
                } else if (f === "currentContractType") {
                    $(sel).replaceWith(`<select id="select-${toPascalCase(f)}" class="form-control mb-2">${optContractType}</select>`);
                } else if (f === "workStatusId") {
                    $(sel).replaceWith(`<select id="select-${toPascalCase(f)}" class="form-control mb-2">${optWorkStatus}</select>`);
                } else if (f === "gender") {
                    // gender as select
                    $(sel).replaceWith(`
                        <select id="input-Gender" class="form-control mb-2">
                            <option value="">-- Chọn giới tính --</option>
                            <option value="Nam" ${data.gender === 'Nam' ? 'selected' : ''}>Nam</option>
                            <option value="Nữ" ${data.gender === 'Nữ' ? 'selected' : ''}>Nữ</option>
                            <option value="Khác" ${data.gender === 'Khác' ? 'selected' : ''}>Khác</option>
                        </select>
                    `);
                } else if (f === "salaryPaymentMethod") {
                    // use select with 2 options (Chuyển khoản / Tiền mặt)
                    $(sel).replaceWith(`
                        <select id="input-SalaryPaymentMethod" class="form-control mb-2">
                            <option value="">-- Chọn phương thức --</option>
                            <option value="Chuyển khoản" ${data.salaryPaymentMethod == "Chuyển khoản" ? 'selected' : ''}>Chuyển khoản</option>
                            <option value="Tiền mặt" ${data.salaryPaymentMethod == "Tiền mặt" ? 'selected' : ''}>Tiền mặt</option>
                        </select>
                    `);
                } else {
                    $(sel).replaceWith(createInput(f));
                }
            }
        }

        $('#input-EmployeeId').prop('disabled', true);

        // Thêm 2 nút SAVE + CANCEL ở cuối (nếu chưa có vùng chứa, tạo 1 vùng)
        $('#btn-tab1').html(`<div class="col-md-12 mt-3" id="edit-action-buttons">
                    <input id="input-Id" type="hidden" value="${data.id || ''}">
                    <button class="btn btn-success me-2" id="btnSaveEdit" onclick="LuuEditInfor()">
                        <i class="bi bi-check-lg"></i> Lưu
                    </button>
                    <button class="btn btn-secondary" id="btnCancelEdit" onclick="huyEditInfor()">
                        <i class="bi bi-x-lg"></i> Hủy
                    </button>
               </div>
            `);

        // Save handler: thu thập tất cả field (cùng tên như modal)
        
    }

    async function LuuEditInfor(){
        if (!validateFormInfor())
               return;
            const updated = {
                Id: $('#input-Id').val() || "",
                EmployeeId: $('#input-EmployeeId').val() || "",
                FullName: $('#input-FullName').val() || "",
                Gender: $('#input-Gender').val() || "",
                DateOfBirth: $('#input-DateOfBirth').val() || null,
                IdentityCardNumber: $('#input-IdentityCardNumber').val() || "",
                IdentityCardIssueDate: $('#input-IdentityCardIssueDate').val() || null,
                IdentityCardIssuePlace: $('#input-IdentityCardIssuePlace').val() || "",
                TaxCode: $('#input-TaxCode').val() || "",
                SocialInsuranceNumber: $('#input-SocialInsuranceNumber').val() || "",
                MobilePhone: $('#input-MobilePhone').val() || "",
                PersonalEmail: $('#input-PersonalEmail').val() || "",
                PermanentAddress: $('#input-PermanentAddress').val() || "",
                CurrentAddress: $('#input-CurrentAddress').val() || "",
                EmergencyContactName: $('#input-EmergencyContactName').val() || "",
                EmergencyContactPhone: $('#input-EmergencyContactPhone').val() || "",
                DepartmentFrId: $('#select-DepartmentFrId').val() || "",
                ChucVuId: $('#select-ChucVuId').val() || "",
                ManagerId: $('#select-ManagerId').val() || "",
                WorkEmail: $('#input-WorkEmail').val() || "",
                HireDate: $('#input-HireDate').val() || null,
                OfficialDate: $('#input-OfficialDate').val() || null,
                CurrentContractType: $('#select-CurrentContractType').val() || "",
                ContractExpirationDate: $('#input-ContractExpirationDate').val() || null,
                WorkStatusId: $('#select-WorkStatusId').val() || "",
                CurrentBasicSalary: $('#input-CurrentBasicSalary').val() || 0.0,
                BankAccountNumber: $('#input-BankAccountNumber').val() || "",
                BankName: $('#input-BankName').val() || "",
                SalaryPaymentMethod: $('#input-SalaryPaymentMethod').val() || "",
                TaxDependentsCount: $('#input-TaxDependentsCount').val() || 0,
                GroupId:"",
                Ordinarily: 0,
                CreateBy:"",
                CreateAt: new Date().toISOString(),
                ApprovalUserId: "",
                DateApproval: null,
                ApprovalDept: "",
                DepartmentId: "",
                DepartmentOrder: 0,
                ApprovalOrder: 0,
                ApprovalId: "",
                LastApprovalId: "",
                IsStatus: "",
                IsActive: 0,
            };

            // gọi API lưu (dùng hàm helper)
            const res = await SaveInforToServer(updated, true);
            if (res?.success) {
                $('#btn-tab1').html("");
                showToastSuccess("Cập nhật thành công");
                // Ẩn nút save/cancel
                $("#edit-action-buttons").html("");
                // Thay thế input/select bằng span chứa giá trị cập nhật
                for (const key in originalHtml) {
                    const selEdit = `#input-${toPascalCase(key)}`;
                    const selectEdit = `#select-${toPascalCase(key)}`;
                    // Replace lại giao diện gốc
                    if ($(selEdit).length > 0) {
                        $(selEdit).replaceWith(originalHtml[key]);
                        // Sau khi replace, cập nhật giá trị mới
                        setTimeout(() => {
                            $(`#input-${toPascalCase(key)}`).val(updated[key] ?? "");
                        }, 0);
                    }
                    if ($(selectEdit).length > 0) {
                        $(selectEdit).replaceWith(originalHtml[key]);
                        setTimeout(() => {
                            $(`#select-${toPascalCase(key)}`).val(updated[key] ?? "");
                        }, 0);
                    }
                }
            } else {
                showToastError(res?.message || "Lưu thất bại");
            }
    }
      
    function huyEditInfor(){
            $('#btn-tab1').html("");
            // replace each input-* back to original
            for (const key in originalHtml) {
                const selEdit = `#input-${toPascalCase(key)}`;
                const selectEdit = `#select-${toPascalCase(key)}`;
                if ($(selEdit).length > 0) {
                    $(selEdit).replaceWith(originalHtml[key]);
                }
                if ($(selectEdit).length > 0) {
                    $(selectEdit).replaceWith(originalHtml[key]);
                }
            }
            // remove action buttons
            $("#edit-action-buttons").html("");
    }



    async function duyetInfor(id) {
        if (!confirm('Bạn có chắc chắn muốn duyệt ')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/NhanSuEmployeeProfile/Duyet?id=${id}`,
                method: "POST",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Duyệt thành công !");
                loadDataInfor();
            } else {
                showToastError(res.message || "Duyệt thất bại");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi duyệt");
        }
    }
