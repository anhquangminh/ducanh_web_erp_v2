            if (res_ManagerId.success && Array.isArray(res_ManagerId.data)) {
                res_ManagerId.data.forEach(item => {
                    selectOptions_ManagerId += `<option value="${item.id}" ${data && data.managerId == item.id ? 'selected' : ''}>${item.fullName}</option>`;
