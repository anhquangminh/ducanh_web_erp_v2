    function validateFormInfor() {
        // Xóa lỗi cũ
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();

        let isValid = true;
        let firstInvalid = null;

        const requiredFields = [
            { selector: '#input-EmployeeId', message: 'Vui lòng nhập mã nhân viên.' },
            { selector: '#input-FullName', message: 'Vui lòng nhập Họ và tên.' },
            { selector: '#input-Gender', message: 'Vui lòng nhập Giới tính.' },
            { selector: '#input-IdentityCardNumber', message: 'Vui lòng nhập Số CCCD/CMND.' },
            { selector: '#input-MobilePhone', message: 'Vui lòng nhập Điện thoại di động.' },
            { selector: '#input-PersonalEmail', message: 'Vui lòng nhập Email cá nhân.' },
        ];

        // 1) --- Kiểm tra bắt buộc ---
        requiredFields.forEach(f => {
            const $input = $(f.selector);
            const val = $input.val();

            if (!val || val.trim() === '') {
                showErrorInfor(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
            }
        });

        // 2) --- Validate nâng cao ---

        // EMPLOYEE ID: phải đúng 6 ký tự
        let empId = $('#input-EmployeeId').val();
        if (empId && empId.trim().length !== 6) {
            showErrorInfor('#input-EmployeeId', 'Mã nhân viên phải gồm đúng 6 ký tự.');
            if (!firstInvalid) firstInvalid = $('#input-EmployeeId')[0];
            isValid = false;
        }

        // HỌ VÀ TÊN: chỉ chữ + khoảng trắng
        let fullName = $('#input-FullName').val();
        if (fullName && !/^[a-zA-ZÀ-ỹ\s]+$/.test(fullName.trim())) {
            showErrorInfor('#input-FullName', 'Họ và tên chỉ được chứa chữ cái và khoảng trắng.');
            if (!firstInvalid) firstInvalid = $('#input-FullName')[0];
            isValid = false;
        }

        // CCCD: đúng 12 số
        let cccd = $('#input-IdentityCardNumber').val();
        if (cccd && !/^\d{12}$/.test(cccd)) {
            showErrorInfor('#input-IdentityCardNumber', 'Số CCCD phải gồm đúng 12 chữ số.');
            if (!firstInvalid) firstInvalid = $('#input-IdentityCardNumber')[0];
            isValid = false;
        }

        // SĐT: 10 số, đầu số Việt Nam: 03|05|07|08|09
        let phone = $('#input-MobilePhone').val();
        if (phone && !/^(03|05|07|08|09)\d{8}$/.test(phone)) {
            showErrorInfor('#input-MobilePhone', 'Số điện thoại không hợp lệ (phải có 10 số và bắt đầu bằng 03/05/07/08/09).');
            if (!firstInvalid) firstInvalid = $('#input-MobilePhone')[0];
            isValid = false;
        }

        // Email: định dạng chuẩn
        let email = $('#input-PersonalEmail').val();
        if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
            showErrorInfor('#input-PersonalEmail', 'Email không đúng định dạng.');
            if (!firstInvalid) firstInvalid = $('#input-PersonalEmail')[0];
            isValid = false;
        }

        // Scroll đến lỗi đầu tiên
        if (!isValid && firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });

            const $el = $(firstInvalid);
            if ($el.hasClass('select2-hidden-accessible')) {
                $el.next('.select2-container').find('.select2-selection').focus();
            } else {
                $el.focus();
            }
        }

        return isValid;
    }
    function showErrorInfor(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }
