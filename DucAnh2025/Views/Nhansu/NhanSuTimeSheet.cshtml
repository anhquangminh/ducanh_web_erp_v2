<div class="tab-content">
    <div class="card mt-3 p-2">
        <div class="card-header">
            <h3 class="m-0 mr-2">Danh sách</h3>
            <span style="cursor:pointer;" onclick="showHuongDanNghiepVu()" title="Hướng dẫn sử dụng">
                <i class="bi bi-question-circle-fill text-info" style="font-size: 1.5em;"></i>
            </span>
        </div>
        <div class="card-body">
            <div>
                <button data-permission="Tao" class="mb-2 mr-2 btn-icon btn btn-primary" onclick="showModalTaoMoi()">
                    <i class="fas fa-plus btn-icon-wrapper"></i> Tạo mới
                </button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover" id="table_danhmuc">
                    <thead>
                        <tr>
                            <th></th>
                            <th>#</th>
                            <th>Mã nhân viên</th>
                            <th>Ngày Chấm công</th>
                            <th>Giờ Vào</th>
                            <th>Giờ Ra</th>
                            <th>Mã Loại công</th>
                            <th>Tổng Giờ công</th>
                            <th>Tổng Công thực tế</th>
                            <th>Nguồn dữ liệu</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th></th>
                            <th>#</th>
                            <th>Mã nhân viên</th>
                            <th>Ngày Chấm công</th>
                            <th>Giờ Vào</th>
                            <th>Giờ Ra</th>
                            <th>Mã Loại công</th>
                            <th>Tổng Giờ công</th>
                            <th>Tổng Công thực tế</th>
                            <th>Nguồn dữ liệu</th>
                            <th>Trạng thái</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
        let danhMucTable = null;
    $(function () {
        loadData();
    });

    function loadData() {
        getJwtToken().then(function (resUser) {
            $.ajax({
                url: `/api/NhanSuTimeSheet/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        employeeId: item.employeeId || '',
                        maNhanVien: item.maNhanVien || '',
                        timeSheetDate: formatDate(item.timeSheetDate) || null,
                        checkInTime: formatDate(item.checkInTime) || null,
                        checkOutTime: formatDate(item.checkOutTime) || null,
                        workTypeId: item.workTypeId || '',
                        totalHours: item.totalHours || '',
                        totalDays: item.totalDays || '',
                        source: item.source || '',
                        groupId: item.groupId || '',
                        ordinarily: item.ordinarily || 0,
                        createAt: formatDate(item.createAt) || null,
                        createBy: item.createBy || '',
                        isActive: item.isActive || 0,
                        approvalUserId: item.approvalUserId || '',
                        dateApproval: formatDate(item.dateApproval) || null,
                        approvalDept: item.approvalDept || '',
                        departmentId: item.departmentId || '',
                        departmentOrder: item.departmentOrder || 0,
                        approvalOrder: item.approvalOrder || 0,
                        approvalId: item.approvalId || '',
                        lastApprovalId: item.lastApprovalId || '',
                        isStatus: item.isStatus || '',
                    }));
                }
                if (!danhMucTable) {
                danhMucTable = $('#table_danhmuc').DataTable({
                    data: dataSet,
                    columns: [
                        {
                            data: null,
                            className: 'text-center align-middle',
                            orderable: false,
                            width: '1%',
                            render: function (data, type, row) {
                                let buttons = `
                                    <div class="btn-group">
                                `;
                                if (row.isActive < 3) {
                                    buttons += `
                                        <button class="btn btn-sm btn-success btn-approve" title="Duyệt" data-id="${row.id}" onclick="duyet('${row.id}')" ><i class="fas fa-check"></i></button>
                                        <button class="btn btn-sm btn-warning btn-cancel-approve" title="Hủy duyệt" data-id="${row.id}" onclick="huyDuyet('${row.id}')" ><i class="fas fa-times"></i></button>
                                    `;
                                } else if (row.isActive == 3) {
                                    buttons += `
                                        <button class="btn btn-sm btn-danger btn-delete" title="Xóa" data-id="${row.id}" onclick="deleteCaiDat('${row.id}')" ><i class="fas fa-trash"></i></button>
                                    `;
                                }
                                buttons += `
                                    <button class="btn btn-sm btn-primary btn-edit" title="Chỉnh sửa" data-id="${row.id}" onclick="editCaiDat('${row.id}')" ><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-sm btn-danger btn-delete" title="Chi tiết !" data-id="${row.id}" onclick="chiTiet('${row.id}')" ><i class="fas fa-eye"></i></button>
                                </div>
                                `;
                                return buttons;
                            }
                        },
                        { data: 'stt', className: 'text-center align-middle', width: '5%' },
                        {
                            data: 'maNhanVien',
                            className: 'align-middle',
                            render: function (data, type, row) {
                                return `<a href="javascript:void(0);" onclick="chiTiet('${row.id}')">${data}</a>`;
                            }
                        },
                        { data: 'timeSheetDate', className: 'align-middle' },
                        { data: 'checkInTime', className: 'align-middle' },
                        { data: 'checkOutTime', className: 'align-middle' },
                        { data: 'workTypeId', className: 'align-middle' },
                        { data: 'totalHours', className: 'align-middle' },
                        { data: 'totalDays', className: 'align-middle' },
                        { data: 'source', className: 'align-middle' },
                        { data: 'isStatus', className: 'align-middle' },
                    ],
                    autoWidth: false,
                    scrollX: false,
                    ordering: true,
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi moí trang ",
                        zeroRecords: "Không tìm thấy dữ liệu !",
                        info: "Hiển thị của _TOTAL_ bản ghi !_START_ đến _END_ của _TOTAL_ bản ghi !",
                        infoEmpty: "Không có bản ghi nào ",
                        infoFiltered: "( Lọc từ )_MAX_( bản ghi)",
                        search: "Tìm kiếm :",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function () {
                            var column = this;
                            var select = $('<select><option value=""></option></select>')
                                .appendTo($(column.footer()).empty())
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });
                            column.data().unique().sort().each(function (d) {
                                select.append('<option value="' + d + '">' + d + '</option>');
                            });
                        });
                    }
                });
               }else {
                danhMucTable.clear();
                danhMucTable.rows.add(dataSet);
                danhMucTable.draw(false);
                }
            }).fail(function (xhr) {
                $('#table_danhmuc tbody').html('<tr><td colspan="7" class="text-center text-danger">Lỗi khi tải dữ liệu </td></tr>');
            });
        });
    }
    async function showModalTaoMoi(isEdit = false, data = null) {
        const modalTitle = isEdit ? "Cập nhật" : "Thêm mới";
        const resUser = await getJwtToken();
       const token = resUser.token;
       const groupId = resUser.userInfor.groupId;
       const userName = resUser.userInfor.userName;

        let selectOptions_EmployeeId = '<option value="">Chọn Mã nhân viên --</option>';
        try {
            const res_EmployeeId = await $.ajax({
                url: `/api/NhanSuEmployeeProfile/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_EmployeeId.success && Array.isArray(res_EmployeeId.data)) {
                res_EmployeeId.data.forEach(item => {
                    selectOptions_EmployeeId += `<option value="${item.id}" ${data && data.employeeId === item.id ? 'selected' : ''}>${item.fullName} (${item.employeeId})</option>`;
                });
            }
        } catch {
            selectOptions_EmployeeId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        let selectOptions_WorkTypeId = '<option value="">Chọn Mã Loại công --</option>';
        try {
            const res_WorkTypeId = await $.ajax({
                url: `/api/NhanSuDMWorkType/GetAll?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + token
                }
            });
            if (res_WorkTypeId.success && Array.isArray(res_WorkTypeId.data)) {
                res_WorkTypeId.data.forEach(item => {
                    selectOptions_WorkTypeId += `<option value="${item.id}" ${data && data.workTypeId === item.id ? 'selected' : ''}>${item.workTypeName}</option>`;
                });
            }
        } catch {
            selectOptions_WorkTypeId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        const bodyHtml = `
                <form id="form_timesheet" class="row">

                    <!-- Nhân viên -->
                    <div class="form-group col-md-3">
                        <label>Mã nhân viên</label>
                        <select id="select-EmployeeId" class="form-control">
                            ${selectOptions_EmployeeId}
                        </select>
                    </div>

                    <!-- Ngày chấm công -->
                    <div class="form-group col-md-3">
                        <label>Ngày Chấm công <span class="text-danger">*</span></label>
                        <input type="date" id="input-TimeSheetDate" name="TimeSheetDate"
                               value="${data ? formatDate(data.timeSheetDate) : ''}"
                               class="form-control" />
                    </div>

                    <!-- Giờ vào -->
                    <div class="form-group col-md-3">
                        <label>Giờ Vào <span class="text-danger">*</span></label>
                        <input type="time" id="input-CheckInTime" name="CheckInTime"
                               value="${data ? formatTime(data.checkInTime) : ''}"
                               class="form-control" />
                    </div>

                    <!-- Giờ ra -->
                    <div class="form-group col-md-3">
                        <label>Giờ Ra <span class="text-danger">*</span></label>
                        <input type="time" id="input-CheckOutTime" name="CheckOutTime"
                               value="${data ? formatTime(data.checkOutTime) : ''}"
                               class="form-control" />
                    </div>

                    <!-- Loại công -->
                    <div class="form-group col-md-3">
                        <label>Mã Loại công</label>
                        <select id="select-WorkTypeId" class="form-control">
                            ${selectOptions_WorkTypeId}
                        </select>
                    </div>

                    <!-- Tổng giờ -->
                    <div class="form-group col-md-3">
                        <label>Tổng Giờ công <span class="text-danger">*</span></label>
                        <input type="number" step="0.1" id="input-TotalHours" name="TotalHours"
                               value="${data ? data.totalHours : ''}"
                               class="form-control" readonly />
                    </div>

                    <!-- Tổng công -->
                    <div class="form-group col-md-3">
                        <label>Tổng Công thực tế <span class="text-danger">*</span></label>
                        <input type="number" step="0.01" id="input-TotalDays" name="TotalDays"
                               value="${data ? data.totalDays : ''}"
                               class="form-control" readonly />
                    </div>

                    <!-- Nguồn dữ liệu -->
                    <div class="form-group col-md-3">
                        <label>Nguồn dữ liệu</label>
                        <input type="text" id="input-Source" name="Source"
                               value="${data ? data.source : ''}"
                               class="form-control" />
                    </div>
                </form>
                <div id="error_msg" class="text-danger font-weight-bold mb-2"></div>
        `;
        const footerHtml = `
            <button type="button" class="btn btn-primary" id="btnLuuCaiDat">${isEdit ? "Cập nhật" : "Lưu "}</button>
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>`;
        showGlobalModal(modalTitle, bodyHtml, footerHtml);
        $('#btnLuuCaiDat').data("isedit", isEdit).data("id", data?.id || "");
        $('#btnLuuCaiDat').off('click').on('click', async function () {
            $('#error_msg').text("");
            const resUser = await getJwtToken();
            const token = resUser.token;
            const isEdit = $(this).data("isedit") === true;
            const id = $(this).data("id");
            if (!validateForm())
               return;

            const date = $('#input-TimeSheetDate').val();
            // Giờ vào
            let checkIn = $('#input-CheckInTime').val(); // HH:mm
            let checkOut = $('#input-CheckOutTime').val(); // HH:mm
            let checkInDateTime = checkIn ? new Date(`${date}T${checkIn}:00`) : null;
            let checkOutDateTime = checkOut ? new Date(`${date}T${checkOut}:00`) : null;
            // Nếu giờ ra < giờ vào → ca đêm → cộng 1 ngày cho giờ ra
            if (checkInDateTime && checkOutDateTime && checkOutDateTime < checkInDateTime) {
                checkOutDateTime.setDate(checkOutDateTime.getDate() + 1);
            }

            const dataSend = {
                Id: id,
                EmployeeId: $('#select-EmployeeId').val() || "",
                TimeSheetDate: date ? new Date(date) : null,
                CheckInTime: checkInDateTime,
                CheckOutTime: checkOutDateTime,
                WorkTypeId: $('#select-WorkTypeId').val() || "",
                TotalHours: parseFloat($('#input-TotalHours').val()) || 0,
                TotalDays: parseFloat($('#input-TotalDays').val()) || 0,
                Source: $('#input-Source').val() || "",
                GroupId: groupId,
                Ordinarily: 0,
                CreateAt: new Date().toISOString(),
                CreateBy: userName,
                IsActive: isEdit && data ? data.isActive : 0,
                ApprovalUserId: "",
                DateApproval: null,
                ApprovalDept: "",
                DepartmentId: "",
                DepartmentOrder: 0,
                ApprovalOrder: 0,
                ApprovalId: "",
                LastApprovalId: "",
                IsStatus: ""
            };
            try {
                const res = await $.ajax({
                    url: `/api/NhanSuTimeSheet/Create?isEdit=${isEdit}`,
                    method: "POST",
                    contentType: "application/json",
                    headers: { Authorization: `Bearer ${token}` },
                    data: JSON.stringify(dataSend)
                });
                if (res.success) {
                    showToastSuccess(isEdit ? "Cập nhật thành công " : "Lưu thành công");
                    $('#globalModal').modal('hide');
                    loadData();
                } else {
                    $('#error_msg').text(res.message || "Có lỗi xảy ra khi lưu");
                    showToastError(res.message || "Có lỗi xảy ra khi lưu");
                }
            } catch (err) {
                $('#error_msg').text("Có lỗi xảy ra khi lưu");
            }
        });
    }

    function validateForm() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();
        let isValid = true;
        let firstInvalid = null;

        const requiredFields = [
            { selector: '#input-TimeSheetDate', message: 'Vui lòng nhâp Ngày Chấm công.' },
            { selector: '#input-CheckInTime', message: 'Vui lòng nhâp Giờ Vào.' },
            { selector: '#input-CheckOutTime', message: 'Vui lòng nhâp Giờ Ra.' },
        ];

        // Kiểm tra rỗng
        requiredFields.forEach(f => {
            const $input = $(f.selector);
            if (!$input.val()) {
                showError(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
            }
        });

        if (!isValid) {
            focusField(firstInvalid);
            return false;
        }

        // Kiểm tra giờ vào-ra hợp lệ
        const checkIn = $("#input-CheckInTime").val();
        const checkOut = $("#input-CheckOutTime").val();

        let tIn = new Date("2000-01-01 " + checkIn);
        let tOut = new Date("2000-01-01 " + checkOut);

        if (tOut <= tIn) tOut = new Date("2000-01-02 " + checkOut); // ca đêm

        const diffHours = (tOut - tIn) / (1000 * 60 * 60);

        if (diffHours <= 0 || diffHours > 24) {
            showError('#input-CheckOutTime', "Giờ Ra không hợp lệ.");
            focusField('#input-CheckOutTime');
            return false;
        }

        return true;
    }

    function focusField(el) {
        const $el = $(el);
        $el[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
        $el.focus();
    }

    $(document).on("change", "#input-CheckInTime, #input-CheckOutTime", function () {
        calcHours();
    });

    function calcHours() {
        const checkIn = $("#input-CheckInTime").val();
        const checkOut = $("#input-CheckOutTime").val();

        if (!checkIn || !checkOut) return;

        let tIn = new Date("2000-01-01 " + checkIn);
        let tOut = new Date("2000-01-01 " + checkOut);

        // --- Trường hợp ca đêm ---
        if (tOut <= tIn) {
            tOut = new Date("2000-01-02 " + checkOut);
        }

        const diffHours = (tOut - tIn) / (1000 * 60 * 60);
        const totalHours = Math.round(diffHours * 10) / 10; // làm tròn 0.1 giờ

        $("#input-TotalHours").val(totalHours);

        // tổng công = tổng giờ / 8
        $("#input-TotalDays").val((totalHours / 8).toFixed(2));
    }


    function showError(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }
    async function chiTiet(id) {
        const resUser = await getJwtToken();
        const token = resUser.token;

        try {
            const res = await $.ajax({
                url: `/api/NhanSuTimeSheet/GetHistory?id=${id}`,
                method: "GET",
                headers: { Authorization: `Bearer ${token}` }
            });

            if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                let tableRows = res.data.map((item, idx) => `
                    <tr>
                        <td class="text-center">${idx + 1}</td>
                        <td>${item.maNhanVien || ''}</td>
                        <td>${item.timeSheetDate || ''}</td>
                        <td>${item.checkInTime || ''}</td>
                        <td>${item.checkOutTime || ''}</td>
                        <td>${item.workTypeId || ''}</td>
                        <td>${item.totalHours || ''}</td>
                        <td>${item.totalDays || ''}</td>
                        <td>${item.source || ''}</td>
                        <td>${item.groupId || ''}</td>
                        <td>${item.ordinarily || ''}</td>
                        <td>${item.createAt || ''}</td>
                        <td>${item.createBy || ''}</td>
                        <td>${item.isActive || ''}</td>
                        <td>${item.approvalUserId || ''}</td>
                        <td>${item.dateApproval || ''}</td>
                        <td>${item.approvalDept || ''}</td>
                        <td>${item.departmentId || ''}</td>
                        <td>${item.departmentOrder || ''}</td>
                        <td>${item.approvalOrder || ''}</td>
                        <td>${item.approvalId || ''}</td>
                        <td>${item.lastApprovalId || ''}</td>
                        <td>${item.isStatus || ''}</td>
                        <td>${item.createBy || ''}</td>
                        <td>${item.createAt ? new Date(item.createAt).toLocaleString() : ''}</td>
                    </tr>`).join('');

                const bodyHtml = `
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover no-wrap-table">
                            <thead class="thead-light">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th> Mã nhân viên</th>
                                    <th> Ngày Chấm công</th>
                                    <th> Giờ Vào</th>
                                    <th> Giờ Ra</th>
                                    <th> Mã Loại công</th>
                                    <th> Tổng Giờ công</th>
                                    <th> Tổng Công thực tế</th>
                                    <th> Nguồn dữ liệu</th>
                                    <th> GroupId</th>
                                    <th> Thứ tự</th>
                                    <th> Ngày tạo</th>
                                    <th> Người tạo</th>
                                    <th> IsActive</th>
                                    <th> Người duyệt</th>
                                    <th> Ngày duyệt</th>
                                    <th> Phòng ban duyệt</th>
                                    <th> Phòng ban duyệt tiếp</th>
                                    <th> Thứ tự phòng ban</th>
                                    <th> Thứ tự duyệt</th>
                                    <th> ID duyệt</th>
                                    <th> Id duyệt cuối</th>
                                    <th> Trạng thái</th>
                                    <th>Nguoi thao tác</th>
                                    <th>Thời gian</th>
                                </tr>
                            </thead>
                            <tbody>${tableRows}</tbody>
                        </table>
                    </div>`;

                showGlobalModal("Lịch sử", bodyHtml, `<button class="btn btn-secondary" data-dismiss="modal">Ðóng</button>`);
            } else {
                showGlobalModal("Lịch sử", `<div class="text-center text-muted">Không có lịch sử</div>`, `<button class="btn btn-secondary" data-dismiss="modal">Ðóng</button>`);
            }
        } catch (err) {
            showGlobalModal("Lịch sử", `<div class="text-center text-danger">Lỗi khi tải dữ liệu lịch sử</div>`, `<button class="btn btn-secondary" data-dismiss="modal">Ðóng</button>`);
        }
    }
    async function duyet(id) {
        if (!confirm('Bạn có chắc chắn muốn duyệt ')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/NhanSuTimeSheet/Duyet?id=${id}`,
                method: "POST",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Duyệt thành công !");
                loadData();
            } else {
                showToastError(res.message || "Duyệt thất bại");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi duyệt");
        }
    }
    async function huyDuyet(id) {
        if (!confirm('Bạn có chắc chắn muốn hủy duyẹt !')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/NhanSuTimeSheet/HuyDuyet?id=${id}`,
                method: "POST",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Hủy duyệt thành công");
                loadData();
            } else {
                showToastError(res.message || "Hủy duyệt thất bại");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi hủy duyệt");
        }
    }
    async function editCaiDat(id) {
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/NhanSuTimeSheet/GetById?id=${id}`,
                method: "GET",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success && res.data) {
                showModalTaoMoi(true, res.data);
            } else {
                showToastError(res.message || "Không lấy được dữ liệu");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi chỉnh sửa ");
        }
    }
    async function deleteCaiDat(id) {
        if (!confirm('Bạn chác chắn muốn xóa ?')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/NhanSuTimeSheet/${id}`,
                method: "DELETE",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Xóa thành công !");
                loadData();
            } else {
                showToastError(res.message || "Xóa thất bại");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi xóa");
        }
    }
