    function validateFormContract() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();

        let isValid = true;
        let firstInvalid = null;

        const requiredFields = [
            { selector: '#input-ContractCode', message: 'Vui lòng nhập Mã Số Hợp đồng.' },
            { selector: '#input-ContractName', message: 'Vui lòng nhập Tên Hợp đồng.' },
            { selector: '#input-SigningDate', message: 'Vui lòng nhập Ngày Ký kết.' },
            { selector: '#input-EffectiveDate', message: 'Vui lòng nhập Ngày Hiệu lực.' },
            { selector: '#input-ExpirationDate', message: 'Vui lòng nhập Ngày Hết hạn.' },
            { selector: '#input-ContractSalary', message: 'Vui lòng nhập Mức lương ghi trong HĐ.' },
            { selector: '#input-DurationMonths', message: 'Vui lòng nhập Thời hạn HĐ (tháng).' },
        ];

        // 1) Kiểm tra bắt buộc
        requiredFields.forEach(f => {
            const $input = $(f.selector);
            const val = $input.val();

            if (!val || val.trim() === '') {
                showErrorContract(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
            }
        });

        // 2) Validate nâng cao
        let signingDate = $('#input-SigningDate').val();
        let effectiveDate = $('#input-EffectiveDate').val();
        let expirationDate = $('#input-ExpirationDate').val();
        let salary = $('#input-ContractSalary').val();
        let duration = $('#input-DurationMonths').val();

        // --- Ngày ký không được lớn hơn ngày hiệu lực ---
        if (signingDate && effectiveDate && new Date(signingDate) > new Date(effectiveDate)) {
            showErrorContract('#input-SigningDate', 'Ngày ký không được sau Ngày hiệu lực.');
            if (!firstInvalid) firstInvalid = $('#input-SigningDate')[0];
            isValid = false;
        }

        // --- Ngày hiệu lực không được lớn hơn ngày hết hạn ---
        if (effectiveDate && expirationDate && new Date(effectiveDate) > new Date(expirationDate)) {
            showErrorContract('#input-EffectiveDate', 'Ngày hiệu lực phải nhỏ hơn hoặc bằng Ngày hết hạn.');
            if (!firstInvalid) firstInvalid = $('#input-EffectiveDate')[0];
            isValid = false;
        }

        // --- Lương phải là số dương ---
        if (salary && (isNaN(salary) || Number(salary) <= 0)) {
            showErrorContract('#input-ContractSalary', 'Mức lương phải là số dương.');
            if (!firstInvalid) firstInvalid = $('#input-ContractSalary')[0];
            isValid = false;
        }

        // --- Thời hạn HĐ (tháng) phải là số nguyên dương ---
        if (duration && (!/^\d+$/.test(duration) || Number(duration) <= 0)) {
            showErrorContract('#input-DurationMonths', 'Thời hạn HĐ phải là số nguyên dương.');
            if (!firstInvalid) firstInvalid = $('#input-DurationMonths')[0];
            isValid = false;
        }

        // Cuộn tới lỗi đầu tiên
        if (!isValid && firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });

            const $el = $(firstInvalid);
            if ($el.hasClass('select2-hidden-accessible')) {
                $el.next('.select2-container').find('.select2-selection').focus();
            } else {
                $el.focus();
            }
        }

        return isValid;
    }

    function showErrorContract(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }
