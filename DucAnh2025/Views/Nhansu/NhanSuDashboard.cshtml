                res_EmployeeId.data.forEach(item => {
                    selectOptions_EmployeeId += `<option value="${item.id}" ${data && data.employeeId === item.id ? 'selected' : ''}>${item.fullName} (${item.employeeId})</option>`;
                });
            }
        } catch {
            selectOptions_EmployeeId += '<option value="">Lỗi tải dữ liệu </option>';
        }
        const bodyHtml = `
            <form id="form_caidat" class="row">
                <div class="form-group col-md-3">
                    <label>Mã nhân viên</label>
                    <select id="select-EmployeeId" class="form-control">${selectOptions_EmployeeId}</select>
                </div>
                <div class="form-group col-md-3">
                    <label>Ngày Hiệu lực <span class="text-danger">*</span></label>
                    <input type="date" id="input-EffectiveDate" name="EffectiveDate" value="${data ? formatDate(data.effectiveDate) : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Mức Lương Cơ bản <span class="text-danger">*</span></label>
                    <input type="number" id="input-BasicSalary" name="BasicSalary" value="${data ? data.basicSalary : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Tổng Phụ cấp Cố định <span class="text-danger">*</span></label>
                    <input type="number" id="input-TotalFixedAllowance" name="TotalFixedAllowance" value="${data ? data.totalFixedAllowance : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Chi tiết Phụ cấp <span class="text-danger">*</span></label>
                    <input type="text" id="input-AllowanceDetails" name="AllowanceDetails" value="${data ? data.allowanceDetails : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Mã Quyết định Lương <span class="text-danger">*</span></label>
                    <input type="text" id="input-DecisionCode" name="DecisionCode" value="${data ? data.decisionCode : ''}" class="form-control" />
                </div>
                <div class="form-group col-md-3">
                    <label>Lý do thay đổi <span class="text-danger">*</span></label>
                    <input type="text" id="input-ChangeReason" name="ChangeReason" value="${data ? data.changeReason : ''}" class="form-control" />
                </div>
            </form>
            <div id="error_msg" class="text-danger font-weight-bold mb-2"></div>
        `;
        const footerHtml = `
            <button type="button" class="btn btn-primary" id="btnLuuCaiDat">${isEdit ? "Cập nhật" : "Lưu "}</button>
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>`;
        showGlobalModal(modalTitle, bodyHtml, footerHtml);
        $('#btnLuuCaiDat').data("isedit", isEdit).data("id", data?.id || "");
        $('#btnLuuCaiDat').off('click').on('click', async function () {
            $('#error_msg').text("");
            const resUser = await getJwtToken();
            const token = resUser.token;
            const isEdit = $(this).data("isedit") === true;
            const id = $(this).data("id");
            if (!validateFormSalary())
               return;
            const dataSend = {
                Id: id,
                EmployeeId: $('#select-EmployeeId').val() || "",
                EffectiveDate: $('#input-EffectiveDate').val() || null,
                BasicSalary: $('#input-BasicSalary').val() || 0.0,
                TotalFixedAllowance: $('#input-TotalFixedAllowance').val() || 0.0,
                AllowanceDetails: $('#input-AllowanceDetails').val() || "",
                DecisionCode: $('#input-DecisionCode').val() || "",
                ChangeReason: $('#input-ChangeReason').val() || "",
                GroupId: groupId,
                Ordinarily: 0,
                CreateAt: new Date().toISOString(),
                CreateBy: userName,
                IsActive: isEdit && data ? data.isActive : 0,
                ApprovalUserId: "",
                DateApproval: null,
                ApprovalDept: "",
                DepartmentId: "",
                DepartmentOrder: 0,
                ApprovalOrder: 0,
                ApprovalId: "",
                LastApprovalId: "",
                IsStatus: ""
            };
            try {
                const res = await $.ajax({
                    url: `/api/NhanSuSalaryHistory/Create?isEdit=${isEdit}`,
                    method: "POST",
                    contentType: "application/json",
                    headers: { Authorization: `Bearer ${token}` },
                    data: JSON.stringify(dataSend)
                });
                if (res.success) {
                    showToastSuccess(isEdit ? "Cập nhật thành công " : "Lưu thành công");
                    $('#globalModal').modal('hide');
                    loadDataSalary();
                } else {
                    $('#error_msg').text(res.message || "Có lỗi xảy ra khi lưu");
                    showToastError(res.message || "Có lỗi xảy ra khi lưu");
                }
            } catch (err) {
                $('#error_msg').text("Có lỗi xảy ra khi lưu");
            }
        });
    }

    function validateFormSalary() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();

        let isValid = true;
        let firstInvalid = null;

        const requiredFields = [
            { selector: '#input-EffectiveDate', message: 'Vui lòng nhập Ngày Hiệu lực.' },
            { selector: '#input-BasicSalary', message: 'Vui lòng nhập Mức Lương Cơ bản.', type: 'number' },
            { selector: '#input-TotalFixedAllowance', message: 'Vui lòng nhập Tổng Phụ cấp Cố định.', type: 'number' },
            { selector: '#input-AllowanceDetails', message: 'Vui lòng nhập Chi tiết Phụ cấp.' },
            { selector: '#input-DecisionCode', message: 'Vui lòng nhập Mã Quyết định Lương.' },
            { selector: '#input-ChangeReason', message: 'Vui lòng nhập Lý do thay đổi.' },
        ];

        requiredFields.forEach(f => {
            const $input = $(f.selector);
            const value = $input.val()?.trim();

            // Kiểm tra rỗng
            if (!value) {
                showErrorSalary(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
                return;
            }

            // Kiểm tra số không âm
            if (f.type === 'number' && (isNaN(value) || Number(value) < 0)) {
                showErrorSalary(f.selector, 'Giá trị phải là số hợp lệ và ≥ 0.');
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
                return;
            }
        });

        // Scroll + focus vào phần tử lỗi đầu tiên
        if (!isValid && firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
            const $el = $(firstInvalid);

            // Nếu là Select2
            if ($el.hasClass('select2-hidden-accessible')) {
                $el.next('.select2-container').find('.select2-selection').focus();
            } else {
                $el.focus();
            }
        }

        return isValid;
    }

    function showErrorSalary(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }
