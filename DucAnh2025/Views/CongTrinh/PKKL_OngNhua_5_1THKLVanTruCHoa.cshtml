                        const uniqueTuyenDuongs = [...new Set(data16.map(item => item.uniqueTuyenDuong))];

                        uniqueTuyenDuongs.forEach(td => {
                            // Tính tổng theo điều kiện
                            const sum = data16
                                .filter(item =>
