<script>
    async function exportExcel(){
        await exportExcelCustom("table_data", [
            { text: "CÔNG TY CỔ PHẦN XÂY DỰNG ĐỨC ANH", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "KHU CÔNG NGHIỆP CẨM KHÊ", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "", cols: 10 },
            { text: "BẢNG CAO ĐỘ ĐẮP HỐ MÓNG ỐNG NƯỚC SẠCH NGANG", align: "center", fontSize: 12, bold: true },
            { text: "Mẫu số 03", align: "center", fontSize: 12, bold: true },
            { text: "In theo từng tuyến", align: "center", fontSize: 11 }
        ], "2.3 C.Độ đắp N.Sạch ngang", "2.3 C.Độ đắp N.Sạch ngang.xlsx");
    }

    $(function () {
        loadData();
    });

    function loadData() {
        showBlockLoading('.table-responsive');
        getJwtToken().then(async function (resUser) {
            await $.ajax({
                url: `/api/PKKLOngNhua2TtChungNSachNgang/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        tenChiNhanh: item.tenChiNhanh ||'',

                        tuyenDuong: item.tuyenDuong|| '',
                        tuLyTrinh: item.tuLyTrinh|| '',
                        denLyTrinh: item.denLyTrinh|| '',
                        loaiCauKien: item.loaiCauKien|| '',
                        duongKinhNgoaiOngNhua: item.duongKinhNgoaiOngNhua|| '0',
                        cDayOngOngNhua: item.cDayOngOngNhua|| '0',
                        chieuDaiOngNhua: item.chieuDaiOngNhua|| '0',
                        cDayDemCatThuongLuu: item.cDayDemCatThuongLuu|| '0',
                        dinhDemCatThuongLuu: item.dinhDemCatThuongLuu|| '0',
                        dongChayThuongLuu: item.dongChayThuongLuu|| '0',
                        dinhDuongOngThuongLuu: item.dinhDuongOngThuongLuu|| '0',
                        dongChayThuongLuu: item.dongChayThuongLuu|| '0',
                        dinhDuongOngThuongLuu: item.dinhDuongOngThuongLuu|| '0',
                        cDoDayDapDatThuongLuu: item.cDoDayDapDatThuongLuu|| '0',
                        chieuDayDapDatThuongLuu: item.chieuDayDapDatThuongLuu|| '0',
                        dinhDapDatThuongLuu: item.dinhDapDatThuongLuu|| '0',
                        cDayDemCatHaLuu: item.cDayDemCatHaLuu|| '0',
                        dinhDemCatHaLuu: item.dinhDemCatHaLuu|| '0',
                        dongChayHaLuu: item.dongChayHaLuu|| '0',
                        dinhDuongOngHaLuu: item.dinhDuongOngHaLuu|| '0',
                        cDayDapCatHaLuu: item.cDayDapCatHaLuu|| '0',
                        dinhDapCatHaLuu: item.dinhDapCatHaLuu|| '0',
                        cDoDayDapDatHaLuu: item.cDoDayDapDatHaLuu|| '0',
                        chieuDayDapDatHaLuu: item.chieuDayDapDatHaLuu|| '0',
                        dinhDapDatHaLuu: item.dinhDapDatHaLuu|| '0',

                        isStatus: item.isStatus || '',
                        isActive: item.isActive || '',
                    }));
                }

                const $table = $('#table_data');
                if ($.fn.DataTable.isDataTable($table)) {
                    $table.DataTable().clear().destroy();
                }

                $table.DataTable({
                    data: dataSet,
                    columns: [
                        { data: 'stt', className: 'text-center align-middle', width: '1%' },
                        { data: 'isStatus', className: 'align-middle' },
                        { data: 'tenChiNhanh', className: 'align-middle' },

                        { data: 'tuyenDuong', className: 'text-center align-middle', width: '1%' },
                        { data: 'tuLyTrinh', className: 'text-center align-middle', width: '1%' },
                        { data: 'denLyTrinh', className: 'text-center align-middle', width: '1%' },
                        { data: 'loaiCauKien', className: 'text-center align-middle', width: '1%' },
                        { data: 'duongKinhNgoaiOngNhua', className: 'text-center align-middle', width: '1%' },
                        { data: 'cDayOngOngNhua', className: 'text-center align-middle', width: '1%' },
                        { data: 'chieuDaiOngNhua', className: 'text-center align-middle', width: '1%' },
                        { data: 'cDayDemCatThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDemCatThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dongChayThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDuongOngThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dongChayThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDuongOngThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'cDoDayDapDatThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'chieuDayDapDatThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDapDatThuongLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'cDayDemCatHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDemCatHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dongChayHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDuongOngHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'cDayDapCatHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDapCatHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'cDoDayDapDatHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'chieuDayDapDatHaLuu', className: 'text-center align-middle', width: '1%' },
                        { data: 'dinhDapDatHaLuu', className: 'text-center align-middle', width: '1%' },

                      ],
                    autoWidth: false,
                    scrollX: false,
                    ordering: true,
                    order: [[0, 'asc']],
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                        zeroRecords: "Không tìm thấy dữ liệu",
                        info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                        infoEmpty: "Không có bản ghi nào",
                        infoFiltered: "(lọc từ _MAX_ bản ghi)",
                        search: "Tìm kiếm:",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function (colIdx) {
                            var column = this;
                            var $footer = $(column.footer()).empty();
                            if (colIdx === 0 || colIdx === 1) {
                                $footer.append('<p></p>');
                            }else{
                                var select = $('<select><option value=""></option></select>')
                                .appendTo($footer)
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });

                                column.data().unique().sort().each(function (d) {
                                    select.append('<option value="' + d + '">' + d + '</option>');
                                });
                            }

                        });
                    }

                });
            }).fail(function (xhr) {
                var colCount = $('#table_data thead th').length;
                $('#table_data tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');
            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }


    // Hiển thị lỗi
    function showError(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }

</script>