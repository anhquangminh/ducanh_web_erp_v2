<div class="tab-content">
    <div class="card mt-3 w-100 d-flex">
        <div class="card-header">
            <h3 class="m-0 mr-2">BẢNG LÝ TRÌNH VAN VÀ TRỤ CỨU HỎA </h3>
            <span style="cursor:pointer;" onclick="showHuongDanNghiepVu()" title="Hướng dẫn sử dụng">
                <i class="bi bi-question-circle-fill text-info" style="font-size: 1.5em;"></i>
            </span>
        </div>
        <div class="card-body">
            <div>
                <button data-permission="Tao" class="mb-2 mr-2 btn-icon btn btn-primary" onclick="showModalTaoMoi()">
                    <i class="fas fa-plus btn-icon-wrapper"></i>Tạo mới
                </button>
            </div>
            <div role="group" class="mb-2 btn-group-sm btn-group btn-group-toggle" data-toggle="buttons">
                <button type="button" class="btn btn-outline-focus" onclick="copyTable('table_data')">Copy</button>
                <button type="button" class="btn btn-outline-focus" onclick="exportExcel()">Excel</button>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="table_data">
                    <thead>
                        <tr>
                            <td colspan="4" class="text-center"></td>
                            <td colspan="3" class="text-center">Thông tin lý trình</td>
                            <td colspan="3" class="text-center">Thông tin khối lượng van + trụ cứu hỏa</td>
                            <td colspan="3" class="text-center">Tọa độ</td>
                        </tr>
                        <tr>
                            <th>#</th>
                            <th></th>
                            <th> Trạng thái</th>
                            <th> Tên công trình</th>
                            <th> Tuyến đường</th>
                            <th> Từ lý trình</th>
                            <th> Hạng mục công việc</th>
                            <th> Loại cấu kiện</th>
                            <th> Hạng mục KL</th>
                            <th> Loại cấu kiện</th>
                            <th> X</th>
                            <th> Y</th>
                            <th> Trạng thái thi công</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>#</th>
                            <th></th>
                            <th>Trạng thái</th>
                            <th> Tên công trình</th>
                            <th> Tuyến đường</th>
                            <th> Từ lý trình</th>
                            <th> Hạng mục công việc</th>
                            <th> Loại cấu kiện</th>
                            <th> Hạng mục KL</th>
                            <th> Loại cấu kiện</th>
                            <th> X</th>
                            <th> Y</th>
                            <th> Trạng thái thi công</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    async function exportExcel(){
        await exportExcelCustom("table_data", [
            { text: "CÔNG TY CỔ PHẦN XÂY DỰNG ĐỨC ANH", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "KHU CÔNG NGHIỆP CẨM KHÊ", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "", cols: 10 },
            { text: "BẢNG LÝ TRÌNH VAN VÀ TRỤ CỨU HỎA ", align: "center", fontSize: 12, bold: true },
            { text: "Mẫu số 01", align: "center", fontSize: 12, bold: true },
            { text: "In theo từng tuyến.", align: "center", fontSize: 11 }
        ], "3.T.Tin L.Đặt van +Trụ C.Hỏa", "3.T.Tin L.Đặt van +Trụ C.Hỏa.xlsx",[1,2]);
    }
    let sourceData = null;
    $(function () {
        loadData();
    });

    function loadData() {
        showBlockLoading('.table-responsive');
        getJwtToken().then(async function (resUser) {
            await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        tenChiNhanh: item.tenChiNhanh ||'',
                        id_TuyenDuong: item.id_TuyenDuong || '',
                        tuyenDuong: item.tuyenDuong || '',
                        id_TuLyTrinh: item.id_TuLyTrinh || '',
                        tuLyTrinh: item.tuLyTrinh || '',
                        id_HangMucCongViec : item.id_HangMucCongViec|| '',
                        hangMucCongViec : item.hangMucCongViec|| '',
                        id_LoaiCauKien : item.id_LoaiCauKien|| '',
                        loaiCauKien : item.loaiCauKien|| '',
                        id_HangMucKhoiLuong : item.id_HangMucKhoiLuong|| '',
                        hangMucKhoiLuong : item.hangMucKhoiLuong|| '',
                        id_LoaiKhoiLuong : item.id_LoaiKhoiLuong|| '',
                        loaiKhoiLuong : item.loaiKhoiLuong|| '',
                        x : item.X|| 0,
                        y : item.Y ||0,
                        id_TrangThaiThiCong : item.id_TrangThaiThiCong|| '',
                        trangThaiThiCong : item.trangThaiThiCong|| '',

                        isStatus: item.isStatus || '',
                        isActive: item.isActive || '',
                    }));
                }

                if (sourceData) {
                  sourceData = $('#table_data').DataTable({
                    data: dataSet,
                    columns: [
                        { data: 'stt', className: 'text-center align-middle', width: '1%' },
                        {
                            data: null,
                            className: 'text-center align-middle',
                            orderable: false,
                            width: "1%",
                            render: function (data, type, row) {
                                let buttons = `
                                         <div class="btn-group">
                                     `;
                                // Chỉ hiển thị nút duyệt/hủy duyệt khi isActive == 0,1,2 (chờ duyệt)
                                 if (row.isActive < 3) {
                                     buttons += `
                                         <button class="btn btn-sm btn-success btn-approve" title="Duyệt" data-id="${row.id}" onclick="duyet('${row.id}')"><i class="fas fa-check"></i></button>
                                         <button class="btn btn-sm btn-warning btn-cancel-approve" title="Hủy duyệt" data-id="${row.id}" onclick="huyDuyet('${row.id}')"><i class="fas fa-times"></i></button>
                                     `;
                                 }else if (row.isActive = 3) {
                                      buttons += `
                                      <button class="btn btn-sm btn-danger btn-delete" title="Xóa" data-id="${row.id}" onclick=deleteCaiDat("${row.id}")><i class="fas fa-trash"></i></button>`;
                                 }
                                 buttons += `
                                     <button class="btn btn-sm btn-primary btn-edit" title="Chỉnh sửa" data-id="${row.id}" onclick=editCaiDat("${row.id}")><i class="fas fa-edit"></i></button>
                                     <button class="btn btn-sm btn-danger btn-delete" title="Chi tiết" data-id="${row.id}" onclick=chiTiet("${row.id}")><i class="fas fa-eye"></i></button>

                                 </div>
                                 `;
                                return buttons;
                            }
                        },
                        { data: 'isStatus', className: 'align-middle' },
                        { data: 'tenChiNhanh', className: 'align-middle' },
                        { data: 'tuyenDuong', className: 'align-middle' },
                        { data: 'tuLyTrinh', className: 'align-middle' },
                        { data: 'hangMucCongViec', className: 'align-middle' },
                        { data: 'loaiCauKien', className: 'align-middle' },
                        { data: 'hangMucKhoiLuong', className: 'align-middle' },
                        { data: 'loaiKhoiLuong', className: 'align-middle' },
                        { data: 'x', className: 'align-middle' },
                        { data: 'y', className: 'align-middle' },
                        { data: 'trangThaiThiCong', className: 'align-middle' },
                    ],
                    autoWidth: false,
                    ordering: true,
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                        zeroRecords: "Không tìm thấy dữ liệu",
                        info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                        infoEmpty: "Không có bản ghi nào",
                        infoFiltered: "(lọc từ _MAX_ bản ghi)",
                        search: "Tìm kiếm:",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function (colIdx) {
                            var column = this;
                            var $footer = $(column.footer()).empty();
                            if (colIdx === 0 || colIdx === 1) {
                                $footer.append('<p></p>');
                            }else{
                                var select = $('<select><option value=""></option></select>')
                                .appendTo($footer)
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });

                                column.data().unique().sort().each(function (d) {
                                    select.append('<option value="' + d + '">' + d + '</option>');
                                });
                            }
                            
                        });
                    }
                });
              } else {
                    sourceData.clear();
                    sourceData.rows.add(dataSet);
                    sourceData.draw(false);
                }
            }).fail(function (xhr) {
                var colCount = $('#table_data thead th').length;
                $('#table_data tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');
            
            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }

    async function showModalTaoMoi(isEdit = false, data = null) {
        const modalTitle = isEdit ? "Cập nhật " : "Thêm mới ";
        const resUser = await getJwtToken();
        const token = resUser.token;
        const groupId = resUser.userInfor.groupId;
        const userName = resUser.userInfor.userName;

        // Dropdowns mapping
        const dropdownApis = [
            { url: "/api/DMTuyenDuong/GetAll", id: ["id_TuyenDuong"], text: "Tuyến đường" },
            { url: "/api/DMLyTrinh/GetAll", id: ["id_TuLyTrinh"], text: "Lý trình" },
            { url: "/api/DMHangMucCongViec/GetAll", id: ["id_HangMucCongViec"], text: "Hạng mục công việc" },
            { url: "/api/DMLoaiCauKien/GetAll", id: ["id_LoaiCauKien" ,"id_LoaiKhoiLuong"], text: "Loại cấu kiện" },
            { url: "/api/DMLoaiKhoiLuong/GetAll", id: ["id_LoaiKhoiLuong"], text: "Loại khối lượng" },
            { url: "/api/DMHangMucKhoiLuong/GetAll", id: ["id_HangMucKhoiLuong"], text: "Hạng mục khối lượng" },
            { url: "/api/DMTrangThaiThiCong/GetAll", id: ["id_TrangThaiThiCong"], text: "Trạng thái thi công" },
        ];

        const dropdowns = {};
        for (const item of dropdownApis) {
            let options = `<option value="">-- Chọn ${item.text} --</option>`;
            let resData = [];

            try {
                const res = await $.ajax({
                    url: `${item.url}?groupId=${groupId}`,
                    method: "GET",
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (res.success && Array.isArray(res.data)) {
                    resData = res.data;
                }
            } catch {
                options += '<option>Lỗi tải dữ liệu</option>';
            }

            for (const idKey of item.id) {
                let selectOptions = options;

                resData.forEach(x => {
                    const selected = data && data[idKey] === x.id ? 'selected' : '';
                    selectOptions += `<option value="${x.id}" ${selected}>${x.tenDanhMuc}</option>`;
                });

                dropdowns[idKey] = selectOptions;
            }
        }

        try {
            let selectChiNhanh = '<option value="">-- Chọn công trình --</option>';
            const res = await $.ajax({
                 url: "/api/ChiNhanh/GetByVM?groupId=" +groupId,
                 method: "POST",
                 headers: {
                     "Content-Type": "application/json",
                     "Authorization": "Bearer " + resUser.token
                 },
                 data: JSON.stringify({
                     Id : "",
                     ParentId : "",
                     TenChiNhanh : "",
                     CompanyType : "",
                     Phone : "",
                     Email : "",
                     Address : "",
                     GroupId : "",
                     Ordinarily : 0,
                     CreateAt : null,
                     CreateBy : "",
                     IsActive : 0,
                     ApprovalUserId : "",
                     DateApproval : null,
                     ApprovalDept : "",
                     DepartmentId : "",
                     DepartmentOrder : 0,
                     ApprovalOrder : 0,
                     ApprovalId : "",
                     LastApprovalId : "",
                     IsStatus : ""
                 })
             });

            if (res && res.success && Array.isArray(res.data)) {
                res.data.forEach(x => {
                    const selected = (data && data["id_ChiNhanh"] === x.id) ? 'selected' : '';
                    selectChiNhanh += `<option value="${x.id}" ${selected}>${x.tenChiNhanh || ''}</option>`;
                });
            } else {
                selectChiNhanh += '<option>Lỗi tải dữ liệu</option>';
            }
            dropdowns["id_ChiNhanh"] = selectChiNhanh;
        } catch (err) {
            let selectChiNhanh = '<option>Lỗi tải dữ liệu</option>';
            dropdowns["id_ChiNhanh"] = selectChiNhanh;
        }


        const bodyHtml = `
              <form id="form_caidat">
                <div class="form-row">
                    <div class="w-100 card-custom shadow-sm p-3 my-3">
                        <span class="card-title-custom">Thông tin lý trình</span>
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>Tên công trình<span class="text-danger">*</span></label>
                                <select id="id_ChiNhanh" class="form-control">${dropdowns.id_ChiNhanh}</select>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Tuyến đường<span class="text-danger">*</span></label>
                                <select id="id_TuyenDuong" class="form-control">${dropdowns.id_TuyenDuong}</select>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Từ lý trình<span class="text-danger">*</span></label>
                                <select id="id_TuLyTrinh" class="form-control">${dropdowns.id_TuLyTrinh}</select>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Hạng mục công việc<span class="text-danger">*</span></label>
                                <select id="id_HangMucCongViec" class="form-control">${dropdowns.id_HangMucCongViec}</select>
                            </div>
                        </div>
                    </div>
                    <div class="w-100 card-custom shadow-sm p-3 my-3">
                        <span class="card-title-custom">Thông tin khối lượng van + trụ cứu hỏa</span>
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label>Loại cấu kiện <span class="text-danger">*</span></label>
                                <select id="id_LoaiCauKien" class="form-control">${dropdowns.id_LoaiCauKien}</select>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Loại khối lượng <span class="text-danger">*</span></label>
                                <select id="id_HangMucKhoiLuong" class="form-control">${dropdowns.id_HangMucKhoiLuong}</select>
                            </div>
                            <div class="form-group col-md-4">
                                <label>Loại cấu kiện <span class="text-danger">*</span></label>
                                <select id="id_LoaiKhoiLuong" class="form-control">${dropdowns.id_LoaiKhoiLuong}</select>
                            </div>

                        </div>
                    </div>
                    <div class="w-100 card-custom shadow-sm p-3 my-3">
                        <span class="card-title-custom">Tọa độ</span>
                        <div class="form-row">
                           <div class="form-group col-md-4">
                                <label>X<span class="text-danger">*</span></label>
                                <input type="number" id="x" value="${data?.x || 0}" class="form-control" step="any" />
                            </div>
                            <div class="form-group col-md-4">
                                <label>Y<span class="text-danger">*</span></label>
                                <input type="number" id="y" value="${data?.y || 0}" class="form-control" step="any" />
                            </div>
                            <div class="form-group col-md-4">
                                <label>Trạng thái thi công <span class="text-danger">*</span></label>
                                <select id="id_TrangThaiThiCong" class="form-control">${dropdowns.id_TrangThaiThiCong}</select>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
            <div id="error_msg" class="text-danger font-weight-bold mb-2"></div>
        `;

        const footerHtml = `
                <button type="button" class="btn btn-primary" id="btnLuuCaiDat">${isEdit ? "Cập nhật" : "Lưu"}</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>
            `;

        showGlobalModal(modalTitle, bodyHtml, footerHtml);
        $('#btnLuuCaiDat').data("isedit", isEdit).data("id", data?.id || "");

        $('#btnLuuCaiDat').off('click').on('click', async function () {
            const id = $(this).data("id");
            const isEdit = $(this).data("isedit");


            if (!validateForm())
                return;

            const dataSend = {
                Id: id,
                id_ChiNhanh : $('#id_ChiNhanh').val(),
                id_TuyenDuong: $('#id_TuyenDuong').val(),
                id_TuLyTrinh: $('#id_TuLyTrinh').val(),
               
                id_HangMucCongViec: $('#id_HangMucCongViec').val(),
                id_LoaiCauKien: $('#id_LoaiCauKien').val(),
                id_HangMucKhoiLuong: $('#id_HangMucKhoiLuong').val(),
                id_LoaiKhoiLuong: $('#id_LoaiKhoiLuong').val(),

                x: parseFloat($('#x').val()) || 0,
                y: parseFloat($('#y').val()) || 0,
                id_TrangThaiThiCong: $('#id_TrangThaiThiCong').val(),

                GroupId: groupId,
                Ordinarily: 0,
                CreateAt: new Date().toISOString(),
                CreateBy: userName,
                IsActive: isEdit && data ? data.isActive : 0,
                ApprovalUserId: "",
                DateApproval: null,
                ApprovalDept: "",
                DepartmentId: "",
                DepartmentOrder: 0,
                ApprovalOrder: 0,
                ApprovalId: "",
                LastApprovalId: "",
                IsStatus: ""
            };

            try {
                const res = await $.ajax({
                    url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/Create?isEdit=${isEdit}`,
                    method: "POST",
                    contentType: "application/json",
                    headers: { Authorization: `Bearer ${token}` },
                    data: JSON.stringify(dataSend)
                });
                if (res.success) {
                    showToastSuccess(isEdit ? "Cập nhật thành công!" : "Lưu thành công!");
                    $('#globalModal').modal('hide');
                    loadData();
                } else {
                    $('#error_msg').text(res.message || "Có lỗi xảy ra khi lưu.");
                    showToastError(res.message || "Có lỗi xảy ra khi lưu.");
                }
            } catch (err) {
                $('#error_msg').text("Lỗi hệ thống khi lưu dữ liệu.");
            }
        });
        setTimeout(function () {
            $('#globalModal select').select2({
                width: '100%',
                theme: 'bootstrap4',
                dropdownParent: $('#globalModal')
            });
        }, 100);
    }
    // Validate form
    function validateForm() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();
        let isValid = true;
        let firstInvalid = null;
        const requiredFields = [
            { selector: '#id_ChiNhanh', message: 'Vui lòng chọn tên công trình.' },
            { selector: '#id_TuyenDuong', message: 'Vui lòng nhập tuyến đường.' },
            { selector: '#id_TuLyTrinh', message: 'Vui lòng nhập Từ lý trình.' },
            
            { selector: '#id_HangMucCongViec', message: 'Vui lòng chọn hạng mục công việc.' },
            { selector: '#id_LoaiCauKien', message: 'Vui lòng chọn cấu kiện.' },
            { selector: '#id_HangMucKhoiLuong', message: 'Vui lòng chọn Hạng mục KL.' },
            { selector: '#id_LoaiKhoiLuong', message: 'Vui lòng chọn cấu kiện.' },

            { selector: '#x', message: 'Vui lòng nhập tọa độ x.' },
            { selector: '#y', message: 'Vui lòng nhập tọa độ y.' },
            { selector: '#id_TrangThaiThiCong', message: 'Vui lòng chọn Trạng thái thi công.' },

        ];

        requiredFields.forEach(f => {
            const $input = $(f.selector);
            if (!$(f.selector).val() || !$(f.selector).val().trim()) {
                showError(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
            }
        });

        if (!isValid && firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });

            const $el = $(firstInvalid);
            if ($el.hasClass("select2-hidden-accessible")) {
                $el.next('.select2-container').find('.select2-selection').focus();
            } else {
                $el.focus();
            }
        }
        return isValid;
    }

    // Hiển thị lỗi
    function showError(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }

    async function chiTiet(id) {
        const resUser = await getJwtToken();
        const token = resUser.token;

        // Show modal trước
        showGlobalModal("Lịch sử", `
            <div class="element-block-example" id="history-modal-body" style="min-height:150px;">
                <!-- Loading hoặc dữ liệu sẽ hiển thị ở đây -->
            </div>
        `, `<button class="btn btn-secondary" data-dismiss="modal">Đóng</button>`);
        showBlockLoading("#history-modal-body");
        
        try {
            const res = await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/GetHistory?id=${id}`,
                method: "GET",
                headers: { Authorization: `Bearer ${token}` }
            });

            let content = "";
            if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                content = generateTableHTML(res.data); // Hàm tạo bảng
            } else {
                content = `<div class="text-center text-muted">Không có dữ liệu lịch sử.</div>`;
            }

            $("#history-modal-body").html(content);
        } catch (err) {
            $("#history-modal-body").html(`<div class="text-center text-danger">Lỗi khi tải dữ liệu.</div>`);
        } finally {
            hideBlockLoading("#history-modal-body");
        }
    }
    function generateTableHTML(data) {
        return `
        <div class="table-responsive">
            <table class="table table-bordered table-hover no-wrap-table mb-0">
                 <thead>
                            <tr>
                                <td rowspan="2" class="text-center">#</td>
                                <td colspan="4" class="text-center">Thông tin lý trình</td>
                                <td colspan="3" class="text-center">Thông tin khối lượng van + trụ cứu hỏa</td>
                                <td colspan="3" class="text-center">Tọa độ</td>
                                <td rowspan="2" class="text-center">Trạng thái</td>
                                <td rowspan="2" class="text-center">Người thao tác</td>
                                <td rowspan="2" class="text-center">Thời gian</td>
                            </tr>
                            <tr>
                                <th> Tên công trình</th>
                                <th> Tuyến đường</th>
                                <th> Từ lý trình</th>
                                <th> Hạng mục công việc</th>
                                <th> Loại cấu kiện</th>
                                <th> Hạng mục KL</th>
                                <th> Loại cấu kiện</th>
                                <th> X</th>
                                <th> Y</th>
                                <th> Trạng thái thi công</th>
                            </tr>
                </thead>
                <tbody>
                    ${data.map((x, i) => `
                        <tr>
                            <td class="text-center">${i + 1}</td>
                            <td>${x.tenChiNhanh|| ""}</td>
                            <td>${x.tuyenDuong|| ""}</td>
                            <td>${x.tuLyTrinh|| ""}</td>
                            <td>${x.hangMucCongViec|| ""}</td>
                            <td>${x.loaiCauKien|| ""}</td>
                            <td>${x.hangMucKhoiLuong|| ""}</td>
                            <td>${x.loaiKhoiLuong|| ""}</td>
                            <td>${x.x|| ""}</td>
                            <td>${x.y|| ""}</td>
                            <td>${x.trangThaiThiCong|| ""}</td>

                            <td>${x.isStatus|| ""}</td>
                            <td>${x.createBy || ""}</td>
                            <td>${x.createAt ? new Date(x.createAt).toLocaleString() : ""}</td>
                        </tr>
                    `).join("")}
                </tbody>
            </table>
        </div>`;
    }
    // Duyệt
    async function duyet(id) {
        if (!confirm('Bạn có chắc chắn muốn duyệt?')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/Duyet?id=${id}`,
                method: "POST",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Duyệt thành công!");
                loadData();
            } else {
                showToastError(res.message || "Duyệt thất bại!");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi duyệt!");
        }
    }

    // Hủy duyệt
    async function huyDuyet(id) {
        if (!confirm('Bạn có chắc chắn muốn hủy duyệt?')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/HuyDuyet?id=${id}`,
                method: "POST",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Hủy duyệt thành công!");
                loadData();
            } else {
                showToastError(res.message || "Hủy duyệt thất bại!");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi hủy duyệt!");
        }
    }

    // Chỉnh sửa
    async function editCaiDat(id) {
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/GetById?id=${id}`,
                method: "GET",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success && res.data) {
                showModalTaoMoi(true, res.data);
            } else {
                showToastError(res.message || "Không lấy được dữ liệu để chỉnh sửa!");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi lấy dữ liệu chỉnh sửa!");
        }
    }

    // Xóa
    async function deleteCaiDat(id) {
        if (!confirm('Bạn có chắc chắn muốn xóa này?')) return;
        const resUser = await getJwtToken();
        const token = resUser.token;
        try {
            const res = await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/${id}`,
                method: "DELETE",
                headers: { Authorization: `Bearer ${token}` }
            });
            if (res.success) {
                showToastSuccess("Xóa thành công!");
                loadData();
            } else {
                showToastError(res.message || "Xóa thất bại!");
            }
        } catch (err) {
            showToastError("Lỗi hệ thống khi xóa!");
        }
    }

    function showHuongDanNghiepVu() {
        const headerHtml =
            `<div><div class="card-header">
                     <i class="header-icon lnr-license icon-gradient bg-plum-plate"></i>
                     <form id="SearchInfo">
                         <select id="ChiNhanhInfo" class="form-control">
                             <option value="">-- Chọn  --</option>
                         </select>
                     </form>
                     <div class="btn-actions-pane-right">
                         <div role="group" class="btn-group-sm nav btn-group">
                             <a data-toggle="tab" href="#tab-hdsd" class="btn-shadow active btn btn-primary">Hướng dẫn sử dụng</a>
                             <a data-toggle="tab" href="#tab-ttd" class="btn-shadow  btn btn-primary">Thứ tự duyệt</a>
                         </div>
                     </div>
                 </div>`;

        const tabsHtml = `
                 <div class="card-body">
                     <div class="tab-content">
                         <div class="tab-pane tabs-animation fade active show" id="tab-hdsd" role="tabpanel">
                             <div class="p-3">Nội dung hướng dẫn sử dụng...</div>
                         </div>
                         <div class="tab-pane tabs-animation fade" id="tab-ttd" role="tabpanel">
                             <div class="row">
                                 <div class="col-md-12">
                                     <div>
                                         <div class="mb-3">
                                             <div role="group" class="btn-group-sm nav btn-group">
                                                 <a data-toggle="tab" href="#tab-them" class="btn-pill pl-3 btn btn-warning active show">Thêm</a>
                                                 <a data-toggle="tab" href="#tab-sua" class="btn btn-warning show">Sửa</a>
                                                 <a data-toggle="tab" href="#tab-xoa" class="btn-pill pr-3 btn btn-warning show">Xóa</a>
                                             </div>
                                         </div>
                                         <div class="tab-content">
                                             <div class="tab-pane show active" id="tab-them" role="tabpanel">
                                                 <div class="row">
                                                     <div class="col-md-4">
                                                         <ul class="list-group" id="ul-them"></ul>
                                                     </div>
                                                     <div class="col-md-8">
                                                         <div class="card-body" id="content-them">Chọn phòng ban để xem chi tiết</div>
                                                     </div>
                                                 </div>
                                             </div>
                                             <div class="tab-pane show" id="tab-sua" role="tabpanel">
                                                 <div class="row">
                                                     <div class="col-md-4">
                                                         <ul class="list-group" id="ul-sua"></ul>
                                                     </div>
                                                     <div class="col-md-8">
                                                         <div class="card-body" id="content-sua">Chọn phòng ban để xem chi tiết</div>
                                                     </div>
                                                 </div>
                                             </div>
                                             <div class="tab-pane show" id="tab-xoa" role="tabpanel">
                                                 <div class="row">
                                                     <div class="col-md-4">
                                                         <ul class="list-group" id="ul-xoa"></ul>
                                                     </div>
                                                     <div class="col-md-8">
                                                         <div class="card-body" id="content-xoa">Chọn phòng ban để xem chi tiết</div>
                                                     </div>
                                                 </div>
                                             </div>
                                         </div>
                                     </div>
                                 </div>
                             </div>
                         </div>
                     </div>
                 </div>
             `;

        const bodyHtml = headerHtml + tabsHtml;
        const footerHtml = `<button type="button" class="btn btn-secondary" data-dismiss="modal">Đóng</button>`;

        showGlobalModal("Thông tin nghiệp vụ", bodyHtml, footerHtml);

        // Lấy groupId và token, sau đó gọi API lấy danh sách
        getJwtToken().then(function (resUser) {
            const groupId = resUser.userInfor.groupId;
            $.ajax({
                url: `/api/caidatsoluotduyet/GetChiNhanhsForCompanyId?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Authorization": "Bearer " + resUser.token
                }
            }).done(function (res) {
                const $ddl = $('#ChiNhanhInfo');
                $ddl.empty().append('<option value="">-- Chọn  --</option>');
                if (res.success && Array.isArray(res.data)) {
                    res.data.forEach(function (item) {
                        $ddl.append(`<option value="${item.id}">${item.tenChiNhanh}</option>`);
                    });
                }
            }).fail(function (err) {
                $('#ChiNhanhInfo').empty().append('<option value="">Lỗi tải </option>');
            });

            // Sau khi gọi API ListDept thành công
            $.ajax({
                url: `/api/caidatphongbanduyet/ListDept?groupId=${groupId}`,
                method: "GET",
                headers: {
                    "Authorization": "Bearer " + resUser.token
                }
            }).done(function (res) {
                let htmlUl = "";
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    var stt = 1;
                    res.data.forEach(function (item, idx) {
                        htmlUl += `<li class="list-group-item" data-idx="${idx}" style="cursor:pointer;">
                                 <b>${stt + "." + item.deptName}</b><br/>
                                 <span>Trạng thái: ${item.isActive ? "Hoạt động" : "Ngừng"}</span>
                             </li>`;
                        stt++;
                    });
                } else {
                    htmlUl = `<li class="list-group-item text-muted">Không có dữ liệu phòng ban.</li>`;
                }
                // Render cho cả 3 tab
                $('#ul-them').html(htmlUl);
                $('#ul-sua').html(htmlUl);
                $('#ul-xoa').html(htmlUl);

                function bindDeptClick(tab, data, groupId) {
                    // Map tab to permissionId
                    const permissionMap = {
                        'them': 'cf46bba6-7059-40f2-8a14-7167d548a50a',
                        'sua': '7e09c638-bdca-43f4-8247-86ed31a3d549',
                        'xoa': '6ab335ac-35b9-48a4-91b1-534fd9f65f01'
                    };
                    const permissionId = permissionMap[tab];

                    $(`#ul-${tab}`).off('click').on('click', 'li', function () {
                        const idx = $(this).data('idx');
                        const dept = data[idx];
                        let content = '';

                        if (dept) {
                            // Call API with correct permissionId
                            $.ajax({
                                url: `/api/caidatsoluotduyet/ListStepSetting?groupId=${groupId}&majorId=afb44175-baca-4a19-bf42-9694134221db&departmentId=${dept.id || 0}&permissionId=${permissionId}`,
                                method: "GET",
                                headers: {
                                    "Authorization": "Bearer " + resUser.token
                                }
                            }).done(function (res) {
                                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                                    let stepsHtml = `<h5>${dept.deptName}</h5>`;
                                    stepsHtml += `<ul class="list-group mb-2">`;
                                    res.data.forEach((step, i) => {
                                        stepsHtml += `<li class="list-group-item">
                                                 <b>Bước ${i + 1}:</b> ${step.content || 0}
                                                 <span class="badge badge-info ml-2">${step.isStatus || 0}</span>
                                             </li>`;
                                    });
                                    stepsHtml += `</ul>`;
                                    content = stepsHtml;
                                } else {
                                    content = `<div class="text-muted">Không có dữ liệu bước duyệt.</div>`;
                                }
                                $(`#content-${tab}`).html(content);
                            }).fail(function (err) {
                                $(`#content-${tab}`).html('<div class="text-danger">Lỗi khi tải dữ liệu bước duyệt.</div>');
                            });
                        } else {
                            $(`#content-${tab}`).html("Không có dữ liệu chi tiết.");
                        }
                        $(`#ul-${tab} li`).removeClass('active');
                        $(this).addClass('active');
                    });
                }
                bindDeptClick('them', res.data, groupId);
                bindDeptClick('sua', res.data, groupId);
                bindDeptClick('xoa', res.data, groupId);
            }).fail(function (err) {
                $('#ul-them, #ul-sua, #ul-xoa').html('<li class="list-group-item text-danger">Lỗi khi tải dữ liệu phòng ban.</li>');
                $('#content-them, #content-sua, #content-xoa').html('');
            });
        });

        // Khởi tạo select2 nếu cần
        if (window.$ && $.fn.select2) {
            $('#ChiNhanhInfo').select2();
        }
        $('#ChiNhanhInfo').off('change').on('change', function () {
            if (typeof onSelectChange === 'function') {
                onSelectChange($(this).val());
            }
        });

    }

    
</script>

