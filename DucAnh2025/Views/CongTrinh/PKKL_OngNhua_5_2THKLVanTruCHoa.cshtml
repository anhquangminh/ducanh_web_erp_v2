<div class="tab-content">
    <div class="card mt-3 w-100 d-flex">
        <div class="card-header">
            <h3 class="m-0 mr-2">BẢNG TỔNG HỢP KHỐI LƯỢNG VAN + TRỤ CỨU HỎA HỆ THỐNG CẤP NƯỚC SẠCH </h3>
        </div>
        <div class="card-body">
            <div role="group" class="mb-2 btn-group-sm btn-group btn-group-toggle" data-toggle="buttons">
                <button type="button" class="btn btn-outline-focus" onclick="copyTable('table_data')">Copy</button>
                <button type="button" class="btn btn-outline-focus" onclick="exportExcel()">Excel</button>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="table_data">
                    <thead>
                        <tr>
                            <th colspan="8">Thông tin hạng mục công việc</th>
                            <th colspan="1" id="col-dynamic">Khối lượng theo tuyến đường</th>
                        </tr>
                        <tr>
                            <th>STT</th>
                            <th>Tên công trình</th>
                            <th>Hạng mục công việc</th>
                            <th>Hạng mục KL</th>
                            <th>Loại cấu kiện</th>
                            <th>Loại khối lượng</th>
                            <th>Tên công tác thực tế</th>
                            <th>Đơn vị</th>
                            <th>Tổng khối lượng </th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>STT</th>
                            <th>Tên công trình</th>
                            <th>Hạng mục công việc</th>
                            <th>Hạng mục KL</th>
                            <th>Loại cấu kiện</th>
                            <th>Loại khối lượng</th>
                            <th>Tên công tác thực tế</th>
                            <th>Đơn vị</th>
                            <th>Tổng khối lượng </th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    async function exportExcel(){
        await exportExcelCustom("table_data", [
            { text: "CÔNG TY CỔ PHẦN XÂY DỰNG ĐỨC ANH", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "KHU CÔNG NGHIỆP CẨM KHÊ", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "", cols: 10 },
            { text: "BẢNG TỔNG HỢP KHỐI LƯỢNG ĐÀO ĐẤT, ĐẮP ĐẤT, ĐẮP CÁT, VẬN CHUYỂN ĐẤT HỆ THỐNG CẤP NƯỚC SẠCH", align: "center", fontSize: 12, bold: true },
            { text: "Mẫu số 02", align: "center", fontSize: 12, bold: true },
            { text: "In tổng thể (Nếu số lượng cột đủ để in được A3 thì in tổng thể; Nếu số lượng cột không đủ để in A3 thì căn chỉnh để in thành nhiều trang A3)", align: "center", fontSize: 11 }
        ], "5.1 THKL đào, đắp", "5.1 THKL đào, đắp.xlsx");
    }

    $(function () {
        loadDMTenCongTac().then(loadData);
    });
    function addDynamicColumns(uniqueTuyenDuong) {
        const $theadRow = $('#table_data thead tr').last(); // lấy row cuối trong thead
        const $tfootRow = $('#table_data tfoot tr').last();

        // Xoá cột động cũ
        $theadRow.find('th.dynamic-col').remove();
        $tfootRow.find('th.dynamic-col').remove();

        // Thêm cột động mới
        uniqueTuyenDuong.forEach(td => {
            $theadRow.append(`<th class="dynamic-col">${td}</th>`);
            $tfootRow.append(`<th class="dynamic-col">${td}</th>`);
        });
        $('#col-dynamic').attr('colspan', uniqueTuyenDuong.length + 1);
    }
    function loadData() {
        showBlockLoading('.table-responsive');
        getJwtToken().then(async function (resUser) {
            await $.ajax({
                url: `/api/PKKLOngNhua3TTinLDatVanTruCHoa/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },

            }).done(function (res) {

                let dataSet = [];
                let mappedData = [];
                let uniqueTuyenDuong = [];

                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    // lấy unique tuyenDuong
                    uniqueTuyenDuong = [...new Set(res.data.map(item => item.tuyenDuong).filter(Boolean))];

                    // cập nhật header/footer
                    addDynamicColumns(uniqueTuyenDuong);

                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        id_ChiNhanh: item.id_ChiNhanh || '',
                        tenChiNhanh: item.tenChiNhanh || '',
                        id_TuyenDuong: item.id_TuyenDuong || '',
                        tuyenDuong: item.tuyenDuong || '',

                        id_HangMucCongViec: item.id_HangMucCongViec || '',
                        hangMucCongViec: item.hangMucCongViec || '',
                        id_LoaiCauKien: item.id_LoaiCauKien || '',
                        loaiCauKien: item.loaiCauKien || '',
                        id_HangMucKhoiLuong: item.id_HangMucKhoiLuong || '',
                        hangMucKhoiLuong: item.hangMucKhoiLuong || '',
                        id_LoaiKhoiLuong: item.id_LoaiKhoiLuong || '',
                        loaiKhoiLuong: item.loaiKhoiLuong || '',

                        tongTrongLuong: '0',
                    }));
                }
                mappedData = dataSet;
                // lọc duy nhất theo 2 trường
                let seen = new Set();
                dataSet = mappedData.filter(row => {
                    let key = [
                        row.id_ChiNhanh,
                        row.id_HangMucCongViec,
                        row.id_LoaiCauKien,
                        row.id_HangMucKhoiLuong,
                        row.id_LoaiKhoiLuong,
                    ].join('|');
                    if (seen.has(key)) return false;
                    seen.add(key);
                    return true;
                });

                // Gom nhóm và đếm (COUNTIFS logic)
                const sumLookup = {};
                mappedData.forEach(item => {
                    const key = [
                        item.id_ChiNhanh,         
                        item.id_LoaiCauKien,      
                        item.id_HangMucKhoiLuong, 
                        item.id_LoaiKhoiLuong,    
                        item.tuyenDuong           
                    ].join('|');
                    sumLookup[key] = (sumLookup[key] || 0) + 1;
                });

                const tenCongTacLookup = {};
                danhMucCongTacs.forEach(item => {
                    const key = [
                        item.id_HangMucCongViec,
                        item.id_LoaiCauKien,
                        item.id_HangMucKhoiLuong,
                        item.id_LoaiKhoiLuong
                    ].join('|');
                    tenCongTacLookup[key] = item;
                });

                dataSet.forEach(row => {
                    let tong = 0;
                    uniqueTuyenDuong.forEach(td => {
                        const key = [
                            row.id_ChiNhanh,         
                            row.id_LoaiCauKien,      
                            row.id_HangMucKhoiLuong, 
                            row.id_LoaiKhoiLuong,    
                            td                      
                        ].join('|');

                        let count = sumLookup[key] || 0;
                        row[td] = count > 0 ? count : "0";
                        tong += count;
                    });
                    row.tongTrongLuong = tong > 0 ? tong : "0";

                    // Tên công tác
                    const keyCongTac = [
                        row.id_HangMucCongViec,
                        row.id_LoaiCauKien,
                        row.id_HangMucKhoiLuong,
                        row.id_LoaiKhoiLuong
                    ].join('|');
                    if (tenCongTacLookup[keyCongTac]) {
                        row.tenCongtac = tenCongTacLookup[keyCongTac].tenCongTac || "";
                        row.donVi = tenCongTacLookup[keyCongTac].donVi || "";
                    }else{
                        row.tenCongtac ="";
                        row.donVi ="";
                    }
                });


                const $table = $('#table_data');
                // Config cột cố định
                let columns = [
                    { data: 'stt', className: 'text-center align-middle', width: '1%' },
                    { data: 'tenChiNhanh', className: 'align-middle' },
                    { data: 'hangMucCongViec', className: 'align-middle' },
                    { data: 'hangMucKhoiLuong', className: 'align-middle' },
                    { data: 'loaiCauKien', className: 'align-middle' },
                    { data: 'loaiKhoiLuong', className: 'align-middle' },
                    { data: 'tenCongtac', className: 'align-middle' },
                    { data: 'donVi', className: 'align-middle' },
                    { data: 'tongTrongLuong', className: 'align-middle' },
                ];

                // Thêm các cột động
                uniqueTuyenDuong.forEach(td => {
                    columns.push({
                        data: td,
                        className: 'align-middle',
                        defaultContent: ''
                    });
                });

                if ($.fn.DataTable.isDataTable($table)) {
                    $table.DataTable().clear().rows.add(dataSet).draw();
                } else {
                    $table.DataTable({
                        data: dataSet,
                        columns: columns,
                        autoWidth: false,
                        ordering: true,
                        searching: true,
                        paging: true,
                        pageLength: 10,
                        info: true,
                        language: {
                            lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                            zeroRecords: "Không tìm thấy dữ liệu",
                            info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                            infoEmpty: "Không có bản ghi nào",
                            infoFiltered: "(lọc từ _MAX_ bản ghi)",
                            search: "Tìm kiếm:",
                            paginate: {
                                first: "Đầu",
                                last: "Cuối",
                                next: "Sau",
                                previous: "Trước"
                            }
                        },
                        initComplete: function () {
                            this.api().columns().every(function (colIdx) {
                                var column = this;
                                var $footer = $(column.footer()).empty();
                                if (colIdx === 0) {
                                    $footer.append('<p></p>');
                                } else {
                                    var select = $('<select><option value=""></option></select>')
                                        .appendTo($footer)
                                        .on('change', function () {
                                            var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                            column
                                                .search(val ? '^' + val + '$' : '', true, false)
                                                .draw();
                                        });

                                    column.data().unique().sort().each(function (d) {
                                        select.append('<option value="' + d + '">' + d + '</option>');
                                    });
                                }

                            });
                        }
                    });
                }
            }).fail(function (xhr) {
                var colCount = $('#table_danhmuc thead th').length;
                $('#table_danhmuc tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');

            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }
    let danhMucCongTacs = [];
    function loadDMTenCongTac() {
        return getJwtToken().then(function (resUser) {
            return $.ajax({
                url: `/api/DMTenCongTac/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
                data: JSON.stringify({
                    Id: "",
                    Id_HangMucCongViec: "",
                    Id_HangMucKhoiLuong: "",
                    Id_LoaiKhoiLuong: "",
                    TenCongTac: "",
                    DonVi: "",

                    GroupId: "",
                    Ordinarily: 0,
                    CreateAt: null,
                    CreateBy: "",
                    IsActive: 0,
                    ApprovalUserId: "",
                    DateApproval: null,
                    ApprovalDept: "",
                    DepartmentId: "",
                    DepartmentOrder: 0,
                    ApprovalOrder: 0,
                    ApprovalId: "",
                    LastApprovalId: "",
                    IsStatus: ""
                })
            }).done(function (res) {
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    danhMucCongTacs = res.data;
                } else {
                    danhMucCongTacs = [];
                }
            }).fail(function (xhr) {
                danhMucCongTacs = [];
            });
        });
    }
</script>



