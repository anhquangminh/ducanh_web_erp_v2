    $(function () {
        loadDMTenCongTac().then(loadData);
    });

    function addDynamicColumns(uniqueTuyenDuong) {
        const $theadRow = $('#table_data thead tr').last(); // lấy row cuối trong thead
        const $tfootRow = $('#table_data tfoot tr').last();

        // Xoá cột động cũ
        $theadRow.find('th.dynamic-col').remove();
        $tfootRow.find('th.dynamic-col').remove();

        // Thêm cột động mới
        uniqueTuyenDuong.forEach(td => {
            $theadRow.append(`<th class="dynamic-col">${td}</th>`);
            $tfootRow.append(`<th class="dynamic-col">${td}</th>`);
        });
        $('#col-dynamic').attr('colspan', uniqueTuyenDuong.length + 1);
    }

    let danhMucCongTacs = [];

    function loadDMTenCongTac() {
        return getJwtToken().then(function (resUser) {
            return $.ajax({
                url: `/api/DMTenCongTac/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
                data: JSON.stringify({
                    Id: "",
                    Id_HangMucCongViec: "",
                    Id_HangMucKhoiLuong: "",
                    Id_LoaiKhoiLuong: "",
                    TenCongTac: "",
                    DonVi: "",

                    GroupId: "",
                    Ordinarily: 0,
                    CreateAt: null,
                    CreateBy: "",
                    IsActive: 0,
                    ApprovalUserId: "",
                    DateApproval: null,
                    ApprovalDept: "",
                    DepartmentId: "",
                    DepartmentOrder: 0,
                    ApprovalOrder: 0,
                    ApprovalId: "",
                    LastApprovalId: "",
                    IsStatus: ""
                })
            }).done(function (res) {
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    danhMucCongTacs = res.data;
                } else {
                    danhMucCongTacs = [];
                }
            }).fail(function (xhr) {
                danhMucCongTacs = [];
            });
        });
    }

    async function loadData() {
        // Call both APIs in parallel
        const [data4_7c, data4_9c] = await Promise.all([
            loadData4_7c(),
            loadData4_9c()
        ]);

        // Lấy uniqueTuyenDuong từ cả hai nguồn
        const uniqueTuyenDuong = [
            ...new Set([
                ...(Array.isArray(data4_7c) ? data4_7c.map(x => x.tuyenDuong).filter(Boolean) : []),
                ...(Array.isArray(data4_9c) ? data4_9c.map(x => x.tuyenDuong).filter(Boolean) : [])
            ])
        ];
        addDynamicColumns(uniqueTuyenDuong);

        let seen = new Set();
        let uniqueRows = [...data4_7c, ...data4_9c].filter(row => {
                        let key = [
                            row.id_ChiNhanh,
                            row.id_LoaiKhoiLuong,
                            row.donVi,
                        ].join('|');
                        if (seen.has(key)) return false;
                        seen.add(key);
                        return true;
                    });
        // Tạo lookup để tra cứu nhanh từ danhMucCongTacs
                    const tenCongTacLookup = {};
                    danhMucCongTacs.forEach(item => {
                        const key = [
                            item.id_HangMucCongViec,
                            item.id_HangMucKhoiLuong,
                            item.id_LoaiKhoiLuong
                        ].join('|');
                        tenCongTacLookup[key] = item;
                    });
        //(id_LoaiKhoiLuong, donVi)
        uniqueRows.forEach((row,idx) => {
            row.stt = idx + 1;
            uniqueTuyenDuong.forEach(td => {
                // Sum from data4_7c
                let sum47 = Array.isArray(data4_7c)
                    ? data4_7c
                        .filter(x => x.id_LoaiKhoiLuong === row.id_LoaiKhoiLuong && x.tuyenDuong === td)
                        .reduce((acc, x) => acc + (parseFloat(x.tongKhoiLuong) || 0), 0)
                    : 0;
                // Sum from data4_9c
                let sum49 = Array.isArray(data4_9c)
                    ? data4_9c
                        .filter(x => x.id_LoaiKhoiLuong === row.id_LoaiKhoiLuong && x.tuyenDuong === td)
                        .reduce((acc, x) => acc + (parseFloat(x.tongKhoiLuong) || 0), 0)
                    : 0;

                let total = sum47 + sum49;
                row[td] = total > 0 ? Math.round(total * 100) / 100 : "0";
               
            });
            // Optionally, calculate total across all tuyenDuong
            row.tongKhoiLuong = uniqueTuyenDuong.reduce((acc, td) => acc + (parseFloat(row[td]) || 0), 0);
            row.tongKhoiLuong = row.tongKhoiLuong > 0 ? Math.round(row.tongKhoiLuong * 100) / 100 : "";

            const keyCongTac = [
                            row.id_HangMucCongViec,
                            row.id_HangMucKhoiLuong,
                            row.id_LoaiKhoiLuong
                        ].join('|');
            if (tenCongTacLookup[keyCongTac]) {
                 row.tenCongtac = tenCongTacLookup[keyCongTac].tenCongTac || "";
                 row.donVi = tenCongTacLookup[keyCongTac].donVi || "";
            }else{
                row.tenCongtac="";
                row.donVi="";
            }
        });
        

        const $table = $('#table_data');

        // Config cột cố định
        let columns = [
            { data: 'stt', className: 'text-center align-middle', width: '1%' },
            { data: 'tenChiNhanh', className: 'align-middle' },
            { data: 'loaiKhoiLuong', className: 'align-middle' },
            { data: 'donVi', className: 'align-middle' },
            { data: 'tongKhoiLuong', className: 'align-middle' }
        ];

        uniqueTuyenDuong.forEach(td => {
            columns.push({
                data: td,
                className: 'align-middle',
                defaultContent: ''
            });
        });

        if ($.fn.DataTable.isDataTable($table)) {
            $table.DataTable().clear().rows.add(uniqueRows).draw();
        } else {
            $table.DataTable({
                data: uniqueRows,
                columns: columns,
                autoWidth: false,
                ordering: true,
                searching: true,
                paging: true,
                pageLength: 10,
                info: true,
                language: {
                    lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                    zeroRecords: "Không tìm thấy dữ liệu",
                    info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                    infoEmpty: "Không có bản ghi nào",
                    infoFiltered: "(lọc từ _MAX_ bản ghi)",
                    search: "Tìm kiếm:",
                    paginate: {
                        first: "Đầu",
                        last: "Cuối",
                        next: "Sau",
                        previous: "Trước"
                    }
                },
                initComplete: function () {
                    this.api().columns().every(function (colIdx) {
                        var column = this;
                        var $footer = $(column.footer()).empty();
                        if (colIdx === 0) {
                            $footer.append('<p></p>');
                        } else {
                            var select = $('<select><option value=""></option></select>')
                                .appendTo($footer)
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });

                            column.data().unique().sort().each(function (d) {
                                select.append('<option value="' + d + '">' + d + '</option>');
                            });
                        }

                    });
                }
            });
        }
    }


