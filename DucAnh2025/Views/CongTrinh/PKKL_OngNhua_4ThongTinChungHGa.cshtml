    function klCChoDapTraDapCat(id_HinhThucDapTra, cDoDayDapCat, cDoDinhDapCat, dayDao, dinhLotMong, dayHgDongChay, dinhHg, cDayLMongHg, cDayMongHg, cCaoTuong, cDayMMoThotDuoi, cDayMMoThotTrenHoacTamDan, klLotMongDapTraDapCat, klMongDapTraDapCat, klTuongBaoGomTuongVaMuMoDapTraDapCat) {
        const validValues = ["Đắp đất + đăp cát", "Đắp cát + đắp đất", "Đắp cát"];

        if (!validValues.includes(id_HinhThucDapTra)) return 0;

        let part1 = 0;
        let part2 = 0;
        let part3 = 0;

        // Phần 1
        if (cDoDayDapCat < dinhLotMong) {
            const minU_J = cDoDinhDapCat > dinhLotMong ? dinhLotMong : cDoDinhDapCat;
            const maxT_G = cDoDayDapCat > dayDao ? cDoDayDapCat : dayDao;
            if (cDayLMongHg !== 0) {
               part1 = ((minU_J - maxT_G) / cDayLMongHg) * klLotMongDapTraDapCat;
            } else {
              part1 = 0;
           }
        }

        // Phần 2
        if (
            (cDoDinhDapCat > dinhLotMong && cDoDayDapCat <= dinhLotMong) ||
            (cDoDinhDapCat >= dayHgDongChay && cDoDayDapCat < dayHgDongChay) ||
            (cDoDinhDapCat <= dayHgDongChay && cDoDayDapCat >= dinhLotMong)
        ) {
            const minU_L = Math.min(cDoDinhDapCat, dayHgDongChay);
            const maxT_J = Math.max(cDoDayDapCat, dinhLotMong);
            if (cDayMongHg !== 0) {
                part2 = ((minU_L - maxT_J) / cDayMongHg) * klMongDapTraDapCat;
            } else {
                part2 = 0; 
            }
        }

        // Phần 3
        if (cDoDinhDapCat > dayHgDongChay) {
            const minU_R = Math.min(cDoDinhDapCat, dinhHg);
            const maxT_L = Math.max(cDoDayDapCat, dayHgDongChay);
            const denominator = cCaoTuong + cDayMMoThotDuoi + cDayMMoThotTrenHoacTamDan;
            if (denominator !== 0) {
                part3 = ((minU_R - maxT_L) / denominator) * klTuongBaoGomTuongVaMuMoDapTraDapCat;
            } else {
                part3 = 0;
            }
        }

        const result = part1 + part2 + part3;
        return Math.round(result * 100) / 100;
    }

