    // Hàm tổng quát để gọi các phép tính và set lại giá trị
    function autoCalculate() {
        try {
            Object.keys(calcMap).forEach(function (resultId) {
                const { func, inputs } = calcMap[resultId];
                const args = inputs.map(id => {
                    const $el = $('#' + id);

                    if ($el.is('select')) {
                        return $el.find(':selected').text();
                    }

                    const inputType = $el.attr('type');
                    const val = $el.val();

                    if (inputType === "text") {
                        return (val === null || typeof val === "undefined") ? "" : val;
                    }

                    if (val === "" || val === null || typeof val === "undefined") return 0;
                    const num = parseFloat(val);
                    return isNaN(num) ? 0 : num;
                });

                let result = func.apply(null, args);

                if (typeof result === "number" && isNaN(result)) result = "";
                $('#' + resultId).val(result);
            });
        } catch (err) {
            console.error('Lỗi tổng thể trong autoCalculate:', err);
        }
    }

    function debounce(fn, delay) {
        let timer = null;
        return function (...args) {
            clearTimeout(timer);
            timer = setTimeout(() => fn.apply(this, args), delay);
        };
    }

    //tính toán
    function dinhLotMong(cDayLMongHg, cDayMongHg, dayHgDongChay) {
        return cDayLMongHg > 0 ? Math.round((dayHgDongChay - cDayMongHg) * 100) / 100 : 0;
    }
    function dayDao(cDayLMongHg, cDayMongHg, dayHgDongChay, dinhLotMong) {
        return dinhLotMong > 0
            ? Math.round((dinhLotMong - cDayLMongHg) * 100) / 100
            : Math.round((dayHgDongChay - cDayMongHg) * 100) / 100;
    }
    function chieuSauDao(hTrangTruocKhiDao, dayDao) {
        return Math.round((hTrangTruocKhiDao - dayDao) * 100) / 100;
    }
    function mMoThotDuoi(cDayMMoThotTrenHoacTamDan, cDayMMoThotDuoi, dinhHg) {
        return (cDayMMoThotTrenHoacTamDan > 0 && cDayMMoThotDuoi > 0) ? (dinhHg - cDayMMoThotTrenHoacTamDan) : 0;
    }
    function dinhTuong(mMoThotDuoi, cDayMMoThotDuoi, cDayMMoThotTrenHoacTamDan, dinhHg) {
        if (mMoThotDuoi > 0) {
            return mMoThotDuoi - cDayMMoThotDuoi;
        } else if (cDayMMoThotTrenHoacTamDan > 0) {
            return dinhHg - cDayMMoThotTrenHoacTamDan;
        } else if (cDayMMoThotDuoi === 0 && cDayMMoThotTrenHoacTamDan === 0) {
            return dinhHg;
        } else {
            return 0;
        }
    }
    function cCaoTuong(dinhTuong, dayHgDongChay) {
        return Math.round((dinhTuong - dayHgDongChay) * 100) / 100;
    }
