    function klTuongBaoGomTuongVaMuMoDapTraDapCat(klDapCatDapTraDapCat, daiKTHH, rongKTHH, cCaoTuong, cDayMMoThotDuoi, cDayMMoThotTrenHoacTamDan) {
        return klDapCatDapTraDapCat === 0
            ? 0
            : Math.round((daiKTHH * rongKTHH * cCaoTuong) + (daiKTHH * rongKTHH * cDayMMoThotDuoi) + (daiKTHH * rongKTHH * cDayMMoThotTrenHoacTamDan) * 100) / 100;
