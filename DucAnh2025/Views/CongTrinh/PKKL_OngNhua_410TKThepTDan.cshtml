<div class="tab-content">
    <div class="card mt-3 w-100 d-flex">
        <div class="card-header">
            <h3 class="m-0 mr-2">BẢNG THỐNG KÊ THÉP TẤM ĐAN HỐ VAN NƯỚC SẠCH </h3>
            <span style="cursor:pointer;" onclick="showHuongDanNghiepVu()" title="Hướng dẫn sử dụng">
                <i class="bi bi-question-circle-fill text-info" style="font-size: 1.5em;"></i>
            </span>
        </div>
        <div class="card-body">
            <div>
                <button data-permission="Tao" class="mb-2 mr-2 btn-icon btn btn-primary" onclick="showModalTaoMoi()">
                    <i class="fas fa-plus btn-icon-wrapper"></i>Tạo mới
                </button>
            </div>
            <div role="group" class="mb-2 btn-group-sm btn-group btn-group-toggle" data-toggle="buttons">
                <button type="button" class="btn btn-outline-focus" onclick="copyTable('table_data')">Copy</button>
                <button type="button" class="btn btn-outline-focus" onclick="exportExcel()">Excel</button>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="table_data">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th></th>
                            <th>Trạng thái</th>
                            <th>Chi nhánh</th>
                            <th>Loại cấu kiện</th>
                            <th>Tên công tác theo vị trí lấy KL</th>
                            <th>Tên công tác theo Đ.Kính</th>
                            <th>Vị trí lấy khối lượng</th>
                            <th>Loại thép</th>
                            <th>Tên thanh thép theo C.Kiện</th>
                            <th>Tên thanh thép theo C.Dài</th>
                            <th>Số hiệu thép</th>
                            <th>ĐK/C.Dầy(mm,mm2)</th>
                            <th>Số thanh/ CK </th>
                            <th>Số CK</th>
                            <th>Tổng số thanh</th>
                            <th>C.Dài 01 thanh (mm)/DT (mm2)</th>
                            <th>Tổng C.Dài (m,m2) </th>
                            <th>T.Lượng/kg </th>
                            <th>Tổng T.lượng (kg) </th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                    <tfoot>
                        <tr>
                            <th>#</th>
                            <th></th>
                            <th>Trạng thái</th>
                            <th>Chi nhánh</th>
                            <th>Loại cấu kiện</th>
                            <th>Tên công tác theo vị trí lấy KL</th>
                            <th>Tên công tác theo Đ.Kính</th>
                            <th>Vị trí lấy khối lượng</th>
                            <th>Loại thép</th>
                            <th>Tên thanh thép theo C.Kiện</th>
                            <th>Tên thanh thép theo C.Dài</th>
                            <th>Số hiệu thép</th>
                            <th>ĐK/C.Dầy(mm,mm2)</th>
                            <th>Số thanh/ CK </th>
                            <th>Số CK</th>
                            <th>Tổng số thanh</th>
                            <th>C.Dài 01 thanh (mm)/DT (mm2)</th>
                            <th>Tổng C.Dài (m,m2) </th>
                            <th>T.Lượng/kg </th>
                            <th>Tổng T.lượng (kg) </th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
   async function exportExcel(){
        await exportExcelCustom("table_data", [
            { text: "CÔNG TY CỔ PHẦN XÂY DỰNG ĐỨC ANH", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "KHU CÔNG NGHIỆP CẨM KHÊ", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "", cols: 10 },
             { text: "BẢNG THỐNG KÊ THÉP TẤM ĐAN HỐ VAN NƯỚC SẠCH", align: "center", fontSize: 12, bold: true },
             { text: "Mẫu số 19", align: "center", fontSize: 12, bold: true },
             { text: "In tổng thể", align: "center", fontSize: 11 }
           ], "4.10 TK thép T.Đan", "4.10 TK thép T.Đan.xlsx",[1,2]);
    }

    $(function () {
        loadData();
    });

    function loadData() {
        showBlockLoading('.table-responsive');
        getJwtToken().then(async function (resUser) {
            await $.ajax({
                url: `/api/PKKLOngNhua410TKThepTDan/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        tenChiNhanh: item.tenChiNhanh ||'',

                        id_LoaiCauKien:  item.id_LoaiCauKien ||'',
                        loaiCauKien:  item.loaiCauKien ||'',
                        tenCongTacTheoKL:  item.tenCongTacTheoKL ||'',
                        tenCongTacTheoDK:  item.tenCongTacTheoDK ||'',
                        viTriLayKL:  item.viTriLayKL ||'',
                        id_TenLoaiThep:  item.id_TenLoaiThep ||'',
                        tenLoaiThep:  item.tenLoaiThep ,
                        tenThanhThepTheoCK:  item.tenThanhThepTheoCK ||'',
                        tenThanhThepTheoCD:  item.tenThanhThepTheoCD ||'',
                        soHieuThep:  item.soHieuThep ||0,
                        dKCDay:  item.dkcDay ||0,
                        soThanhCK:  item.soThanhCK ||0,
                        soCK:  item.soCK ||0,
                        tongSoThanh:  item.tongSoThanh ||0,
                        cDai1Thanh:  item.cDai1Thanh ||0,
                        tongCDai:  item.tongCDai ||0,
                        trongLuong:  item.trongLuong ||0,
                        tongTrongLuong:  item.tongTrongLuong ||0,

                        isStatus: item.isStatus || '',
                        isActive: item.isActive || '',
                    }));
                }

                const $table = $('#table_data');
                if ($.fn.DataTable.isDataTable($table)) {
                    $table.DataTable().clear().destroy();
                }

                $table.DataTable({
                    data: dataSet,
                    columns: [
                        { data: 'stt', className: 'text-center align-middle', width: '1%' },
                        {
                            data: null,
                            className: 'text-center align-middle',
                            orderable: false,
                            width: "1%",
                            render: function (data, type, row) {
                                let buttons = `
                                         <div class="btn-group">
                                     `;
                                // Chỉ hiển thị nút duyệt/hủy duyệt khi isActive == 0,1,2 (chờ duyệt)
                                 if (row.isActive < 3) {
                                     buttons += `
                                         <button class="btn btn-sm btn-success btn-approve" title="Duyệt" data-id="${row.id}" onclick="duyet('${row.id}')"><i class="fas fa-check"></i></button>
                                         <button class="btn btn-sm btn-warning btn-cancel-approve" title="Hủy duyệt" data-id="${row.id}" onclick="huyDuyet('${row.id}')"><i class="fas fa-times"></i></button>
                                     `;
                                 }else if (row.isActive = 3) {
                                      buttons += `
                                      <button class="btn btn-sm btn-danger btn-delete" title="Xóa" data-id="${row.id}" onclick=deleteCaiDat("${row.id}")><i class="fas fa-trash"></i></button>`;
                                 }
                                 buttons += `
                                     <button class="btn btn-sm btn-primary btn-edit" title="Chỉnh sửa" data-id="${row.id}" onclick=editCaiDat("${row.id}")><i class="fas fa-edit"></i></button>
                                     <button class="btn btn-sm btn-danger btn-delete" title="Chi tiết" data-id="${row.id}" onclick=chiTiet("${row.id}")><i class="fas fa-eye"></i></button>

                                 </div>
                                 `;
                                return buttons;
                            }
                        },
                        { data: 'isStatus', className: 'align-middle' },
                        { data: 'tenChiNhanh', className: 'align-middle' },

                        { data: 'loaiCauKien', className: 'align-middle' },
                        { data: 'tenCongTacTheoKL', className: 'align-middle' },
                        { data: 'tenCongTacTheoDK', className: 'align-middle' },
                        { data: 'viTriLayKL', className: 'align-middle' },
                        { data: 'tenLoaiThep', className: 'align-middle' },
                        { data: 'tenThanhThepTheoCK', className: 'align-middle' },
                        { data: 'tenThanhThepTheoCD', className: 'align-middle' },
                        { data: 'soHieuThep', className: 'align-middle' },
                        { data: 'dKCDay', className: 'align-middle' },
                        { data: 'soThanhCK', className: 'align-middle' },
                        { data: 'soCK', className: 'align-middle' },
                        { data: 'tongSoThanh', className: 'align-middle' },
                        { data: 'cDai1Thanh', className: 'align-middle' },
                        { data: 'tongCDai', className: 'align-middle' },
                        { data: 'trongLuong', className: 'align-middle' },
                        { data: 'tongTrongLuong', className: 'align-middle' },
                        ],
                    autoWidth: false,
                    ordering: true,
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                        zeroRecords: "Không tìm thấy dữ liệu",
                        info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                        infoEmpty: "Không có bản ghi nào",
                        infoFiltered: "(lọc từ _MAX_ bản ghi)",
                        search: "Tìm kiếm:",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function (colIdx) {
                            var column = this;
                            var $footer = $(column.footer()).empty();
                            if (colIdx === 0 || colIdx === 1) {
                                $footer.append('<p></p>');
                            }else{
                                var select = $('<select><option value=""></option></select>')
                                .appendTo($footer)
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });

                                column.data().unique().sort().each(function (d) {
                                    select.append('<option value="' + d + '">' + d + '</option>');
                                });
                            }
                            
                        });
                    }
                });
            }).fail(function (xhr) {
                var colCount = $('#table_data thead th').length;
                $('#table_data tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');
            
            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }

    async function showModalTaoMoi(isEdit = false, data = null) {
        const modalTitle = isEdit ? "Cập nhật " : "Thêm mới ";
        const resUser = await getJwtToken();
        const token = resUser.token;
        const groupId = resUser.userInfor.groupId;
        const userName = resUser.userInfor.userName;

        // Dropdowns mapping
        const dropdownApis = [
            { url: "/api/DMLoaiCauKien/GetAll", id: ["id_LoaiCauKien"], text: "Loại cấu kiện" },
        ];
        
        const dropdowns = {};
        for (const item of dropdownApis) {
            let options = `<option value="">-- Chọn ${item.text} --</option>`;
            let resData = [];

            try {
                const res = await $.ajax({
                    url: `${item.url}?groupId=${groupId}`,
                    method: "GET",
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (res.success && Array.isArray(res.data)) {
                    resData = res.data;
                }
            } catch {
                options += '<option>Lỗi tải dữ liệu</option>';
            }

            for (const idKey of item.id) {
                let selectOptions = options;

                resData.forEach(x => {
                    const selected = data && data[idKey] === x.id ? 'selected' : '';
                    selectOptions += `<option value="${x.id}" ${selected}>${x.tenDanhMuc}</option>`;
                });

                dropdowns[idKey] = selectOptions;
            }
        }

        try {
            let selectChiNhanh = '<option value="">-- Chọn công trình --</option>';
            const res = await $.ajax({
                 url: "/api/ChiNhanh/GetByVM?groupId=" +groupId,
                 method: "POST",
                 headers: {
                     "Content-Type": "application/json",
                     "Authorization": "Bearer " + resUser.token
                 },
                 data: JSON.stringify({
                     Id : "",
                     ParentId : "",
                     TenChiNhanh : "",
                     CompanyType : "",
                     Phone : "",
                     Email : "",
                     Address : "",
                     GroupId : "",
                     Ordinarily : 0,
                     CreateAt : null,
                     CreateBy : "",
                     IsActive : 0,
                     ApprovalUserId : "",
                     DateApproval : null,
                     ApprovalDept : "",
                     DepartmentId : "",
                     DepartmentOrder : 0,
                     ApprovalOrder : 0,
                     ApprovalId : "",
                     LastApprovalId : "",
                     IsStatus : ""
                 })
             });

            if (res && res.success && Array.isArray(res.data)) {
                res.data.forEach(x => {
                    const selected = (data && data["id_ChiNhanh"] === x.id) ? 'selected' : '';
                    selectChiNhanh += `<option value="${x.id}" ${selected}>${x.tenChiNhanh || ''}</option>`;
                });
            } else {
                selectChiNhanh += '<option>Lỗi tải dữ liệu</option>';
            }
            dropdowns["id_ChiNhanh"] = selectChiNhanh;
        } catch (err) {
            let selectChiNhanh = '<option>Lỗi tải dữ liệu</option>';
            dropdowns["id_ChiNhanh"] = selectChiNhanh;
        }
        try {
            let selectLoaiThep = '<option value="">-- Chọn loại thép --</option>';
            const res = await $.ajax({
                 url: `/api/DMDanhMucThep/GetByVM?groupId=${groupId}`,
                 method: "POST",
                 headers: {
                     "Content-Type": "application/json",
                     "Authorization": "Bearer " + resUser.token
                 },
                 data: JSON.stringify({
                    Id : "",
                    Id_TenLoaiThep : "",
                    TenLoaiThep : "",
                    DuongKinh : "",
                    TrongLuong : 0.0,
                    DonVi : "",

                    GroupId : "",
                    Ordinarily : 0,
                    CreateAt : null,
                    CreateBy : "",
                    IsActive : 0,
                    ApprovalUserId : "",
                    DateApproval : null,
                    ApprovalDept : "",
                    DepartmentId : "",
                    DepartmentOrder : 0,
                    ApprovalOrder : 0,
                    ApprovalId : "",
                    LastApprovalId : "",
                    IsStatus : ""
                })
             });

            if (res && res.success && Array.isArray(res.data)) {
                res.data.forEach(x => {
                    const selected = (data && data["id_TenLoaiThep"] === x.id) ? 'selected' : '';
                    selectLoaiThep += `<option value="${x.id}" ${selected}>${x.tenLoaiThep} (${x.duongKinh}-${x.trongLuong})</option>`;
                });
            } else {
                selectLoaiThep += '<option>Lỗi tải dữ liệu</option>';
            }
            dropdowns["id_TenLoaiThep"] = selectLoaiThep;
        } catch (err) {
            let selectLoaiThep = '<option>Lỗi tải dữ liệu</option>';
            dropdowns["id_TenLoaiThep"] = selectLoaiThep;
        }

        const bodyHtml = `
               <form id="form_caidat">
                 <div class="form-row">
                     <div class="w-100 card-custom shadow-sm p-3 my-3">
                         <span class="card-title-custom">Thông tin lý trình</span>
                         <div class="form-row">
                             <div class="form-group col-md-4">
                                 <label>Tên công trình<span class="text-danger">*</span></label>
                                 <select id="id_ChiNhanh" class="form-control">${dropdowns.id_ChiNhanh}</select>
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Loại cấu kiện<span class="text-danger">*</span></label>
                                 <select id="id_LoaiCauKien" class="form-control">${dropdowns.id_LoaiCauKien}</select>
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tên công tác theo vị trí lấy KL<span class="text-danger">*</span></label>
                                 <input type="text" id="tenCongTacTheoKL" value="${data?.tenCongTacTheoKL || ''}" class="form-control" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tên công tác theo Đ.Kính<span class="text-danger">*</span></label>
                                 <input type="text" id="tenCongTacTheoDK" value="${data?.tenCongTacTheoDK || ''}" class="form-control" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Vị trí lấy khối lượng<span class="text-danger">*</span></label>
                                 <input type="text" id="viTriLayKL" value="${data?.viTriLayKL || ''}" class="form-control" />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Loại thép<span class="text-danger">*</span></label>
                                 <select id="id_TenLoaiThep" class="form-control">${dropdowns.id_TenLoaiThep}</select>
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tên thanh thép theo C.Kiện<span class="text-danger">*</span></label>
                                 <input type="text" id="tenThanhThepTheoCK" value="${data?.tenThanhThepTheoCK || ''}" class="form-control" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tên thanh thép theo C.Dài<span class="text-danger">*</span></label>
                                 <input type="text" id="tenThanhThepTheoCD" value="${data?.tenThanhThepTheoCD || ''}" class="form-control" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Số hiệu thép<span class="text-danger">*</span></label>
                                 <input type="number" id="soHieuThep" value="${data?.soHieuThep || 0}" class="form-control" step="any" />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>ĐK/C.Dầy(mm,mm2) thép<span class="text-danger">*</span></label>
                                 <input type="number" id="dKCDay" value="${data?.dKCDay || 0}" class="form-control" step="any" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Số thanh/ CK<span class="text-danger">*</span></label>
                                 <input type="number" id="soThanhCK" value="${data?.soThanhCK || 0}" class="form-control" step="any" />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Số CK<span class="text-danger">*</span></label>
                                 <input type="number" id="soCK" value="${data?.soCK || 0}" class="form-control" step="any" />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tổng số thanh<span class="text-danger">*</span></label>
                                 <input type="number" id="tongSoThanh" value="${data?.tongSoThanh || 0}" class="form-control" step="any" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>C.Dài 01 thanh (mm)/DT (mm2)thanh<span class="text-danger">*</span></label>
                                 <input type="number" id="cDai1Thanh" value="${data?.cDai1Thanh || 0}" class="form-control" step="any" />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tổng C.Dài (m,m2)<span class="text-danger">*</span></label>
                                 <input type="number" id="tongCDai" value="${data?.tongCDai || 0}" class="form-control" step="any" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>T.Lượng/kg<span class="text-danger">*</span></label>
                                 <input type="number" id="trongLuong" value="${data?.trongLuong || 0}" class="form-control" step="any" readonly />
                             </div>
                             <div class="form-group col-md-4">
                                 <label>Tổng T.lượng (kg)<span class="text-danger">*</span></label>
                                 <input type="number" id="tongTrongLuong" value="${data?.tongTrongLuong || 0}" class="form-control" step="any" readonly />
                             </div>
                         </div>
                     </div>
                 </div>
             </form>
             <div id="error_msg" class="text-danger font-weight-bold mb-2"></div>
         `;

        const footerHtml = `
                <button type="button" class="btn btn-primary" id="btnLuuCaiDat">${isEdit ? "Cập nhật" : "Lưu"}</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Hủy</button>
            `;

        showGlobalModal(modalTitle, bodyHtml, footerHtml);
        $('#btnLuuCaiDat').data("isedit", isEdit).data("id", data?.id || "");

        $('#btnLuuCaiDat').off('click').on('click', async function () {
            const id = $(this).data("id");
            const isEdit = $(this).data("isedit");


            if (!validateForm())
                return;

            const dataSend = {
                Id: id,
                id_ChiNhanh : $('#id_ChiNhanh').val(),
                id_LoaiCauKien : $('#id_LoaiCauKien').val(),
                tenCongTacTheoKL : $('#tenCongTacTheoKL').val(),
                tenCongTacTheoDK : $('#tenCongTacTheoDK').val(),
                viTriLayKL : $('#viTriLayKL').val(),
                id_TenLoaiThep : $('#id_TenLoaiThep').val(),
                tenThanhThepTheoCK : $('#tenThanhThepTheoCK').val(),
                tenThanhThepTheoCD : $('#tenThanhThepTheoCD').val(),
                soHieuThep :parseFloat($('#soHieuThep').val()) || 0,
                dKCDay :parseFloat($('#dKCDay').val()) || 0,
                soThanhCK :parseFloat($('#soThanhCK').val()) || 0,
                soCK :parseFloat($('#soCK').val()) || 0,
                tongSoThanh :parseFloat($('#tongSoThanh').val()) || 0,
                cDai1Thanh :parseFloat($('#cDai1Thanh').val()) || 0,
                tongCDai :parseFloat($('#tongCDai').val()) || 0,
                trongLuong :parseFloat($('#trongLuong').val()) || 0,
                tongTrongLuong :parseFloat($('#tongTrongLuong').val()) || 0,

                GroupId: groupId,
                Ordinarily: 0,
                CreateAt: new Date().toISOString(),
                CreateBy: userName,
                IsActive: isEdit && data ? data.isActive : 0,
                ApprovalUserId: "",
                DateApproval: null,
                ApprovalDept: "",
                DepartmentId: "",
                DepartmentOrder: 0,
                ApprovalOrder: 0,
                ApprovalId: "",
                LastApprovalId: "",
                IsStatus: ""
            };

            try {
                const res = await $.ajax({
                    url: `/api/PKKLOngNhua410TKThepTDan/Create?isEdit=${isEdit}`,
                    method: "POST",
                    contentType: "application/json",
                    headers: { Authorization: `Bearer ${token}` },
                    data: JSON.stringify(dataSend)
                });
                if (res.success) {
                    showToastSuccess(isEdit ? "Cập nhật thành công!" : "Lưu thành công!");
                    $('#globalModal').modal('hide');
                    loadData();
                } else {
                    $('#error_msg').text(res.message || "Có lỗi xảy ra khi lưu.");
                    showToastError(res.message || "Có lỗi xảy ra khi lưu.");
                }
            } catch (err) {
