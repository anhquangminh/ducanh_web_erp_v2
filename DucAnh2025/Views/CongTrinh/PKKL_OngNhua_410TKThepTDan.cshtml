    // Validate form
    function validateForm() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();
        let isValid = true;
        let firstInvalid = null;
        const requiredFields = [
                { selector: '#id_ChiNhanh', message: 'Vui lòng chọn tên công trình.' },
                { selector: '#id_LoaiCauKien', message: 'Vui lòng chọn loại cấu kiện' },
                { selector: '#tenCongTacTheoKL', message: 'Tên công tác theo vị trí lấy KL' },
                { selector: '#tenCongTacTheoDK', message: 'Tên công tác theo Đ.Kính' },
                { selector: '#viTriLayKL', message: 'Vị trí lấy khối lượng' },
                { selector: '#id_TenLoaiThep', message: 'Loại thép' },
                { selector: '#tenThanhThepTheoCK', message: 'Tên thanh thép theo C.Kiện' },
                { selector: '#tenThanhThepTheoCD', message: 'Tên thanh thép theo C.Dài' },
                { selector: '#soHieuThep', message: 'Số hiệu thép' },
                { selector: '#dKCDay', message: 'ĐK/C.Dầy(mm,mm2)' },
                { selector: '#soThanhCK', message: 'Số thanh/ CK ' },
                { selector: '#soCK', message: 'Số CK' },
                { selector: '#tongSoThanh', message: 'Tổng số thanh' },
                { selector: '#cDai1Thanh', message: 'C.Dài 01 thanh (mm)/DT (mm2)' },
                { selector: '#tongCDai', message: 'Tổng C.Dài (m,m2) ' },
                { selector: '#trongLuong', message: 'T.Lượng/kg ' },
                { selector: '#tongTrongLuong', message: 'Tổng T.lượng (kg) ' },

            ];
            requiredFields.forEach(f => {
                const $input = $(f.selector);
                if (!$(f.selector).val() || !$(f.selector).val().trim()) {
                    showError(f.selector, f.message);
                    if (!firstInvalid) firstInvalid = $input[0];
                    isValid = false;
                }
            });

            if (!isValid && firstInvalid) {
                firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });

                const $el = $(firstInvalid);
                if ($el.hasClass("select2-hidden-accessible")) {
                    $el.next('.select2-container').find('.select2-selection').focus();
                } else {
                    $el.focus();
                }
            }
         return isValid;
    }

    // Hiển thị lỗi
    function showError(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }

