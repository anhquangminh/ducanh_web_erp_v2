    const calcMap = {
        "tenCongTacTheoKL": {
            func: tenCongTacTheoKL,
            inputs: ["viTriLayKL", "dKCDay"]
        },
        "tenCongTacTheoDK": {
            func: tenCongTacTheoDK,
            inputs: ["dKCDay"]
        },
        "tenThanhThepTheoCK": {
            func: tenThanhThepTheoCK,
            inputs: ["id_LoaiCauKien", "dKCDay", "soHieuThep", "cDai1Thanh"]
        },
        "tenThanhThepTheoCD": {
            func: tenThanhThepTheoCD,
            inputs: ["dKCDay","cDai1Thanh"]
        },
        "tongSoThanh": {
            func: tongSoThanh,
            inputs: ["soThanhCK","soCK"]
        },
        "tongCDai": {
            func: tongCDai,
            inputs: ["tongSoThanh","cDai1Thanh"]
        },
        "tongTrongLuong": {
            func: tongTrongLuong,
            inputs: ["id_TenLoaiThep","dKCDay","tongCDai","trongLuong"]
        },
    };

        // Hàm tổng quát để gọi các phép tính và set lại giá trị
    function autoCalculate() {
        try {
            Object.keys(calcMap).forEach(function (resultId) {
                const { func, inputs } = calcMap[resultId];
                const args = inputs.map(id => {
                    const $el = $('#' + id);

                    if ($el.is('select')) {
                        return $el.find(':selected').text();
                    }

                    const inputType = $el.attr('type');
                    const val = $el.val();

                    if (inputType === "text") {
                        return (val === null || typeof val === "undefined") ? "" : val;
                    }

                    if (val === "" || val === null || typeof val === "undefined") return 0;
                    const num = parseFloat(val);
                    return isNaN(num) ? 0 : num;
                });

                let result = func.apply(null, args);

                if (typeof result === "number" && isNaN(result)) result = "";
                $('#' + resultId).val(result);
            });
        } catch (err) {
            console.error('Lỗi tổng thể trong autoCalculate:', err);
        }
    }

    function debounce(fn, delay) {
        let timer = null;
        return function (...args) {
            clearTimeout(timer);
            timer = setTimeout(() => fn.apply(this, args), delay);
        };
    }

    function tenCongTacTheoKL(viTriLayKL, dKCDay) {
        return "Gia công lắp dựng thép " + viTriLayKL + ", thép D" + dKCDay;
    }
    function tenCongTacTheoDK(dKCDay) {
        return "Gia công lắp dựng thép D" + dKCDay;
    }
    function tenThanhThepTheoCK(id_LoaiCauKien, dKCDay, soHieuThep, cDai1Thanh) {
        return id_LoaiCauKien + "/D" + dKCDay + "/T" + soHieuThep + "/L=" + cDai1Thanh;
    }
    function tenThanhThepTheoCD(dKCDay, cDai1Thanh) {
        return "D" + dKCDay + "/L=" + cDai1Thanh;
    }
    function tongSoThanh(soThanhCK, soCK) {
        return soThanhCK * soCK;
    }
    function tongCDai(tongSoThanh, cDai1Thanh) {
        return (tongSoThanh * cDai1Thanh) / 1000;
    }
    function tongTrongLuong(id_TenLoaiThep, dKCDay, tongCDai, trongLuong) {
        let result;

        if (id_TenLoaiThep === "Thép bản") {
            result = (dKCDay * tongCDai * trongLuong) / 1000000;
        } else {
            result = tongCDai * trongLuong;
        }

        return Math.round(result * 100) / 100; // làm tròn đến 2 chữ số thập phân
    }

</script>

