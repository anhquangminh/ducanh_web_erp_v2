                        if (it.tenHoVan && it.id_HangMucKhoiLuongXayTren && it.id_LoaiKhoiLuongXayTren) {
                            const key = makeKey(idCN,tenHoVan,it.id_HangMucKhoiLuongXayTren, it.id_LoaiKhoiLuongXayTren);
                                        map11.set(key, (map11.get(key) || 0) + num(it.tongKlXayTren));
                        }
                        // 12)
                        if (it.tenHoVan && it.id_HangMucKhoiLuongXayTren && it.id_LoaiKhoiLuongChatTren) {
                            const key = makeKey(idCN,tenHoVan,it.id_HangMucKhoiLuongXayTren, it.id_LoaiKhoiLuongChatTren);
                                        map12.set(key, (map12.get(key) || 0) + num(it.tongKlChatTren));
                        }
                        // 13)
                        if (it.tenHoVan && it.id_HangMucKhoiLuongXayTren && it.id_LoaiKhoiLuongChatTrenTrong) {
                            const key = makeKey(idCN,tenHoVan,it.id_HangMucKhoiLuongXayTren, it.id_LoaiKhoiLuongChatTrenTrong);
                                        map13.set(key, (map13.get(key) || 0) + num(it.tongKlChatTrenTrong));
                        }

                    });
                    dataSet.forEach(row => {
                        let tong = 0;

                         const key = makeKey(
                                row.id_ChiNhanh,
                                row.tenHoVan,
                                row.id_HangMucKhoiLuong,
                                row.id_LoaiKhoiLuong,
                            );
                            const sum =
                                (map1.get(key) || 0) +
                                (map2.get(key) || 0) +
                                (map3.get(key) || 0) +
                                (map4.get(key) || 0) +
                                (map5.get(key) || 0) +
                                (map6.get(key) || 0) +
                                (map7.get(key) || 0) +
                                (map8.get(key) || 0) +
                                (map9.get(key) || 0) +
                                (map10.get(key) || 0) +
                                (map11.get(key) || 0) +
                                (map12.get(key) || 0) +
                                (map13.get(key) || 0);

                        row.tongKhoiLuong = sum > 0 ? Math.round(sum * 100) / 100 : "0";
                        
                        // Tên công tác
                        const keyCongTac = [
                            row.id_HangMucCongViec,
                            row.id_HangMucKhoiLuong,
                            row.id_LoaiKhoiLuong
                        ].join('|');
                        if (tenCongTacLookup[keyCongTac]) {
                            row.tenCongtac = tenCongTacLookup[keyCongTac].tenCongTac || "";
                            row.donVi = tenCongTacLookup[keyCongTac].donVi || "";
                        }

                    });

                    let data_47a = dataSet;

                    const sumLookup = {};

                    // Gom nhóm và tính tổng trước
                    data_47a.forEach(row => {
                        // Key
                        const key = [
                                row.id_ChiNhanh,
                                row.id_HangMucCongViec,
                                row.id_HangMucKhoiLuong,
                                row.id_LoaiKhoiLuong,
                                row.tenCongtac,
                                row.donVi,
                                row.tuyenDuong
                        ].join('|');
                        sumLookup[key] = (sumLookup[key] || 0) + (parseFloat(row.tongKhoiLuong) || 0);

                    });

                    // lọc duy nhất theo 6 trường
                    let seen = new Set();
                    dataSet = data_47a.filter(row => {
                        let key = [
                            row.id_ChiNhanh,
                            row.id_HangMucCongViec,
                            row.id_HangMucKhoiLuong,
                            row.id_LoaiKhoiLuong,
                            row.tenCongtac,
                            row.donVi,
                        ].join('|');
                        if (seen.has(key)) return false;
                        seen.add(key);
                        return true;
                    });
                    uniqueTuyenDuong = [...new Set(data_47a.map(item => item.tuyenDuong).filter(Boolean))];
                    addDynamicColumns(uniqueTuyenDuong);
                 
                    dataSet.forEach(row => {
                        let tong = 0;

                        uniqueTuyenDuong.forEach(td => {
                            const key = [
                                row.id_ChiNhanh,
                                row.id_HangMucCongViec,
                                row.id_HangMucKhoiLuong,
                                row.id_LoaiKhoiLuong,
                                row.tenCongtac,
                                row.donVi,
                                td
                            ].join('|');
                            
                            let sum = (sumLookup[key] || 0) ;
                            row[td] = sum > 0 ? Math.round(sum * 100) / 100 : "0";
                            tong = +sum;
                        });
                         row.tongKhoiLuong = tong > 0 ? Math.round(tong * 100) / 100 : "0";
                        
                    });


                    const $table = $('#table_hoga');

                    // Config cột cố định
                    let columns = [
                        { data: 'stt', className: 'text-center align-middle', width: '1%' },
                        { data: 'tenChiNhanh', className: 'align-middle' },
                        { data: 'hangMucCongViec', className: 'align-middle' },
                        { data: 'hangMucKhoiLuong', className: 'align-middle' },
                        { data: 'loaiKhoiLuong', className: 'align-middle' },
                        { data: 'tenCongtac', className: 'align-middle' },
                        { data: 'donVi', className: 'align-middle' },
                        { data: 'tongKhoiLuong', className: 'align-middle' }
                    ];

                    uniqueTuyenDuong.forEach(td => {
                        columns.push({
                            data: td,
                            className: 'align-middle',
                            defaultContent: ''
                        });
                    });
                   
                    if ($.fn.DataTable.isDataTable($table)) {
                        $table.DataTable().clear().rows.add(dataSet).draw();
                    } else {
                        $table.DataTable({
                            data: dataSet,
                            columns: columns,
                            autoWidth: false,
                            ordering: true,
                            searching: true,
                            paging: true,
                            pageLength: 10,
                            info: true,
                            language: {
                                lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                                zeroRecords: "Không tìm thấy dữ liệu",
                                info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                                infoEmpty: "Không có bản ghi nào",
                                infoFiltered: "(lọc từ _MAX_ bản ghi)",
                                search: "Tìm kiếm:",
                                paginate: {
                                    first: "Đầu",
                                    last: "Cuối",
                                    next: "Sau",
                                    previous: "Trước"
                                }
                            },
                            initComplete: function () {
                                this.api().columns().every(function (colIdx) {
                                    var column = this;
                                    var $footer = $(column.footer()).empty();
                                    if (colIdx === 0) {
                                        $footer.append('<p></p>');
                                    } else {
                                        var select = $('<select><option value=""></option></select>')
                                            .appendTo($footer)
                                            .on('change', function () {
                                                var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                                column
                                                    .search(val ? '^' + val + '$' : '', true, false)
                                                    .draw();
                                            });

                                        column.data().unique().sort().each(function (d) {
                                            select.append('<option value="' + d + '">' + d + '</option>');
                                        });
                                    }

                                });
                            }
                        });
                    }
                }
            }).fail(function (xhr) {
                var colCount = $('#table_hoga thead tr:last th').length;
                $('#table_hoga tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');
            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }


    // Hiển thị lỗi
    function showError(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }

    function addDynamicColumns(uniqueTuyenDuong) {
        const $theadRow = $('#table_hoga thead tr').last(); // lấy row cuối trong thead
        const $tfootRow = $('#table_hoga tfoot tr');

        // Xoá cột động cũ
        $theadRow.find('th.dynamic-col').remove();
        $tfootRow.find('th.dynamic-col').remove();

        // Thêm cột động mới
        uniqueTuyenDuong.forEach(td => {
            $theadRow.append(`<th class="dynamic-col">${td}</th>`);
            $tfootRow.append(`<th class="dynamic-col">${td}</th>`);
        });
        $('#col-dynamic').attr('colspan', uniqueTuyenDuong.length + 1);
    }

</script>

