<div class="tab-content">
    <div class="card mt-3 w-100 d-flex">
        <div class="card-header">
            <h3 class="m-0 mr-2">BẢNG TỔNG HỢP KHỐI LƯỢNG TẤM ĐAN HỐ VAN NƯỚC SẠCH THEO LÝ TRÌNH </h3>
        </div>
        <div class="card-body">
            <div role="group" class="mb-2 btn-group-sm btn-group btn-group-toggle" data-toggle="buttons">
                <button type="button" class="btn btn-outline-focus" onclick="copyTable('table_data')">Copy</button>
                <button type="button" class="btn btn-outline-focus" onclick="exportExcel()">Excel</button>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="table_data">
                    <thead>
                        <tr>
                            <td colspan="7">Thông tin loại tấm đan</td>
                            <td colspan="3">Thông tin lắp đặt</td>
                            <td colspan="7">Thông tin sản xuất</td>
                        </tr>
                        <tr>
                            <th>#</th>
                            <th>Tên công trình</th>

                            <th>Tuyến đường</th>
                            <th>Từ lý trình</th>
                            <th>Tên hố van</th>
                            <th>Hạng mục công việc</th>
                            <th>Loại cấu kiện</th>
                            <th>Hạng mục KL</th>
                            <th>Loại KL</th>
                            <th>KL</th>
                            <th>Hạng mục KL</th>
                            <th>Loại KL</th>
                            <th>KL 01CK (m3)</th>
                            <th>Tổng KL (m3)</th>
                            <th>Loại KL</th>
                            <th>KL 01CK (m2)</th>
                            <th>Tổng KL (m2)</th>
                        </tr>
                    </thead>

                    <tfoot>
                        <tr>
                            <th>#</th>
                            <th>Tên công trình</th>

                            <th>Tuyến đường</th>
                            <th>Từ lý trình</th>
                            <th>Tên hố van</th>
                            <th>Hạng mục công việc</th>
                            <th>Loại cấu kiện</th>
                            <th>Hạng mục KL</th>
                            <th>Loại KL</th>
                            <th>KL</th>
                            <th>Hạng mục KL</th>
                            <th>Loại KL</th>
                            <th>KL 01CK (m3)</th>
                            <th>Tổng KL (m3)</th>
                            <th>Loại KL</th>
                            <th>KL 01CK (m2)</th>
                            <th>Tổng KL (m2)</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    async function exportExcel(){
        await exportExcelCustom("table_data", [
            { text: "CÔNG TY CỔ PHẦN XÂY DỰNG ĐỨC ANH", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "KHU CÔNG NGHIỆP CẨM KHÊ", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "", cols: 10 },
            { text: "BẢNG TỔNG HỢP KHỐI LƯỢNG TẤM ĐAN HỐ VAN NƯỚC SẠCH THEO LÝ TRÌNH", align: "center", fontSize: 12, bold: true },
            { text: "Mẫu số 15", align: "center", fontSize: 12, bold: true },
            { text: "In theo tuyến", align: "center", fontSize: 11 }
        ], "4.9 KL TĐHG theo L.Trình", "4.9 KL TĐHG theo L.Trình.xlsx");
    }

     $(function () {
        loadData();
    });

    function loadData() {
        showBlockLoading('.table-responsive');
        getJwtToken().then(async function (resUser) {
            await $.ajax({
                url: `/api/PKKLOngNhua4ThongTinChungHGa/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];

                if (res.success && Array.isArray(res.data) && res.data.length > 0) {

                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        id_ChiNhanh: item.id_ChiNhanh || '',
                        tenChiNhanh: item.tenChiNhanh || '',
                        tuyenDuong: item.tuyenDuong || '',
                        lyTrinh: item.lyTrinh || '',
                        tenHoVan: item.tenHoVan || '',
                        id_HangMucCongViecTamDan: item.id_HangMucCongViecTamDan || '',
                        hangMucCongViecTamDan: item.hangMucCongViecTamDan || '',
                        id_LoaiCauKien: item.id_LoaiCauKien || '',
                        loaiCauKien: item.loaiCauKien || '',
                        id_HangMucKhoiLuongTamDan: item.id_HangMucKhoiLuongTamDan || '',
                        hangMucKhoiLuongTamDan: item.hangMucKhoiLuongTamDan || '',
                        id_LoaiKhoiLuongTamDan: item.id_LoaiKhoiLuongTamDan || '',
                        loaiKhoiLuongTamDan: item.loaiKhoiLuongTamDan || '',
                        soLuong: item.soLuong || '0',
                        id_HangMucKhoiLuongXayTamDan: item.id_HangMucKhoiLuongXayTamDan || '',
                        hangMucKhoiLuongXayTamDan: item.hangMucKhoiLuongXayTamDan || '',
                        id_LoaiKhoiLuongXayTamDan: item.id_LoaiKhoiLuongXayTamDan || '',
                        loaiKhoiLuongXayTamDan: item.loaiKhoiLuongXayTamDan || '',
                        kl01TDanXayTamDan: item.kl01TDanXayTamDan || '0',
                        tongKlTDanXayTamDan: item.tongKlTDanXayTamDan || '0',
                        id_LoaiKhoiLuongVanKhuan: item.id_LoaiKhoiLuongVanKhuan || '',
                        loaiKhoiLuongVanKhuan: item.loaiKhoiLuongVanKhuan || '',
                        kl01CauKienVanKhuan: item.kl01CauKienVanKhuan || '0',
                        tongKlVanKhuanTDanVanKhuan: item.tongKlVanKhuanTDanVanKhuan || '0',

                        isStatus: item.isStatus || '',
                        isActive: item.isActive || '',
                    }));
                }


                const $table = $('#table_data');
                // Config cột cố định
                let columns = [
                    { data: 'stt', className: 'text-center align-middle', width: '1%' },
                    { data: 'tenChiNhanh', className: 'align-middle' },
                    { data: 'tuyenDuong', className: 'align-middle' },
                    { data: 'lyTrinh', className: 'align-middle' },
                    { data: 'tenHoVan', className: 'align-middle' },
                    { data: 'hangMucCongViecTamDan', className: 'align-middle' },
                    { data: 'loaiCauKien', className: 'align-middle' },
                    { data: 'hangMucKhoiLuongTamDan', className: 'align-middle' },
                    { data: 'loaiKhoiLuongTamDan', className: 'align-middle' },
                    { data: 'soLuong', className: 'align-middle' },
                    { data: 'hangMucKhoiLuongXayTamDan', className: 'align-middle' },
                    { data: 'loaiKhoiLuongXayTamDan', className: 'align-middle' },
                    { data: 'kl01TDanXayTamDan', className: 'align-middle' },
                    { data: 'tongKlTDanXayTamDan', className: 'align-middle' },
                    { data: 'loaiKhoiLuongVanKhuan', className: 'align-middle' },
                    { data: 'kl01CauKienVanKhuan', className: 'align-middle' },
                    { data: 'tongKlVanKhuanTDanVanKhuan', className: 'align-middle' },
                ];

                if ($.fn.DataTable.isDataTable($table)) {
                    $table.DataTable().clear().rows.add(dataSet).draw();
                } else {
                    $table.DataTable({
                        data: dataSet,
                        columns: columns,
                        autoWidth: false,
                        ordering: true,
                        searching: true,
                        paging: true,
                        pageLength: 10,
                        info: true,
                        language: {
                            lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                            zeroRecords: "Không tìm thấy dữ liệu",
                            info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                            infoEmpty: "Không có bản ghi nào",
                            infoFiltered: "(lọc từ _MAX_ bản ghi)",
                            search: "Tìm kiếm:",
                            paginate: {
                                first: "Đầu",
                                last: "Cuối",
                                next: "Sau",
                                previous: "Trước"
                            }
                        },
                        initComplete: function () {
                            this.api().columns().every(function (colIdx) {
                                var column = this;
                                var $footer = $(column.footer()).empty();
                                if (colIdx === 0) {
                                    $footer.append('<p></p>');
                                } else {
                                    var select = $('<select><option value=""></option></select>')
                                        .appendTo($footer)
                                        .on('change', function () {
                                            var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                            column
                                                .search(val ? '^' + val + '$' : '', true, false)
                                                .draw();
                                        });

                                    column.data().unique().sort().each(function (d) {
                                        select.append('<option value="' + d + '">' + d + '</option>');
                                    });
                                }

                            });
                        }
                    });
                }
            }).fail(function (xhr) {
                var colCount = $('#table_data thead th').length;
                $('#table_data tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');

            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }
</script>
