                            <th>Loại KL</th>
                            <th>Khối lượng </th>
                        </tr>
                    </thead>

                    <tfoot>
                        <tr>
                            <th>#</th>
                            <th>Tên công trình</th>

                            <th>Tuyến đường</th>
                            <th>Từ lý trình</th>
                            <th>Hạng mục công việc</th>
                            <th>Tên hố van</th>
                            <th>Hình thức đắp trả</th>
                            <th>Hạng mục KL</th>
