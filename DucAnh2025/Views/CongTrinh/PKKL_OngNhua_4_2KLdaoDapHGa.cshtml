                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
   async function exportExcel(){
        await exportExcelCustom("table_data", [
            { text: "CÔNG TY CỔ PHẦN XÂY DỰNG ĐỨC ANH", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "KHU CÔNG NGHIỆP CẨM KHÊ", cols: 5, align: "left", fontSize: 12, bold: true },
            { text: "", cols: 10 },
             { text: "BẢNG THỐNG KÊ KHỐI LƯỢNG ĐÀO, ĐẮP, VẬN CHUYỂN ĐẤT, CÁT THEO LÝ TRÌNH", align: "center", fontSize: 12, bold: true },
            { text: "Mẫu số 02", align: "center", fontSize: 12, bold: true },
             { text: "In theo từng tuyến", align: "center", fontSize: 11 }
          ], "4.2 KL đào đắp H.Ga", "4.2 KL đào đắp H.Ga.xlsx");
    }

    $(function () {
        loadData();
    });

    function loadData() {
        showBlockLoading('.table-responsive');
        getJwtToken().then(async function (resUser) {
            await $.ajax({
                url: `/api/PKKLOngNhua4ThongTinChungHGa/GetByVM?groupId=${resUser.userInfor.groupId}`,
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": "Bearer " + resUser.token
                },
            }).done(function (res) {
                let dataSet = [];
                if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                    dataSet = res.data.map((item, idx) => ({
                        stt: idx + 1,
                        id: item.id,
                        tenChiNhanh: item.tenChiNhanh|| '',

                        tuyenDuong:item.tuyenDuong || '',
                        lyTrinh:item.lyTrinh || '',
                        id_HangMucCongViec:item.id_HangMucCongViec || '',
                        hangMucCongViec:item.hangMucCongViec || '',
                        tenHoVan:item.tenHoVan || '',
                        id_HinhThucDapTra:item.id_HinhThucDapTra || '',
                        hinhThucDapTra:item.hinhThucDapTra || '',
                        hangMucKlDao:item.hangMucKlDao || '0',
                        loaiKlDao:item.loaiKlDao || '0',
                        klDao:item.klDao || '0',
                        hangMucKlDapTraDapCat:item.hangMucKlDapTraDapCat || '0',
                        loaiKlDapTraDapCat:item.loaiKlDapTraDapCat || '0',
                        klDapCatSauCChoDapTraDapCat:item.klDapCatSauCChoDapTraDapCat || '0',
                        hangMucKlDapTraDapDat:item.hangMucKlDapTraDapDat || '0',
                        loaiKlDapTraDapDat:item.loaiKlDapTraDapDat || '0',
                        klDapDatSauCChoDapTraDapDat:item.klDapDatSauCChoDapTraDapDat || '0',
                        hangMucKlDapTraDapDatThua:item.hangMucKlDapTraDapDatThua || '0',
                        loaiKlDapTraDapDatThua:item.loaiKlDapTraDapDatThua || '0',
                        klDatThuaDapTraDapDat:item.klDatThuaDapTraDapDat || '0',
                   }));
                }

                const $table = $('#table_data');
                if ($.fn.DataTable.isDataTable($table)) {
                    $table.DataTable().clear().destroy();
                }

                $table.DataTable({
                    data: dataSet,
                    columns: [
                        { data: 'stt', className: 'text-center align-middle', width: '1%' },
                        { data: 'tenChiNhanh', className: 'align-middle' },
                        { data: 'tuyenDuong', className: 'align-middle' },
                        { data: 'lyTrinh', className: 'align-middle' },
                        { data: 'hangMucCongViec', className: 'align-middle' },
                        { data: 'tenHoVan', className: 'align-middle' },
                        { data: 'hinhThucDapTra', className: 'align-middle' },
                        { data: 'hangMucKlDao', className: 'align-middle' },
                        { data: 'loaiKlDao', className: 'align-middle' },
                        { data: 'klDao', className: 'align-middle' },
                        { data: 'hangMucKlDapTraDapCat', className: 'align-middle' },
                        { data: 'loaiKlDapTraDapCat', className: 'align-middle' },
                        { data: 'klDapCatSauCChoDapTraDapCat', className: 'align-middle' },
                        { data: 'hangMucKlDapTraDapDat', className: 'align-middle' },
                        { data: 'loaiKlDapTraDapDat', className: 'align-middle' },
                        { data: 'klDapDatSauCChoDapTraDapDat', className: 'align-middle' },
                        { data: 'hangMucKlDapTraDapDatThua', className: 'align-middle' },
                        { data: 'loaiKlDapTraDapDatThua', className: 'align-middle' },
                        { data: 'klDatThuaDapTraDapDat', className: 'align-middle' },
                             ],
                    autoWidth: false,
                    ordering: true,
                    searching: true,
                    paging: true,
                    pageLength: 10,
                    info: true,
                    language: {
                        lengthMenu: "Hiển thị _MENU_ bản ghi mỗi trang",
                        zeroRecords: "Không tìm thấy dữ liệu",
                        info: "Hiển thị _START_ đến _END_ của _TOTAL_ bản ghi",
                        infoEmpty: "Không có bản ghi nào",
                        infoFiltered: "(lọc từ _MAX_ bản ghi)",
                        search: "Tìm kiếm:",
                        paginate: {
                            first: "Đầu",
                            last: "Cuối",
                            next: "Sau",
                            previous: "Trước"
                        }
                    },
                    initComplete: function () {
                        this.api().columns().every(function (colIdx) {
                            var column = this;
                            var $footer = $(column.footer()).empty();
                            if (colIdx === 0) {
                                $footer.append('<p></p>');
                            }else{
                                var select = $('<select><option value=""></option></select>')
                                .appendTo($footer)
                                .on('change', function () {
                                    var val = $.fn.dataTable.util.escapeRegex($(this).val());
                                    column
                                        .search(val ? '^' + val + '$' : '', true, false)
                                        .draw();
                                });

                                column.data().unique().sort().each(function (d) {
                                    select.append('<option value="' + d + '">' + d + '</option>');
                                });
                            }
                            
                        });
                    }
                });
            }).fail(function (xhr) {
                var colCount = $('#table_data thead th').length;
                $('#table_data tbody').html('<tr><td colspan="' + colCount + '" class="text-left text-danger">Lỗi khi tải dữ liệu.</td></tr>');
            
            }).always(function () {
                hideBlockLoading('.table-responsive');
            });
        });
    }
</script>

