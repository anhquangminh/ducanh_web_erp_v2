    // Validate form
    function validateForm() {
        $('.is-invalid').removeClass('is-invalid');
        $('.invalid-feedback').remove();
        let isValid = true;
        let firstInvalid = null;
        const requiredFields = [
            { selector: '#id_ChiNhanh', message: 'Vui lòng chọn tên công trình.' },
            { selector: '#id_TuyenDuong', message: 'Vui lòng chọn tuyến đường.' },
            { selector: '#id_TuLyTrinh', message: 'Vui lòng chọn từ lý trình.' },
            { selector: '#id_DenLyTrinh', message: 'Vui lòng chọn dến lý trình.' },
            { selector: '#id_HangMucCongViec', message: 'Vui lòng chọn hạng mục công việc.' },
            { selector: '#id_LoaiCauKien', message: 'Vui lòng chọncấu kiện.' },
            { selector: '#id_HangMucKhoiLuong', message: 'Vui lòng chọn Hạng mục KL.' },
            { selector: '#id_LoaiKhoiLuong', message: 'Vui lòng chọnkhối lượng.' },
            { selector: '#id_TrangThaiThiCongOngNhua', message: 'Vui lòng chọn trạng thái thi công.' },
            { selector: '#id_HinhThucDapTra', message: 'Vui lòng chọn Hình thức đắp trả' },
            { selector: '#hangMucKlDaoDat', message: 'Vui lòng nhập Hạng mục KL.' },
            { selector: '#loaiKlDaoDat', message: 'Vui lòng nhập Loại KL.' },
            { selector: '#id_TrangThaiThiCongDaoDat', message: 'Vui lòng chọn Trạng thái thi công.' },
            { selector: '#hangMucKlDapCat', message: 'Vui lòng nhập Hạng mục KL.' },
            { selector: '#loaiKlDapCat', message: 'Vui lòng nhập Loại KL.' },
            { selector: '#id_TrangThaiThiCongDapCat', message: 'Vui lòng chọn Trạng thái thi công.' },
            { selector: '#hangMucKlDapDat', message: 'Vui lòng nhập Hạng mục KL.' },
            { selector: '#loaiKlDapDat', message: 'Vui lòng nhập Loại KL.' },
            { selector: '#id_TrangThaiThiCongDapDat', message: 'Vui lòng chọn Trạng thái thi công.' },
            { selector: '#hangMucKlDatThua', message: 'Vui lòng nhập Hạng mục KL.' },
            { selector: '#loaiKlDatThua', message: 'Vui lòng nhập Loại KL.' },
            { selector: '#id_TrangThaiThiCongDatThua', message: 'Vui lòng chọn Trạng thái thi công.' },
            { selector: '#x1', message: 'Vui lòng nhập tọa độ x.' },
            { selector: '#x2', message: 'Vui lòng nhập tọa độ x.' },
            { selector: '#y1', message: 'Vui lòng nhập tọa độ y.' },
            { selector: '#y2', message: 'Vui lòng nhập tọa độ y.' },
        ];
        requiredFields.forEach(f => {
            const $input = $(f.selector);
            if (!$(f.selector).val() || !$(f.selector).val().trim()) {
                showError(f.selector, f.message);
                if (!firstInvalid) firstInvalid = $input[0];
                isValid = false;
            }
        });

        if (!isValid && firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });

            const $el = $(firstInvalid);
            if ($el.hasClass("select2-hidden-accessible")) {
                $el.next('.select2-container').find('.select2-selection').focus();
            } else {
                $el.focus();
            }
        }

        return isValid;
    }

    // Hiển thị lỗi
    function showError(selector, message) {
        const $input = $(selector);
        $input.addClass('is-invalid');
        if ($input.next('.invalid-feedback').length === 0) {
            $input.after(`<div class="invalid-feedback">${message}</div>`);
        }
    }

    async function chiTiet(id) {
        const resUser = await getJwtToken();
        const token = resUser.token;

        // Show modal trước
        showGlobalModal("Lịch sử", `
            <div class="element-block-example" id="history-modal-body" style="min-height:150px;">
                <!-- Loading hoặc dữ liệu sẽ hiển thị ở đây -->
            </div>
        `, `<button class="btn btn-secondary" data-dismiss="modal">Đóng</button>`);
        showBlockLoading("#history-modal-body");
        
        try {
            const res = await $.ajax({
                url: `/api/PKKLOngNhua2TtChungNSachNgang/GetHistory?id=${id}`,
                method: "GET",
                headers: { Authorization: `Bearer ${token}` }
            });

            let content = "";
            if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                content = generateTableHTML(res.data); // Hàm tạo bảng
            } else {
                content = `<div class="text-center text-muted">Không có dữ liệu lịch sử.</div>`;
            }

            $("#history-modal-body").html(content);
        } catch (err) {
            $("#history-modal-body").html(`<div class="text-center text-danger">Lỗi khi tải dữ liệu.</div>`);
        } finally {
            hideBlockLoading("#history-modal-body");
        }
    }
