    async function showModalTaoMoi(isEdit = false, data = null) {
        const modalTitle = isEdit ? "Cập nhật " : "Thêm mới ";
        const resUser = await getJwtToken();
        const token = resUser.token;
        const groupId = resUser.userInfor.groupId;
        const userName = resUser.userInfor.userName;

        // Dropdowns mapping
        const dropdownApis = [
            { url: "/api/DMTuyenDuong/GetAll", id: ["id_TuyenDuong"], text: "Tuyến đường" },
            { url: "/api/DMLyTrinh/GetAll", id: ["id_TuLyTrinh","id_DenLyTrinh"], text: "Lý trình" },
            { url: "/api/DMHangMucCongViec/GetAll", id: ["id_HangMucCongViec"], text: "Hạng mục công việc" },
            { url: "/api/DMLoaiCauKien/GetAll", id: ["id_LoaiCauKien"], text: "Loại cấu kiện" },
            { url: "/api/DMHangMucKhoiLuong/GetAll", id: ["id_HangMucKhoiLuong", "id_HangMucKhoiLuongOngThep"], text: "Hạng mục khối lượng" },
            { url: "/api/DMLoaiKhoiLuong/GetAll", id: ["id_LoaiKhoiLuong", "id_LoaiKhoiLuongOngThep"], text: "Loại khối lượng" },
            { url: "/api/DMTrangThaiThiCong/GetAll", id: ["id_TrangThaiThiCongOngNhua", "id_TrangThaiThiCongOngThep", "id_TrangThaiThiCongDaoDat", "id_TrangThaiThiCongDapCat", "id_TrangThaiThiCongDapDat", "id_TrangThaiThiCongDatThua"], text: "Trạng thái thi công" },
            { url: "/api/DMLoaiCauKien/GetAll", id: ["id_LoaiCauKienOngThep"], text: "Loại cấu kiện" },
            { url: "/api/DMHinhThucDapTra/GetAll", id: ["id_HinhThucDapTra"], text: "Hình thức đắp trả" },
        ];

        const dropdowns = {};
        for (const item of dropdownApis) {
            let options = `<option value="">-- Chọn ${item.text} --</option>`;
            let resData = [];

            try {
                const res = await $.ajax({
                    url: `${item.url}?groupId=${groupId}`,
                    method: "GET",
                    headers: { "Authorization": `Bearer ${token}` }
                });
                if (res.success && Array.isArray(res.data)) {
                    resData = res.data;
                }
            } catch {
                options += '<option>Lỗi tải dữ liệu</option>';
            }

            for (const idKey of item.id) {
                let selectOptions = options;

                resData.forEach(x => {
                    const selected = data && data[idKey] === x.id ? 'selected' : '';
                    selectOptions += `<option value="${x.id}" ${selected}>${x.tenDanhMuc}</option>`;
                });

                dropdowns[idKey] = selectOptions;
            }
        }

