                <div class="table-responsive ">
                    <table class="table table-bordered  table-hover " id="table_qlnv" style="border-collapse: collapse">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Chi nhánh</th>
                                <th>Tên nhóm</th>
                                <th>Tên nhân viên</th>
                                <th>Trạng thái</th>
