                    <button data-permission-qlnv="Thêm_qlnv" class="mb-2 mr-2 btn-icon btn btn-primary" onclick="showModalQLNV()">
                        <i class="pe-7s-user btn-icon-wrapper"></i>Thêm nhân viên
                    </button>
