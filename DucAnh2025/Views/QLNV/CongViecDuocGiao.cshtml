    <style>
        @@import url('/css/qlnv_task_collaboration.css?v=1');

        .control-sidebar {
            position: fixed;
            bottom: 0;
            right: 0;
            background: #fff;
            color: #000;
            transition: transform 0.3s ease-in-out;
            box-shadow: -3px 0px 5px rgba(0, 0, 0, 0.2);
            z-index: 1007;
            border-left: 1px solid #ddd;
            display: flex;
            flex-direction: column;
            height: calc(100vh - 56px); /* Đảm bảo sidebar không bị che */
            transform: translateX(100%);
            margin-top: 10px;
        }

            .control-sidebar.open {
                transform: translateX(0);
            }

        .control-sidebar-header,
        .control-sidebar-footer {
            flex-shrink: 0;
            padding: 15px;
            font-weight: bold;
            border-bottom: 1px solid #ddd;
            background: #f8f9fa;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .control-sidebar-footer {
            border-top: 1px solid #ddd;
            justify-content: center;
        }

        .control-sidebar-body {
            flex-grow: 1;
            padding: 15px;
            overflow-y: auto; /* Cho phép cuộn */
        }

        .control-sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1006;
        }
    </style>

    <div class="control-sidebar " style="width: 600px;">
        <div class="control-sidebar-header d-flex justify-content-between align-items-center">
            <span>Chi tiết công việc</span>
            <button aria-label="Close" onclick="onCloseSidebar()" class="mb-2 mr-2 btn-icon btn-shadow btn-outline-2x btn btn-outline-link">
                <i class="fa fa-times btn-icon-wrapper"></i>
             </button>
        </div>
        <div class="control-sidebar-body">
            <form method="post" id="editFormId">
                <p class="text-danger"></p>
                <div class="row g-3">
                    <input id="idRowCongViec" hidden  class="form-control valid">
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group mb-3">
                            <label for="Id_NguoiGiaoViec">Người Giao việc <span class="text-danger">*</span></label>
                            <input id="Id_NguoiGiaoViec" readonly name="cvModel.Id_NguoiGiaoViec" class="form-control valid" >
                        </div>
                        <div class="form-group mb-3">
                            <label for="LapLai">Lặp lại <span class="text-danger">*</span></label>
                            <input id="LapLai" readonly name="cvModel.LapLai" class="form-control valid">
                        </div>
                        <div class="form-group mb-3">
                            <label for="NgayBatDau">Ngày bắt đầu <span class="text-danger">*</span></label>
                            <p id="NgayBatDau" readonly class="form-control valid"></p>
                            
                        </div>
                        <div class="form-group mb-3"><label for="FileDinhKem">File đính kèm <span class="text-danger">*</span></label></div>
                    </div>
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group mb-3">
                            <label for="TenNhom">Nhóm công việc <span class="text-danger">*</span></label>
                            <input id="TenNhom" readonly name="cvModel.TenNhom" class="form-control valid" >
                        </div>
                        <div class="form-group mb-3">
                            <label for="MucDoUuTien">Mức độ ưu tiên <span class="text-danger">*</span></label>
                            <input id="MucDoUuTien" readonly name="cvModel.MucDoUuTien" class="form-control valid">
                        </div>
                        <div class="form-group mb-3">
                            <label for="NgayKetThuc">Ngày kết thúc <span class="text-danger">*</span></label>
                            <p id="NgayKetThuc" readonly class="form-control valid"></p>
                            
                        </div>
                    </div>
                    <div class="col-12 form-group mb-3">
                        <label for="NguoiThucHien">Người thực hiện <span class="text-danger">*</span></label>
                        <textarea id="NguoiThucHien" readonly name="cvModel.NguoiThucHien" class="form-control valid" ></textarea>
                    </div>
                    <div class="col-12 form-group mb-3">
                        <label for="TenCongViec">Tên công việc <span class="text-danger">*</span></label>
                        <input id="TenCongViec" readonly name="cvModel.TenCongViec" class="form-control valid" />
                    </div>
                    <div class="col-12 form-group mb-3">
                        <label for="NoiDungCongViec">Nội dung công việc <span class="text-danger">*</span></label>
                        <textarea id="NoiDungCongViec" readonly name="cvModel.NoiDungCongViec" class="form-control valid" ></textarea>
                    </div>
                </div>

                <div class="row">
                    <p class="mt-4 mb-2">Công việc con</p>
                    <div class="table-responsive">
                        <table id="table_cvc" class="table table-striped table-hover">

                            <thead class="table-info">
                                <tr>
                                    <th>STT</th>
                                    <th>Nội dung công việc</th>
                                    <th>Tệp đính kèm</th>
                                    <th>Hoàn thành</th>
                                </tr>
                            </thead>
                            <tbody>
                               
                            </tbody>
                        </table>
                    </div>
                </div><div class="row">
                    <div class="col-12 form-group">
                        <label>Được đánh giá <span class="text-danger">*</span></label>
                        <input  id="duocDanhGia" type="number" readonly class="form-control">
                    </div>
                    <div class="col-12 form-group">
                        <label>Ghi chú<span class="text-danger">*</span></label>
                        <input  id="ghiChuDuocDanhGia" type="text" readonly class="form-control valid">
                    </div>
                </div><div class="row g-3">
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            <label for="TienDo">Tiến độ <span class="text-danger">*</span></label>
                            <input id="TienDo" type="number" name="Input.TienDo" class="form-control valid">
                        </div>
                    </div>
                    <div class="col-sm-12 col-md-6">
                        <div class="form-group">
                            <label for="TuDanhGia">Tự đánh giá <span class="text-danger">*</span></label>
                            <textarea id="TuDanhGia" name="Input.TuDanhGia" class="form-control valid"></textarea>

                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-12">
                        <div id="qlnv-task-collaboration-panel"></div>
                    </div>
                </div>
            </form>
        </div>
        <div class="control-sidebar-footer"><button class="btn btn-primary w-100" onclick="onCloseSidebar()">Đóng</button></div>
    </div>
    <div class="control-sidebar-overlay" style="display:none;"></div>
</div>

<script src="@Url.Content("~/js/QLNV/qlnv_task_collaboration.js?v=4")"></script>
<script src="@Url.Content("~/js/QLNV/qlnv_congviecduocgiao.js?v=5")"></script>
